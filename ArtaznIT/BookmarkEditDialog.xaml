<Window x:Class="ArtaznIT.BookmarkEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add to Favorites" Height="350" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#FF0D0D0D" ResizeMode="NoResize">

    <!-- TAG: #VERSION_7 #BOOKMARKS #UI -->

    <Window.Resources>
        <SolidColorBrush x:Key="AccentOrange" Color="#FFFF8533"/>
        <SolidColorBrush x:Key="TextMuted" Color="#FFA1A1AA"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FF1E1E1E" BorderBrush="{StaticResource AccentOrange}"
                BorderThickness="0,0,0,2" Padding="14,10" Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="⭐ ADD TO FAVORITES" Foreground="{StaticResource AccentOrange}"
                           FontSize="14" FontWeight="Bold"/>
                <TextBlock x:Name="TxtHostname" Text="Computer: " Foreground="{StaticResource TextMuted}"
                           FontSize="10" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Form -->
        <StackPanel Grid.Row="1">
            <!-- Category -->
            <TextBlock Text="Category *" Foreground="{StaticResource TextMuted}"
                       FontSize="10" Margin="0,0,0,4"/>
            <ComboBox x:Name="ComboCategory" Padding="10,8" FontSize="11"
                      Background="#FF1E1E1E" Foreground="White"
                      BorderBrush="#FF3C3C3C" BorderThickness="1"
                      Margin="0,0,0,14" IsEditable="True">
                <ComboBoxItem Content="Domain Controllers" IsSelected="True"/>
                <ComboBoxItem Content="SQL Servers"/>
                <ComboBoxItem Content="Web Servers"/>
                <ComboBoxItem Content="File Servers"/>
                <ComboBoxItem Content="Exchange Servers"/>
                <ComboBoxItem Content="Critical"/>
                <ComboBoxItem Content="General"/>
            </ComboBox>

            <!-- Description -->
            <TextBlock Text="Description / Notes" Foreground="{StaticResource TextMuted}"
                       FontSize="10" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtDescription" Padding="10,8" FontSize="11"
                     Background="#FF1E1E1E" Foreground="White"
                     BorderBrush="#FF3C3C3C" BorderThickness="1"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Height="80" Margin="0,0,0,0"/>
        </StackPanel>

        <!-- Footer Buttons -->
        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="⭐ ADD FAVORITE" x:Name="BtnSave" Click="BtnSave_Click"
                    Padding="14,8" FontSize="11" FontWeight="SemiBold"
                    BorderThickness="0" Foreground="White" Margin="0,0,8,0">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFFF8533" Offset="0"/>
                        <GradientStop Color="#FFCC6B29" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

            <Button Grid.Column="2" Content="CANCEL" x:Name="BtnCancel" Click="BtnCancel_Click"
                    Background="#FF3C3C3C" Foreground="White" BorderThickness="0"
                    Padding="14,8" FontSize="11" FontWeight="SemiBold"/>
        </Grid>
    </Grid>
</Window>
