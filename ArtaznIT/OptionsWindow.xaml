<Window x:Class="ArtaznIT.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ArtaznIT Options"
        Height="700" Width="800"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="#FF0D0D0D"
        ResizeMode="CanResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Match MainWindow color scheme -->
        <SolidColorBrush x:Key="BgDarkest" Color="#FF0D0D0D"/>
        <SolidColorBrush x:Key="BgDark" Color="#FF1A1A1A"/>
        <SolidColorBrush x:Key="BgCard" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="BorderDim" Color="#FF3C3C3C"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FFFF8533"/>
        <SolidColorBrush x:Key="AccentZinc" Color="#FFA1A1AA"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextMuted" Color="#FF888888"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#FF16C60C"/>
        <SolidColorBrush x:Key="DangerRed" Color="#FFE81123"/>

        <!-- Button Styles -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentOrange}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFF9944"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFDD6622"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#FF444444"/>
                                <Setter Property="Foreground" Value="#FF888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="{StaticResource DangerRed}"/>
        </Style>

        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource AccentZinc}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDim}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════ -->
        <!-- HEADER                           -->
        <!-- ════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource BgDark}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="30,0">
                    <TextBlock Text="⚙️ APPLICATION OPTIONS" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource AccentOrange}"/>
                    <TextBlock Text="Configure application settings and preferences"
                               FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Close Button -->
                <Button Grid.Column="1" Content="✕" Width="40" Height="40"
                        Margin="0,0,20,0" Click="BtnClose_Click"
                        Style="{StaticResource BtnGhost}" FontSize="18"/>
            </Grid>
        </Border>

        <!-- ════════════════════════════════ -->
        <!-- CONTENT (Scrollable)             -->
        <!-- ════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,20">

                <!-- Status Message (Hidden by default) -->
                <Border x:Name="StatusMessage" Background="{StaticResource BgCard}"
                        BorderBrush="{StaticResource AccentGreen}" BorderThickness="1"
                        CornerRadius="4" Padding="12,8" Margin="0,0,0,15"
                        Visibility="Collapsed">
                    <TextBlock x:Name="TxtStatusMessage" Foreground="{StaticResource AccentGreen}"
                               FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>

                <!-- ══════════════════════════════ -->
                <!-- SECTION 1: ADMIN TOOLS        -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderAdminTools" Header="🔧 ADMIN &amp; DEBUGGING TOOLS"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="ADMIN LAUNCHER SETUP" Foreground="{StaticResource AccentOrange}"
                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>

                            <!-- Create Shortcut Button - TAG: #ADMIN_TOOLS -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource AccentOrange}"
                                    BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,8"
                                    Cursor="Hand" MouseEnter="DebugButton_MouseEnter" MouseLeave="DebugButton_MouseLeave"
                                    MouseLeftButtonDown="CreateShortcut_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="🚀" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock x:Name="DebugButtonText" Text="Create Admin Launcher Shortcut"
                                                  Foreground="{StaticResource AccentOrange}" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Text="Creates a desktop shortcut to launch ArtaznIT Suite as domain admin"
                                                  Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <TextBlock Text="ℹ️ This tool creates a secure launcher that remembers your admin credentials using Windows Credential Manager. Perfect for testing or if you accidentally deleted the shortcut."
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" LineHeight="14"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION 2: GENERAL SETTINGS   -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderGeneral" Header="⚙️ GENERAL SETTINGS"
                          IsExpanded="True" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <!-- Last Username -->
                            <TextBlock Text="Cached Username:" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                            <Grid Margin="0,4,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtLastUser" Grid.Column="0" IsReadOnly="True"
                                         Background="{StaticResource BgDark}" Foreground="White"
                                         BorderBrush="{StaticResource BorderDim}" Padding="8,6" FontSize="11"/>
                                <Button Grid.Column="1" Content="CLEAR" Style="{StaticResource BtnDanger}"
                                        Click="BtnClearLastUser_Click" Margin="8,0,0,0" Padding="12,6" FontSize="10"/>
                            </Grid>

                            <!-- Remember DC Selection -->
                            <CheckBox x:Name="ChkRememberDC" Content="Remember Domain Controller selection"
                                      Foreground="White" FontSize="11" Margin="0,0,0,12"/>

                            <!-- AD Query Method - TAG: #VERSION_7 #AD_QUERY_BACKEND_SELECTION #PERFORMANCE_AUDIT -->
                            <TextBlock Text="AD Query Method:" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox x:Name="ComboADQueryMethod" Margin="0,0,0,12"
                                      Background="{StaticResource BgDark}" Foreground="White"
                                      BorderBrush="{StaticResource BorderDim}" Padding="8,6" FontSize="11"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Content="DirectorySearcher (Fast)" Tag="DirectorySearcher" IsSelected="True"/>
                                <ComboBoxItem Content="ActiveDirectoryManager (Detailed)" Tag="ActiveDirectoryManager"/>
                            </ComboBox>
                            <TextBlock Text="💡 DirectorySearcher is faster for large environments. ActiveDirectoryManager provides richer AD object properties."
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="14"/>

                            <!-- Target History -->
                            <TextBlock Text="Recent Targets:" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,6"/>
                            <ListBox x:Name="ListTargetHistory" Height="120" Background="{StaticResource BgDark}"
                                     BorderBrush="{StaticResource BorderDim}" Foreground="White" FontSize="11" Margin="0,0,0,8"/>
                            <Button Content="CLEAR HISTORY" Style="{StaticResource BtnDanger}"
                                    Click="BtnClearHistory_Click" Padding="12,6" FontSize="10"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION 3: GLOBAL SERVICES    -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderGlobalServices" Header="🌐 GLOBAL SERVICES CONFIGURATION"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Configure which cloud services to monitor for status and uptime. You can use the visual editor or edit the raw JSON configuration."
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="14"/>

                            <!-- Tab Selector - TAG: #THEME_COLORS -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnVisualEditor" Content="📋 VISUAL EDITOR" Grid.Column="0"
                                        Background="{StaticResource AccentOrange}" Foreground="White" BorderThickness="0"
                                        Padding="8,6" FontSize="10" FontWeight="Bold" Margin="0,0,2,0"
                                        Click="BtnVisualEditor_Click" Cursor="Hand"/>
                                <Button x:Name="BtnJsonEditor" Content="{}{} JSON EDITOR" Grid.Column="1"
                                        Background="#FF2A2A2A" Foreground="{StaticResource TextMuted}" BorderThickness="0"
                                        Padding="8,6" FontSize="10" FontWeight="Bold" Margin="2,0,0,0"
                                        Click="BtnJsonEditor_Click" Cursor="Hand"/>
                            </Grid>

                            <!-- Visual Editor Panel -->
                            <StackPanel x:Name="VisualEditorPanel" Margin="0,0,0,0">
                                <TextBlock Text="SERVICES LIST" Foreground="{StaticResource AccentOrange}"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>

                                <!-- Services DataGrid - TAG: #GLOBAL_SERVICES -->
                                <DataGrid x:Name="GridServicesConfig"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="True"
                                          CanUserDeleteRows="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          Background="{StaticResource BgCard}"
                                          Foreground="#FFE0E0E0"
                                          BorderBrush="{StaticResource BorderDim}"
                                          BorderThickness="1"
                                          RowBackground="#FF2A2A2A"
                                          AlternatingRowBackground="#FF252525"
                                          FontSize="10"
                                          Height="200"
                                          Margin="0,0,0,12">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="{StaticResource BgDark}"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="10"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AccentOrange}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FF353535"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#FF404040"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Service Name" Binding="{Binding ServiceName}" Width="140">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                                    <Setter Property="Padding" Value="4,2"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                                    <Setter Property="Background" Value="#FF1A1A1A"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentOrange}"/>
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="API Endpoint / IP" Binding="{Binding Endpoint}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                                    <Setter Property="Padding" Value="4,2"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                                    <Setter Property="Background" Value="#FF1A1A1A"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentOrange}"/>
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="💡 TIP: Use 'ping:IP' for simple ping checks (e.g., ping:8.8.8.8) or full HTTPS URLs for status APIs"
                                           Foreground="{StaticResource AccentOrange}" FontSize="8" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="12"/>
                            </StackPanel>

                            <!-- JSON Editor Panel -->
                            <StackPanel x:Name="JsonEditorPanel" Visibility="Collapsed">
                                <TextBlock Text="RAW JSON CONFIGURATION" Foreground="{StaticResource AccentOrange}"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>

                                <TextBox x:Name="TxtJsonConfig"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="{StaticResource BgDark}"
                                         Foreground="#FF00FF00"
                                         BorderBrush="{StaticResource BorderDim}"
                                         BorderThickness="1"
                                         Padding="10"
                                         FontFamily="Consolas"
                                         FontSize="9"
                                         Height="220"
                                         Margin="0,0,0,12"/>

                                <TextBlock Text="⚠️ JSON Format: [{}ServiceName:Azure, Endpoint:https://... (use editor above)]"
                                           Foreground="#FFFF6B6B" FontSize="8" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="12"/>
                            </StackPanel>

                            <!-- Action Buttons -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="💾 SAVE" x:Name="BtnSaveServicesConfig"
                                        Background="#FF00C853" Foreground="White" BorderThickness="0"
                                        Padding="8,6" FontSize="10" FontWeight="Bold" Margin="0,0,3,0"
                                        Click="BtnSaveServicesConfig_Click" Cursor="Hand"/>
                                <Button Grid.Column="1" Content="🔄 RESET TO DEFAULTS" x:Name="BtnResetServicesConfig"
                                        Background="#FFFF6B6B" Foreground="White" BorderThickness="0"
                                        Padding="8,6" FontSize="9" FontWeight="Bold" Margin="1.5,0,1.5,0"
                                        Click="BtnResetServicesConfig_Click" Cursor="Hand"/>
                                <Button Grid.Column="2" Content="🧪 TEST APIS" x:Name="BtnTestAPIs"
                                        Background="#FF2196F3" Foreground="White" BorderThickness="0"
                                        Padding="8,6" FontSize="10" FontWeight="Bold" Margin="3,0,0,0"
                                        Click="BtnTestAPIs_Click" Cursor="Hand"/>
                            </Grid>

                            <TextBlock x:Name="TxtConfigStatus" Text="" Foreground="#FF00FF00"
                                       FontSize="9" FontWeight="Bold" Margin="0,8,0,0"
                                       HorizontalAlignment="Center" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION 4: PINNED DEVICES     -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderPinnedDevices" Header="📌 PINNED DEVICES MANAGEMENT"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Manage devices pinned for quick status monitoring (max 10)"
                                       Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,0,0,12"/>

                            <!-- Pinned Devices DataGrid -->
                            <DataGrid x:Name="GridPinnedDevicesManager" AutoGenerateColumns="False"
                                      CanUserAddRows="False" Height="200" Margin="0,0,0,12"
                                      Background="{StaticResource BgDark}"
                                      Foreground="#FFE0E0E0"
                                      BorderBrush="{StaticResource BorderDim}"
                                      BorderThickness="1"
                                      RowBackground="#FF2A2A2A"
                                      AlternatingRowBackground="#FF252525"
                                      FontSize="10"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource BgDark}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentOrange}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FF353535"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#FF404040"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Device" Binding="{Binding Input}" Width="*" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Last Checked" Binding="{Binding LastChecked}" Width="120" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- First Row: Import/Template buttons -->
                                <Button Grid.Row="0" Grid.Column="0" Content="📥 IMPORT FROM CSV" Style="{StaticResource BtnPrimary}"
                                        Click="BtnImportPinnedCsv_Click" Padding="12,6" FontSize="10" Margin="0,0,0,8"/>
                                <Button Grid.Row="0" Grid.Column="1" Content="📋 DOWNLOAD TEMPLATE" Style="{StaticResource BtnGhost}"
                                        Click="BtnDownloadTemplate_Click" Margin="8,0,0,8" Padding="12,6" FontSize="10"/>

                                <!-- Second Row: Clear/Export buttons -->
                                <Button Grid.Row="1" Grid.Column="0" Content="CLEAR ALL PINNED DEVICES" Style="{StaticResource BtnDanger}"
                                        Click="BtnClearAllPinned_Click" Padding="12,6" FontSize="10"/>
                                <Button Grid.Row="1" Grid.Column="1" Content="📤 EXPORT TO CSV" Style="{StaticResource BtnGhost}"
                                        Click="BtnExportPinned_Click" Margin="8,0,0,0" Padding="12,6" FontSize="10"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION 5: PERFORMANCE        -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderPerformance" Header="🔧 PERFORMANCE &amp; THREADING"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Column -->
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <!-- Max Parallel Scans -->
                                <TextBlock Text="Max Parallel Scans:" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <Grid Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SliderMaxParallel" Grid.Column="0" Minimum="1" Maximum="100"
                                            Value="30" TickFrequency="10" IsSnapToTickEnabled="False"
                                            ValueChanged="SliderMaxParallel_ValueChanged"/>
                                    <TextBox x:Name="TxtMaxParallel" Grid.Column="1" Text="30" TextAlignment="Center"
                                             Background="{StaticResource BgDark}" Foreground="White"
                                             BorderBrush="{StaticResource BorderDim}" Padding="4" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- WMI Timeout -->
                                <TextBlock Text="WMI Timeout (ms):" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <TextBox x:Name="TxtWmiTimeout" Text="15000" Margin="0,4,0,12"
                                         Background="{StaticResource BgDark}" Foreground="White"
                                         BorderBrush="{StaticResource BorderDim}" Padding="8,6"/>
                            </StackPanel>

                            <!-- Right Column -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <!-- Ping Timeout -->
                                <TextBlock Text="Ping Timeout (ms):" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <TextBox x:Name="TxtPingTimeout" Text="1200" Margin="0,4,0,12"
                                         Background="{StaticResource BgDark}" Foreground="White"
                                         BorderBrush="{StaticResource BorderDim}" Padding="8,6"/>

                                <!-- Max Retry Attempts -->
                                <TextBlock Text="Max Retry Attempts:" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <TextBox x:Name="TxtMaxRetry" Text="3" Margin="0,4,0,12"
                                         Background="{StaticResource BgDark}" Foreground="White"
                                         BorderBrush="{StaticResource BorderDim}" Padding="8,6"/>

                                <!-- Cache Cleanup - TAG: #VERSION_7 #CACHE #PERFORMANCE_AUDIT -->
                                <TextBlock Text="Failure Cache:" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,8,0,4"/>
                                <Button Content="🗑 CLEAR FAILURE CACHE" Style="{StaticResource BtnGhost}"
                                        Click="BtnClearFailureCache_Click" Padding="12,6" FontSize="10" HorizontalAlignment="Stretch"/>
                                <TextBlock Text="💡 Cache automatically sizes based on AD computer count (2× limit, max 10000)"
                                           Foreground="{StaticResource TextMuted}" FontSize="8" TextWrapping="Wrap" Margin="0,4,0,0" LineHeight="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION 6: APPEARANCE         -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderAppearance" Header="🎨 APPEARANCE &amp; BRANDING"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Column: Logo & Colors -->
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <!-- Custom Logo - TAG: #LOGO_PLACEMENT #BRANDING -->
                                <TextBlock Text="Custom Logo:" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold"/>
                                <Grid Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtLogoPath" Grid.Column="0" IsReadOnly="True"
                                             Background="{StaticResource BgDark}" Foreground="White"
                                             BorderBrush="{StaticResource BorderDim}" Padding="8,6" FontSize="10"
                                             Text="(Using default Artazn logo)"/>
                                    <Button Grid.Column="1" Content="BROWSE" Style="{StaticResource BtnPrimary}"
                                            Click="BtnBrowseLogo_Click" Margin="8,0,0,0" Padding="12,6" FontSize="10"/>
                                </Grid>

                                <!-- Logo Preview -->
                                <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                        BorderThickness="1" Padding="10" Margin="0,0,0,12" Height="80">
                                    <Viewbox x:Name="LogoPreview" Stretch="Uniform" HorizontalAlignment="Center">
                                        <TextBlock Text="A" FontSize="48" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentOrange}"/>
                                    </Viewbox>
                                </Border>

                                <!-- Logo Size -->
                                <TextBlock Text="Logo Size:" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <Grid Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SliderLogoSize" Grid.Column="0" Minimum="32" Maximum="128"
                                            Value="64" TickFrequency="16" IsSnapToTickEnabled="False"/>
                                    <TextBox x:Name="TxtLogoSize" Grid.Column="1" Text="64" TextAlignment="Center"
                                             Background="{StaticResource BgDark}" Foreground="White"
                                             BorderBrush="{StaticResource BorderDim}" Padding="4" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- Primary Accent Color - TAG: #THEME_COLORS -->
                                <TextBlock Text="Primary Accent Color (Orange):" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <Grid Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="PrimaryColorPreview" Grid.Column="0" Width="40" Height="30"
                                            Background="#FFFF8533" BorderBrush="{StaticResource BorderDim}"
                                            BorderThickness="1" Margin="0,0,8,0" Cursor="Hand"
                                            MouseLeftButtonDown="PrimaryColorPreview_Click"
                                            ToolTip="Click to open color picker"/>
                                    <TextBox x:Name="TxtPrimaryColor" Grid.Column="1" Text="#FFFF8533"
                                             Background="{StaticResource BgDark}" Foreground="White"
                                             BorderBrush="{StaticResource BorderDim}" Padding="8,6" FontSize="10"
                                             TextChanged="TxtPrimaryColor_TextChanged"/>
                                </Grid>

                                <!-- Secondary Accent Color -->
                                <TextBlock Text="Secondary Accent Color (Zinc):" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <Grid Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="SecondaryColorPreview" Grid.Column="0" Width="40" Height="30"
                                            Background="#FFA1A1AA" BorderBrush="{StaticResource BorderDim}"
                                            BorderThickness="1" Margin="0,0,8,0" Cursor="Hand"
                                            MouseLeftButtonDown="SecondaryColorPreview_Click"
                                            ToolTip="Click to open color picker"/>
                                    <TextBox x:Name="TxtSecondaryColor" Grid.Column="1" Text="#FFA1A1AA"
                                             Background="{StaticResource BgDark}" Foreground="White"
                                             BorderBrush="{StaticResource BorderDim}" Padding="8,6" FontSize="10"
                                             TextChanged="TxtSecondaryColor_TextChanged"/>
                                </Grid>
                            </StackPanel>

                            <!-- Right Column: Preview & Actions -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <!-- Preview Panel -->
                                <TextBlock Text="Preview:" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold"/>
                                <Border Background="{StaticResource BgDarkest}" BorderBrush="{StaticResource BorderDim}"
                                        BorderThickness="1" Padding="15" Margin="0,4,0,12" Height="200">
                                    <StackPanel>
                                        <TextBlock Text="Artazn LLC" FontSize="18" FontWeight="Bold" Margin="0,0,0,8">
                                            <TextBlock.Foreground>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop x:Name="PreviewPrimaryStop" Color="#FFFF8533" Offset="0"/>
                                                    <GradientStop x:Name="PreviewSecondaryStop" Color="#FFA1A1AA" Offset="0.7"/>
                                                </LinearGradientBrush>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                        <TextBlock Text="I T   M A N A G E M E N T   S U I T E" FontSize="7"
                                                   Foreground="{StaticResource AccentOrange}" FontWeight="Bold" Opacity="0.8"/>
                                        <Border Height="1" Background="{StaticResource BorderDim}" Margin="0,10"/>
                                        <Button Content="Sample Button" Padding="12,6" FontSize="11" Margin="0,10,0,0">
                                            <Button.Background>
                                                <SolidColorBrush x:Name="PreviewButtonBg" Color="#FFFF8533"/>
                                            </Button.Background>
                                            <Button.Foreground>
                                                <SolidColorBrush Color="White"/>
                                            </Button.Foreground>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <!-- Font Settings -->
                                <TextBlock Text="Font Family:" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <ComboBox x:Name="CmbFontFamily" Margin="0,4,0,12"
                                          Background="{StaticResource BgDark}" Foreground="White"
                                          BorderBrush="{StaticResource BorderDim}" Padding="8,6" FontSize="10">
                                    <ComboBoxItem Content="Segoe UI (Default)" IsSelected="True"/>
                                    <ComboBoxItem Content="Arial"/>
                                    <ComboBoxItem Content="Calibri"/>
                                    <ComboBoxItem Content="Consolas"/>
                                    <ComboBoxItem Content="Courier New"/>
                                </ComboBox>

                                <!-- Action Buttons -->
                                <Button Content="🔄 RESET TO DEFAULTS" Style="{StaticResource BtnDanger}"
                                        Click="BtnResetAppearance_Click" Padding="12,8" FontSize="10" Margin="0,20,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION: FONT SIZE - TAG: #VERSION_7 #QUICK_WINS -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderFontSize" Header="🔤 FONT SIZE"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Adjust the font size multiplier for the entire application (0.8x - 2.0x)"
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="14"/>

                            <!-- Font Size Slider -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Font Size:" Foreground="White" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>

                                <Slider x:Name="SliderFontSize" Grid.Column="1" Minimum="0.8" Maximum="2.0"
                                        Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                        ValueChanged="SliderFontSize_ValueChanged"
                                        VerticalAlignment="Center"/>

                                <TextBlock x:Name="TxtFontSizeValue" Grid.Column="2" Text="1.0x" FontWeight="Bold"
                                           Foreground="{StaticResource AccentOrange}" FontSize="12"
                                           VerticalAlignment="Center" Margin="12,0,0,0" MinWidth="50"/>
                            </Grid>

                            <!-- Preview Text -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                <TextBlock x:Name="TxtFontPreview" Text="The quick brown fox jumps over the lazy dog. 0123456789"
                                           Foreground="White" FontSize="12" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Action Buttons -->
                            <StackPanel Orientation="Horizontal">
                                <Button Content="✓ APPLY" Style="{StaticResource BtnPrimary}"
                                        Click="BtnApplyFontSize_Click" Padding="12,6" FontSize="10" Margin="0,0,8,0"/>
                                <Button Content="↺ RESET TO DEFAULT (1.0x)" Style="{StaticResource BtnGhost}"
                                        Click="BtnResetFontSize_Click" Padding="12,6" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION: AUTO-SAVE - TAG: #VERSION_7 #QUICK_WINS -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderAutoSave" Header="💾 AUTO-SAVE &amp; BACKUP"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Automatically save inventory backups at regular intervals. Backups are stored in %AppData%\ArtaznIT\AutoSave\"
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="14"/>

                            <!-- Enable/Disable Auto-Save -->
                            <CheckBox x:Name="ChkAutoSaveEnabled" Content="Enable automatic backups"
                                      Foreground="White" FontSize="11" Margin="0,0,0,12"
                                      Checked="ChkAutoSaveEnabled_Changed" Unchecked="ChkAutoSaveEnabled_Changed"/>

                            <!-- Interval Setting -->
                            <StackPanel x:Name="PanelAutoSaveSettings" Margin="0,0,0,12">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Save interval:" Foreground="White" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBox x:Name="TxtAutoSaveInterval" Grid.Column="1" Text="5"
                                             Background="{StaticResource BgDark}" Foreground="White"
                                             BorderBrush="{StaticResource BorderDim}" Padding="8,6" FontSize="11"/>
                                    <TextBlock Grid.Column="2" Text="minutes (1-60)" Foreground="{StaticResource TextMuted}" FontSize="11"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>

                                <TextBlock Text="💡 Backups are automatically cleaned up (last 10 kept)"
                                           Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,0,0,0"/>
                            </StackPanel>

                            <!-- Manual Backup Button -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Manual Backup" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="Create a backup of the current inventory right now"
                                                   Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <Button Grid.Column="1" Content="💾 BACKUP NOW" Style="{StaticResource BtnPrimary}"
                                            Click="BtnManualBackup_Click" Padding="12,6" FontSize="10"/>
                                </Grid>
                            </Border>

                            <!-- View Backups Button -->
                            <Button Content="📂 OPEN BACKUP FOLDER" Style="{StaticResource BtnGhost}"
                                    Click="BtnOpenBackupFolder_Click" Padding="12,6" FontSize="10" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION: CONNECTION PROFILES - TAG: #VERSION_7 #CONNECTION_PROFILES -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderConnectionProfiles" Header="🔌 CONNECTION PROFILES"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Save frequently used domain controller configurations for quick access"
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="14"/>

                            <!-- Profiles List -->
                            <DataGrid x:Name="GridConnectionProfiles" AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="{StaticResource BgDark}" Foreground="#FFE0E0E0"
                                      BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                                      RowBackground="#FF1A1A1A" AlternatingRowBackground="#FF151515"
                                      FontSize="10" Height="180" Margin="0,0,0,12">

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource BgDark}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </DataGrid.CellStyle>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Profile Name" Binding="{Binding ProfileName}" Width="150"/>
                                    <DataGridTextColumn Header="Domain/Server" Binding="{Binding ServerAddress}" Width="200"/>
                                    <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="150"/>
                                    <DataGridTemplateColumn Header="Actions" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="✓ LOAD" Tag="{Binding}" Background="#FF16C60C" Foreground="White"
                                                            BorderThickness="0" Padding="10,4" Margin="0,0,8,0" FontSize="9"
                                                            Click="BtnLoadProfile_Click" Cursor="Hand"/>
                                                    <Button Content="✏ EDIT" Tag="{Binding}" Background="#FF2A2A2A" Foreground="White"
                                                            BorderThickness="0" Padding="10,4" Margin="0,0,8,0" FontSize="9"
                                                            Click="BtnEditProfile_Click" Cursor="Hand"/>
                                                    <Button Content="🗑 DELETE" Tag="{Binding}" Background="{StaticResource DangerRed}" Foreground="White"
                                                            BorderThickness="0" Padding="10,4" FontSize="9"
                                                            Click="BtnDeleteProfile_Click" Cursor="Hand"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Add New Profile -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Add New Profile"
                                               Foreground="{StaticResource AccentOrange}" FontSize="11" FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Profile Name:" Foreground="White" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,8,4"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtNewProfileName"
                                             Background="#FF0D0D0D" Foreground="White" BorderBrush="{StaticResource BorderDim}"
                                             Padding="6,4" FontSize="10" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Server/Domain:" Foreground="White" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,8,4"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtNewProfileServer"
                                             Background="#FF0D0D0D" Foreground="White" BorderBrush="{StaticResource BorderDim}"
                                             Padding="6,4" FontSize="10" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Username:" Foreground="White" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtNewProfileUsername"
                                             Background="#FF0D0D0D" Foreground="White" BorderBrush="{StaticResource BorderDim}"
                                             Padding="6,4" FontSize="10"/>
                                </Grid>
                            </Border>

                            <!-- Add Button -->
                            <Button Content="➕ ADD PROFILE" Style="{StaticResource BtnPrimary}"
                                    Click="BtnAddProfile_Click" Padding="12,6" FontSize="10" HorizontalAlignment="Left"/>

                            <TextBlock Text="💡 Profiles are stored locally. Credentials are saved securely in Windows Credential Manager."
                                       Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,12,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION: BOOKMARKS/FAVORITES - TAG: #VERSION_7 #BOOKMARKS -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderBookmarks" Header="⭐ BOOKMARKS / FAVORITES"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Save frequently accessed servers and devices for quick access"
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="14"/>

                            <!-- Bookmarks List -->
                            <DataGrid x:Name="GridBookmarks" AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="{StaticResource BgDark}" Foreground="#FFE0E0E0"
                                      BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                                      RowBackground="#FF1A1A1A" AlternatingRowBackground="#FF151515"
                                      FontSize="10" Height="200" Margin="0,0,0,12">

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource BgDark}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </DataGrid.CellStyle>

                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="⭐" Width="30">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="⭐" FontSize="12" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="150"/>
                                    <DataGridTextColumn Header="Hostname/IP" Binding="{Binding Hostname}" Width="150"/>
                                    <DataGridTextColumn Header="Folder" Binding="{Binding Folder}" Width="100"/>
                                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                                    <DataGridTemplateColumn Header="Actions" Width="180">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="📋 COPY" Tag="{Binding}" Background="#FF2A2A2A" Foreground="White"
                                                            BorderThickness="0" Padding="8,4" Margin="0,0,6,0" FontSize="9"
                                                            Click="BtnCopyBookmark_Click" Cursor="Hand"/>
                                                    <Button Content="✏ EDIT" Tag="{Binding}" Background="#FF2A2A2A" Foreground="White"
                                                            BorderThickness="0" Padding="8,4" Margin="0,0,6,0" FontSize="9"
                                                            Click="BtnEditBookmark_Click" Cursor="Hand"/>
                                                    <Button Content="🗑 DELETE" Tag="{Binding}" Background="{StaticResource DangerRed}" Foreground="White"
                                                            BorderThickness="0" Padding="8,4" FontSize="9"
                                                            Click="BtnDeleteBookmark_Click" Cursor="Hand"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Add New Bookmark -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Add New Bookmark"
                                               Foreground="{StaticResource AccentOrange}" FontSize="11" FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Display Name:" Foreground="White" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,8,4"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtNewBookmarkName"
                                             Background="#FF0D0D0D" Foreground="White" BorderBrush="{StaticResource BorderDim}"
                                             Padding="6,4" FontSize="10" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Hostname/IP:" Foreground="White" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,8,4"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtNewBookmarkHost"
                                             Background="#FF0D0D0D" Foreground="White" BorderBrush="{StaticResource BorderDim}"
                                             Padding="6,4" FontSize="10" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Folder (optional):" Foreground="White" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,8,4"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtNewBookmarkFolder"
                                             Background="#FF0D0D0D" Foreground="White" BorderBrush="{StaticResource BorderDim}"
                                             Padding="6,4" FontSize="10" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Notes (optional):" Foreground="White" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtNewBookmarkNotes"
                                             Background="#FF0D0D0D" Foreground="White" BorderBrush="{StaticResource BorderDim}"
                                             Padding="6,4" FontSize="10"/>
                                </Grid>
                            </Border>

                            <!-- Add Button -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="➕ ADD BOOKMARK" Style="{StaticResource BtnPrimary}"
                                        Click="BtnAddBookmark_Click" Padding="12,6" FontSize="10" Margin="0,0,8,0"/>
                                <Button Content="📂 IMPORT FROM CSV" Style="{StaticResource BtnGhost}"
                                        Click="BtnImportBookmarks_Click" Padding="12,6" FontSize="10" Margin="0,0,8,0"/>
                                <Button Content="📤 EXPORT TO CSV" Style="{StaticResource BtnGhost}"
                                        Click="BtnExportBookmarks_Click" Padding="12,6" FontSize="10"/>
                            </StackPanel>

                            <TextBlock Text="💡 Use folders to organize bookmarks (e.g., 'Production', 'Development', 'Critical')"
                                       Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,0,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- ════════════════════════════════ -->
        <!-- FOOTER BUTTONS                   -->
        <!-- ════════════════════════════════ -->
        <Border Grid.Row="2" Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                BorderThickness="0,1,0,0" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Reset All -->
                <Button Grid.Column="0" Content="🔄 RESET ALL" Style="{StaticResource BtnDanger}"
                        Click="BtnResetAll_Click" Padding="14,8" FontSize="11" Margin="0,0,10,0"/>

                <!-- TAG: #VERSION_7 #EXPORT_IMPORT - Backup/Restore All Settings -->
                <Button Grid.Column="1" Content="📤 EXPORT ALL" Style="{StaticResource BtnGhost}"
                        Click="BtnExportAllSettings_Click" Padding="14,8" FontSize="10" Margin="0,0,10,0"/>

                <Button Grid.Column="2" Content="📥 IMPORT ALL" Style="{StaticResource BtnGhost}"
                        Click="BtnImportAllSettings_Click" Padding="14,8" FontSize="10"/>

                <!-- Spacer -->
                <StackPanel Grid.Column="3"/>

                <!-- Cancel -->
                <Button Grid.Column="4" Content="CANCEL" Style="{StaticResource BtnGhost}"
                        Click="BtnCancel_Click" Padding="20,8" Margin="0,0,10,0" FontSize="11"/>

                <!-- Apply -->
                <Button Grid.Column="5" Content="APPLY" Style="{StaticResource BtnPrimary}"
                        Click="BtnApply_Click" Padding="20,8" Margin="0,0,10,0" FontSize="11"/>

                <!-- Save & Close -->
                <Button Grid.Column="6" Content="SAVE &amp; CLOSE" Style="{StaticResource BtnPrimary}"
                        Click="BtnSaveAndClose_Click" Padding="20,8" FontSize="11"/>
            </Grid>
        </Border>

    </Grid>
</Window>
