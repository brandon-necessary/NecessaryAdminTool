<Window x:Class="ArtaznIT.ScriptExecutorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📜 PowerShell Script Executor"
        Height="700" Width="1200"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource MicaBrush}"
        FontFamily="{StaticResource FluentFont}"
        Loaded="Window_Loaded">

    <!-- TAG: #AUTO_UPDATE_UI_ENGINE #FLUENT_THEME -->

    <Window.Resources>
        <!-- Orange/Zinc Theme Buttons -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF6B35" Offset="0"/>
                        <GradientStop Color="#71797E" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource MicaAltBrush}" Padding="16"
                CornerRadius="{StaticResource FluentCornerRadius}" Margin="0,0,0,12"
                Effect="{StaticResource Elevation2dp}">
            <StackPanel>
                <TextBlock Text="📜 PowerShell Script Executor"
                           FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Run PowerShell scripts on multiple computers simultaneously"
                           FontSize="12" Foreground="#AAA" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Script Library -->
            <Border Grid.Column="0" Background="{StaticResource MicaAltBrush}" Padding="12"
                    CornerRadius="{StaticResource FluentCornerRadius}" Margin="0,0,8,0"
                    Effect="{StaticResource Elevation2dp}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Library Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="📚 Script Library" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock x:Name="TxtScriptCount" Text="0 scripts" FontSize="10" Foreground="#888" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Script List -->
                    <ListBox x:Name="ListScripts" Grid.Row="1"
                             Background="#0D0D0D"
                             BorderBrush="#333" BorderThickness="1"
                             Foreground="White"
                             SelectionChanged="ListScripts_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock>
                                        <Run Text="{Binding CategoryIcon}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding Name}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="10"
                                               Foreground="#888"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Library Actions -->
                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <Button Content="➕ New Script" Style="{StaticResource BtnPrimary}"
                                Click="BtnNewScript_Click" Margin="0,0,0,6"/>
                        <Button Content="📥 Import .ps1" Style="{StaticResource BtnSecondary}"
                                Click="BtnImportScript_Click" Margin="0,0,0,6"/>
                        <Button Content="🗑️ Delete" Style="{StaticResource BtnSecondary}"
                                x:Name="BtnDeleteScript"
                                Click="BtnDeleteScript_Click" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right Panel: Script Editor & Execution -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="250"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Script Details -->
                <Border Grid.Row="0" Background="#1A1A1A" Padding="12" CornerRadius="6" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Script Name:" FontSize="10" Foreground="#888"/>
                            <TextBox x:Name="TxtScriptName"
                                     Background="#0D0D0D" Foreground="White"
                                     BorderBrush="#444" Padding="6"
                                     FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,8,0,0">
                            <TextBlock Text="Description:" FontSize="10" Foreground="#888"/>
                            <TextBox x:Name="TxtScriptDescription"
                                     Background="#0D0D0D" Foreground="White"
                                     BorderBrush="#444" Padding="6"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                    Margin="12,0,0,0" VerticalAlignment="Center">
                            <Button Content="💾 Save" Style="{StaticResource BtnPrimary}"
                                    Width="100" Margin="0,0,0,6"
                                    Click="BtnSaveScript_Click"/>
                            <Button Content="📤 Export .ps1" Style="{StaticResource BtnSecondary}"
                                    Width="100"
                                    Click="BtnExportScript_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Script Editor -->
                <Border Grid.Row="1" Background="#1A1A1A" Padding="12" CornerRadius="6" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="📝 Script Content (PowerShell)"
                                   FontSize="12" FontWeight="SemiBold" Foreground="White"
                                   Margin="0,0,0,8"/>

                        <TextBox x:Name="TxtScriptContent" Grid.Row="1"
                                 Background="#0D0D0D" Foreground="#00FF00"
                                 BorderBrush="#444" BorderThickness="1"
                                 FontFamily="Consolas" FontSize="12"
                                 AcceptsReturn="True" TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>

                <!-- Execution Controls -->
                <Border Grid.Row="2" Background="#1A1A1A" Padding="12" CornerRadius="6" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="🎯 Target Computers" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock x:Name="TxtTargetCount" Text="0 selected" FontSize="10" Foreground="#888"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="Max Parallel:" FontSize="10" Foreground="#888" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtMaxConcurrency" Text="10" Width="50"
                                     Background="#0D0D0D" Foreground="White" BorderBrush="#444"
                                     Margin="8,0,0,0" Padding="4" TextAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Column="2" Content="▶️ Execute Script"
                                Style="{StaticResource BtnPrimary}"
                                x:Name="BtnExecute"
                                Click="BtnExecute_Click"
                                Padding="24,8" FontSize="14"/>
                    </Grid>
                </Border>

                <!-- Results Grid -->
                <Border Grid.Row="3" Background="#1A1A1A" Padding="12" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Results Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="📊 Execution Results" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock x:Name="TxtResultSummary" Text="No results yet" FontSize="10" Foreground="#888"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="📋 Export CSV" Style="{StaticResource BtnSecondary}"
                                        x:Name="BtnExportCsv"
                                        Click="BtnExportCsv_Click" Margin="0,0,6,0" IsEnabled="False"/>
                                <Button Content="📄 Export TXT" Style="{StaticResource BtnSecondary}"
                                        x:Name="BtnExportTxt"
                                        Click="BtnExportTxt_Click" IsEnabled="False"/>
                            </StackPanel>
                        </Grid>

                        <!-- Results DataGrid -->
                        <DataGrid x:Name="GridResults" Grid.Row="1"
                                  Background="#0D0D0D"
                                  Foreground="White"
                                  BorderBrush="#333" BorderThickness="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  RowBackground="#1A1A1A"
                                  AlternatingRowBackground="#0D0D0D"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#333"
                                  SelectionChanged="GridResults_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusIcon}" Width="60"/>
                                <DataGridTextColumn Header="Computer" Binding="{Binding Hostname}" Width="150"/>
                                <DataGridTextColumn Header="Result" Binding="{Binding StatusText}" Width="80"/>
                                <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="100"/>
                                <DataGridTextColumn Header="Output Preview" Binding="{Binding Output}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Output Details -->
                        <Border Grid.Row="2" Background="#0D0D0D"
                                BorderBrush="#444" BorderThickness="1"
                                Padding="8" Margin="0,8,0,0" MaxHeight="150">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="TxtOutputDetails"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="#00FF00"
                                           TextWrapping="Wrap"
                                           Text="Select a result to view full output"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#1A1A1A" Padding="12,8" CornerRadius="6" Margin="0,12,0,0">
            <Grid>
                <TextBlock x:Name="TxtStatus" Text="Ready" Foreground="#888" FontSize="11"/>
                <ProgressBar x:Name="ProgressExecution"
                             Height="4" VerticalAlignment="Bottom"
                             Visibility="Collapsed"
                             Foreground="#FF6B35" Background="#333"/>
            </Grid>
        </Border>
    </Grid>
</Window>
