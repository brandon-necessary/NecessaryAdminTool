<Window x:Class="ArtaznIT.ToolConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Height="500" Width="600"
        Background="{StaticResource MicaBrush}" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="{StaticResource FluentFont}">

    <!-- TAG: #AUTO_UPDATE_UI_ENGINE #FLUENT_THEME -->

    <!-- TAG: #TOOL_CONFIG #DIALOG -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="TxtTitle" FontSize="16" FontWeight="Bold"
                       Foreground="#FFFF8533" Margin="0,0,0,8"/>
            <TextBlock Text="Configure connection settings and credentials"
                       Foreground="#FFA1A1AA" FontSize="10"/>
        </StackPanel>

        <!-- Configuration Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ConfigPanel">
                <!-- Dynamic content based on tool type -->
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="TEST CONNECTION" x:Name="BtnTest"
                    Style="{StaticResource FluentButtonSecondary}"
                    Padding="15,8" Margin="0,0,8,0" FontSize="{StaticResource FontSmall}" Click="Test_Click"/>
            <Button Content="SAVE" x:Name="BtnSave"
                    Style="{StaticResource FluentButtonPrimary}"
                    Padding="15,8" Margin="0,0,8,0" FontSize="{StaticResource FontSmall}" Click="Save_Click"
                    IsDefault="True"/>
            <Button Content="CANCEL" x:Name="BtnCancel"
                    Style="{StaticResource FluentButtonSecondary}"
                    Padding="15,8" FontSize="{StaticResource FontSmall}" Click="Cancel_Click"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
