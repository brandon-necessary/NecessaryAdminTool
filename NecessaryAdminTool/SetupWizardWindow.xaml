<Window x:Class="NecessaryAdminTool.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NecessaryAdminTool - Initial Setup"
        Width="700" Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#FF0D0D0D">

    <!-- Theme resources inherited from App.xaml -->

    <Border BorderBrush="{StaticResource AccentOrangeBrush}" BorderThickness="2" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource AccentOrangeBrush}" Padding="30,20">
                <StackPanel>
                    <TextBlock Text="🚀 Welcome to NecessaryAdminTool"
                               FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Let's configure your installation"
                               FontSize="14" Foreground="White" Opacity="0.9" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" Margin="30,20">
                <StackPanel>
                    <!-- Database Type Selection -->
                    <TextBlock Text="1. Select Database Type:" FontSize="18" FontWeight="SemiBold"
                               Foreground="White" Margin="0,0,0,15"/>

                    <RadioButton x:Name="RbSqlite" Content="SQLite (Recommended)" IsChecked="True"
                                 Foreground="White" FontSize="15" FontWeight="SemiBold" Margin="0,8"/>
                    <TextBlock Text="   • Fast, reliable, zero configuration" Foreground="{StaticResource AccentZincBrush}" Margin="25,0,0,5"/>
                    <TextBlock Text="   • AES-256 encrypted with SQLCipher" Foreground="{StaticResource AccentZincBrush}" Margin="25,0,0,5"/>
                    <TextBlock Text="   • Best for single-user or small teams (100,000+ computers)" Foreground="{StaticResource AccentZincBrush}" Margin="25,0,0,15"/>

                    <RadioButton x:Name="RbSqlServer" Content="SQL Server"
                                 Foreground="White" FontSize="15" Margin="0,8"/>
                    <TextBlock Text="   • Enterprise-grade, multi-user support" Foreground="{StaticResource AccentZincBrush}" Margin="25,0,0,5"/>
                    <TextBlock Text="   • Requires SQL Server installation" Foreground="{StaticResource AccentZincBrush}" Margin="25,0,0,5"/>
                    <TextBlock Text="   • Unlimited capacity" Foreground="{StaticResource AccentZincBrush}" Margin="25,0,0,15"/>

                    <RadioButton x:Name="RbAccess" Content="Microsoft Access"
                                 Foreground="White" FontSize="15" Margin="0,8"/>
                    <TextBlock Text="   • Excel integration, familiar interface" Foreground="{StaticResource AccentZincBrush}" Margin="25,0,0,5"/>
                    <TextBlock Text="   • 2GB database limit (~50,000 computers)" Foreground="{StaticResource AccentZincBrush}" Margin="25,0,0,15"/>

                    <RadioButton x:Name="RbCsv" Content="CSV/JSON (Fallback)"
                                 Foreground="White" FontSize="15" Margin="0,8"/>
                    <TextBlock Text="   • Human-readable, portable" Foreground="{StaticResource AccentZincBrush}" Margin="25,0,0,5"/>
                    <TextBlock Text="   • Limited performance (~10,000 computers)" Foreground="{StaticResource AccentZincBrush}" Margin="25,0,0,20"/>

                    <!-- Database Location -->
                    <TextBlock Text="2. Database Location:" FontSize="18" FontWeight="SemiBold"
                               Foreground="White" Margin="0,20,0,15"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="TxtDatabasePath" Grid.Column="0"
                                 Text="C:\ProgramData\NecessaryAdminTool"
                                 Background="{StaticResource BgDarkBrush}" Foreground="White"
                                 Padding="12" FontSize="14" BorderBrush="{StaticResource AccentZincBrush}"/>
                        <Button Grid.Column="1" Content="📁 Browse..." Click="BtnBrowse_Click"
                                Width="120" Margin="10,0,0,0"
                                Background="{StaticResource AccentOrangeBrush}" Foreground="White"
                                Padding="12" FontSize="14" FontWeight="SemiBold" Cursor="Hand"/>
                        <Button Grid.Column="2" Content="💾 Export Template" Click="BtnExportTemplate_Click"
                                Width="150" Margin="10,0,0,0"
                                Style="{StaticResource BtnGhost}"
                                Padding="12" FontSize="14" Cursor="Hand"
                                ToolTip="Export an empty database template file"/>
                    </Grid>

                    <!-- Service Installation -->
                    <TextBlock Text="3. Background Service (Optional):" FontSize="18" FontWeight="SemiBold"
                               Foreground="White" Margin="0,25,0,15"/>

                    <CheckBox x:Name="ChkInstallService"
                              Content="Install Windows Service for automatic scanning (Recommended)"
                              IsChecked="True" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="   • Runs scans in the background every 2 hours (requires admin rights)"
                               Foreground="{StaticResource AccentZincBrush}" Margin="30,8,0,5"/>
                    <TextBlock Text="   • Falls back to scheduled task if not admin"
                               Foreground="{StaticResource AccentZincBrush}" Margin="30,0,0,20"/>

                    <!-- Scan Interval -->
                    <TextBlock Text="4. Automatic Scan Interval:" FontSize="18" FontWeight="SemiBold"
                               Foreground="White" Margin="0,15,0,15"/>

                    <ComboBox x:Name="CmbScanInterval" SelectedIndex="1"
                              Background="{StaticResource BgDarkBrush}" Foreground="White"
                              FontSize="14" Padding="12">
                        <ComboBoxItem Content="Every hour"/>
                        <ComboBoxItem Content="Every 2 hours (Recommended)"/>
                        <ComboBoxItem Content="Every 4 hours"/>
                        <ComboBoxItem Content="Daily"/>
                        <ComboBoxItem Content="Manual only"/>
                    </ComboBox>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer Buttons -->
            <Border Grid.Row="2" Background="#FF1E1E1E" Padding="30,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Main button row -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left side - Help and Test buttons -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Content="📖 Database Guide" Click="BtnDatabaseGuide_Click"
                                    Width="160" Margin="0,0,10,0"
                                    Style="{StaticResource BtnGhost}"
                                    Padding="12" FontSize="14" Cursor="Hand"
                                    ToolTip="Opens comprehensive database setup guide with detailed comparisons, troubleshooting, and best practices for SQLite, SQL Server, Access, and CSV providers."/>
                            <Button Content="🧪 Test Database" Click="BtnTestDatabase_Click"
                                    Width="160" HorizontalAlignment="Left"
                                    Style="{StaticResource BtnGhost}"
                                    Padding="12" FontSize="14" Cursor="Hand"
                                    ToolTip="Tests database connectivity and performs validation checks. Verifies CRUD operations, transaction support, and schema creation. Takes 10-30 seconds depending on provider."/>
                        </StackPanel>

                        <!-- Right side - Cancel and Finish buttons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel" Click="BtnCancel_Click" Width="120" Margin="0,0,15,0"
                                    Background="{StaticResource AccentZincBrush}" Foreground="White"
                                    Padding="12" FontSize="14" Cursor="Hand"/>
                            <Button Content="✓ Finish Setup" Click="BtnFinish_Click" Width="150"
                                    Background="{StaticResource AccentOrangeBrush}" Foreground="White"
                                    FontWeight="Bold" Padding="12" FontSize="14" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>

                    <!-- Bottom row - Version badge (DEBUG super menu trigger) -->
                    <!-- TAG: #VERSION_DISPLAY #DEBUG_BYPASS #SUPERADMIN #THEME_COLORS -->
                    <Border Grid.Row="1" Margin="0,15,0,0" HorizontalAlignment="Left">
                        <Border Background="#FF1A1A1A"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="6,2"
                                VerticalAlignment="Center">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF8533" Offset="0"/>
                                    <GradientStop Color="#A1A1AA" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtVersionBadge" FontSize="10" FontWeight="Bold" Margin="0,0,8,0">
                                        <TextBlock.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF8533" Offset="0"/>
                                                <GradientStop Color="#A1A1AA" Offset="1"/>
                                            </LinearGradientBrush>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                    <TextBlock x:Name="TxtBuildDate" Text="Built: February 15, 2026"
                                               FontSize="9" Foreground="#A1A1AA" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- TAG: #DEBUG_BYPASS #SUPERADMIN - Invisible button overlay - Click 5x rapidly to bypass setup (DEBUG builds only) -->
                                <Button x:Name="BtnDebugBypassTrigger"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Arrow"
                                        Click="BtnDebugBypassTrigger_Click"
                                        ToolTip=""
                                        Opacity="0.01"
                                        IsTabStop="False"
                                        Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
