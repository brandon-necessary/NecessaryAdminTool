<!-- TAG: #AUTO_UPDATE_VERSION #ABOUT_WINDOW #VERSION_DISPLAY -->
<!-- FUTURE CLAUDES: Update version and build date in this file with each release -->
<!-- Current Version: 3.0 (3.2602.0.0) | Build Date: February 20, 2026 -->
<Window x:Class="NecessaryAdminTool.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About NecessaryAdminTool Suite"
        Height="650" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="500" MinWidth="420"
        Background="#FF0D0D0D"
        WindowStyle="None"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Colors — AccentOrangeBrush/AccentZincBrush inherited from App.xaml (modular, driven by Options) -->
        <Color x:Key="BgDarkest">#FF0D0D0D</Color>
        <Color x:Key="BgCard">#FF1E1E1E</Color>
        <Color x:Key="BorderDim">#FF3C3C3C</Color>
        <SolidColorBrush x:Key="BgDarkestBrush" Color="{StaticResource BgDarkest}"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="BorderDimBrush" Color="{StaticResource BorderDim}"/>

        <!-- Close Button Style -->
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF888888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFFF3333"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Expander Style -->
        <Style TargetType="Expander">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDimBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ToggleButton Style for Expander -->
        <Style x:Key="ExpanderToggleButton" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="8,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="Arrow" Grid.Column="0" Text="▶"
                                          Foreground="{DynamicResource AccentOrangeBrush}"
                                          FontSize="10" Margin="0,0,8,0"
                                          RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="0"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Arrow"
                                                           Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)"
                                                           To="90" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Arrow"
                                                           Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)"
                                                           To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Arrow" Property="Foreground" Value="#FFFFAA66"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource AccentOrangeBrush}" BorderThickness="2" CornerRadius="8">
        <Grid>
            <!-- Header with gradient background -->
            <Grid.RowDefinitions>
                <RowDefinition Height="180"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header Section with Logo -->
            <Border Grid.Row="0" CornerRadius="6,6,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF1A1A1A" Offset="0"/>
                        <GradientStop Color="#FF2A2A2A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- TAG: #TOOLTIPS #NAVIGATION -->
                    <!-- Close Button -->
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Style="{StaticResource CloseButton}" Click="CloseButton_Click"
                            Margin="0,8,8,0" Width="32" Height="32"
                            ToolTip="Closes the About window and returns to main application. (Esc)"/>

                    <!-- Logo and Branding -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <!-- Icon with Orange/Zinc Gradient -->
                        <Border Width="64" Height="64" CornerRadius="12" Margin="0,0,0,16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFFF8533" Offset="0"/>
                                    <GradientStop Color="#FFCC6B29" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#FFFF8533" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                            </Border.Effect>
                            <Viewbox Width="36" Height="36">
                                <Canvas Width="24" Height="24">
                                    <!-- A Letter Icon -->
                                    <Path Fill="White" Data="M12,2 L20,22 L16,22 L14.5,18 L9.5,18 L8,22 L4,22 Z M10.5,14 L13.5,14 L12,9 Z"/>
                                </Canvas>
                            </Viewbox>
                        </Border>

                        <!-- Brand Text with Gradient -->
                        <TextBlock HorizontalAlignment="Center" Margin="0,0,0,4">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.7"/>
                            </TextBlock.Effect>
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FFFF8533" Offset="0"/>
                                    <GradientStop Color="#FFA1A1AA" Offset="0.7"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                            <!-- TAG: #DYNAMIC_BRANDING - Branding set programmatically in code-behind -->
                            <Run x:Name="RunCompanyName" Text="NecessaryAdmin" FontSize="36" FontWeight="ExtraBold"/>
                            <Run x:Name="RunCompanySuffix" Text="" FontSize="28" FontWeight="Light"/>
                        </TextBlock>

                        <TextBlock Text="I T   M A N A G E M E N T   S U I T E"
                                   FontSize="9" Foreground="{DynamicResource AccentOrangeBrush}"
                                   FontWeight="Bold" HorizontalAlignment="Center" Opacity="0.8"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Section -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30,20">
                <StackPanel>
                    <!-- Version Info -->
                    <Border Background="{DynamicResource BgCardBrush}"
                            BorderBrush="{DynamicResource BorderDimBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Version:"
                                       Foreground="#FF888888" FontSize="12" Margin="0,0,12,6"/>
                            <TextBlock x:Name="TxtVersion" Grid.Row="0" Grid.Column="1" Text="1.2602.0.0"
                                       Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Build Date:"
                                       Foreground="#FF888888" FontSize="12" Margin="0,0,12,6"/>
                            <TextBlock x:Name="TxtBuildDate" Grid.Row="1" Grid.Column="1" Text="2026-02-14"
                                       Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Developer:"
                                       Foreground="#FF888888" FontSize="12" Margin="0,0,12,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Brandon Necessary"
                                       Foreground="White" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                    </Border>

                    <!-- Features -->
                    <TextBlock Text="KEY FEATURES" Foreground="{DynamicResource AccentOrangeBrush}"
                               FontSize="11" FontWeight="Bold" Margin="0,8,0,8"/>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="• Active Directory Fleet Management" Foreground="White" FontSize="11" Margin="0,2"/>
                        <TextBlock Text="• Remote WMI &amp; PowerShell Control" Foreground="White" FontSize="11" Margin="0,2"/>
                        <TextBlock Text="• Multicore Parallel Processing" Foreground="White" FontSize="11" Margin="0,2"/>
                        <TextBlock Text="• Real-time System Monitoring" Foreground="White" FontSize="11" Margin="0,2"/>
                        <TextBlock Text="• Comprehensive Audit Logging" Foreground="White" FontSize="11" Margin="0,2"/>
                        <TextBlock Text="• Automated Deployment &amp; Updates" Foreground="White" FontSize="11" Margin="0,2"/>
                    </StackPanel>

                    <!-- Technology Stack -->
                    <TextBlock Text="TECHNOLOGY STACK" Foreground="{DynamicResource AccentOrangeBrush}"
                               FontSize="11" FontWeight="Bold" Margin="0,8,0,8"/>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="• WPF / .NET Framework 4.8.1" Foreground="White" FontSize="11" Margin="0,2"/>
                        <TextBlock Text="• WMI &amp; CIM Integration" Foreground="White" FontSize="11" Margin="0,2"/>
                        <TextBlock Text="• PowerShell Remoting (WinRM)" Foreground="White" FontSize="11" Margin="0,2"/>
                        <TextBlock Text="• Task.WhenAll &amp; PLINQ Optimization" Foreground="White" FontSize="11" Margin="0,2"/>
                        <TextBlock Text="• Active Directory Services" Foreground="White" FontSize="11" Margin="0,2"/>
                    </StackPanel>

                    <!-- Network Ports & Requirements (Expandable) -->
                    <!-- TAG: #NETWORK_PORTS #FIREWALL_REQUIREMENTS -->
                    <TextBlock Text="NETWORK PORTS &amp; REQUIREMENTS" Foreground="{DynamicResource AccentOrangeBrush}"
                               FontSize="11" FontWeight="Bold" Margin="0,8,0,8"/>

                    <Expander Background="{DynamicResource BgCardBrush}"
                              BorderBrush="{DynamicResource BorderDimBrush}"
                              BorderThickness="1"
                              Margin="0,0,0,12" Padding="0">
                        <Expander.HeaderTemplate>
                            <DataTemplate>
                                <Grid Background="Transparent" Cursor="Hand">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="🌐" FontSize="14" Margin="0,0,8,0"
                                              Foreground="{DynamicResource AccentOrangeBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Network Ports &amp; Firewall Requirements"
                                              Foreground="White" FontSize="11" FontWeight="Bold"
                                              VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </Expander.HeaderTemplate>

                        <Border Background="#FF0D0D0D" BorderBrush="#FF2A2A2A" BorderThickness="0,1,0,0"
                                Padding="14,12,14,12" CornerRadius="0,0,6,6">
                            <StackPanel>

                                <!-- Copy button -->
                                <Border Background="#FF1A1A1A" BorderBrush="#FF3C3C3C" BorderThickness="1"
                                        CornerRadius="4" Padding="10,7" Margin="0,0,0,12" Cursor="Hand"
                                        MouseLeftButtonDown="BtnCopyPorts_Click"
                                        ToolTip="Copies a formatted port list to your clipboard - paste into a firewall change request or ticket">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="📋" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Copy Port List to Clipboard"
                                                      Foreground="{DynamicResource AccentOrangeBrush}" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock Text="Paste into a firewall change request or IT ticket"
                                                      Foreground="#FF888888" FontSize="9" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="→" FontSize="16" Foreground="{DynamicResource AccentOrangeBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Table column headers -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="76"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="PORT" Foreground="{DynamicResource AccentOrangeBrush}" FontSize="9" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" Text="PROTO" Foreground="{DynamicResource AccentOrangeBrush}" FontSize="9" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="FEATURE / PURPOSE" Foreground="{DynamicResource AccentOrangeBrush}" FontSize="9" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="3" Text="STATUS" Foreground="{DynamicResource AccentOrangeBrush}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </Grid>
                                <Border Background="#FF3C3C3C" Height="1" Margin="0,0,0,6"/>

                                <!-- ── GROUP: Active Directory ── -->
                                <TextBlock Text="ACTIVE DIRECTORY &amp; AUTHENTICATION" Foreground="#FF888888"
                                           FontSize="9" FontWeight="Bold" Margin="0,4,0,4"/>

                                <!-- DNS -->
                                <Border Background="#FF181818" CornerRadius="3" Padding="6,5" Margin="0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="76"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="53" Foreground="{DynamicResource AccentOrangeBrush}" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="TCP/UDP" Foreground="{DynamicResource AccentZincBrush}" FontSize="9"/>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="DNS — Hostname &amp; DC resolution" Foreground="White" FontSize="10"/>
                                            <TextBlock Text="Enable: Open on DCs by default" Foreground="#FF666666" FontSize="9" FontStyle="Italic"/>
                                        </StackPanel>
                                        <Border Grid.Column="3" Background="#FF1A3A1A" CornerRadius="3" Padding="4,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="✓ Default" Foreground="#FF4CAF50" FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Kerberos -->
                                <Border Background="#FF141414" CornerRadius="3" Padding="6,5" Margin="0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="76"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="88" Foreground="{DynamicResource AccentOrangeBrush}" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="TCP/UDP" Foreground="{DynamicResource AccentZincBrush}" FontSize="9"/>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Kerberos — Domain authentication" Foreground="White" FontSize="10"/>
                                            <TextBlock Text="Enable: Open on DCs by default" Foreground="#FF666666" FontSize="9" FontStyle="Italic"/>
                                        </StackPanel>
                                        <Border Grid.Column="3" Background="#FF1A3A1A" CornerRadius="3" Padding="4,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="✓ Default" Foreground="#FF4CAF50" FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- LDAP -->
                                <Border Background="#FF181818" CornerRadius="3" Padding="6,5" Margin="0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="76"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="389" Foreground="{DynamicResource AccentOrangeBrush}" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="TCP/UDP" Foreground="{DynamicResource AccentZincBrush}" FontSize="9"/>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="LDAP — Active Directory queries" Foreground="White" FontSize="10"/>
                                            <TextBlock Text="Enable: Open on DCs by default" Foreground="#FF666666" FontSize="9" FontStyle="Italic"/>
                                        </StackPanel>
                                        <Border Grid.Column="3" Background="#FF1A3A1A" CornerRadius="3" Padding="4,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="✓ Default" Foreground="#FF4CAF50" FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- LDAPS -->
                                <Border Background="#FF141414" CornerRadius="3" Padding="6,5" Margin="0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="76"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="636" Foreground="{DynamicResource AccentOrangeBrush}" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="TCP" Foreground="{DynamicResource AccentZincBrush}" FontSize="9"/>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="LDAPS — Encrypted AD queries" Foreground="White" FontSize="10"/>
                                            <TextBlock Text="Enable: Requires DC certificate (AD CS or 3rd-party)" Foreground="#FF666666" FontSize="9" FontStyle="Italic"/>
                                        </StackPanel>
                                        <Border Grid.Column="3" Background="#FF1A2A3A" CornerRadius="3" Padding="4,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="Configure" Foreground="#FF2196F3" FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Global Catalog -->
                                <Border Background="#FF181818" CornerRadius="3" Padding="6,5" Margin="0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="76"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="3268" Foreground="{DynamicResource AccentOrangeBrush}" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="TCP" Foreground="{DynamicResource AccentZincBrush}" FontSize="9"/>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Global Catalog — Forest-wide AD search" Foreground="White" FontSize="10"/>
                                            <TextBlock Text="Enable: Open on GC DCs by default" Foreground="#FF666666" FontSize="9" FontStyle="Italic"/>
                                        </StackPanel>
                                        <Border Grid.Column="3" Background="#FF1A3A1A" CornerRadius="3" Padding="4,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="✓ Default" Foreground="#FF4CAF50" FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- ── GROUP: WMI / System Scanning ── -->
                                <TextBlock Text="WMI / SYSTEM SCANNING" Foreground="#FF888888"
                                           FontSize="9" FontWeight="Bold" Margin="0,10,0,4"/>

                                <!-- RPC Endpoint Mapper -->
                                <Border Background="#FF181818" CornerRadius="3" Padding="6,5" Margin="0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="76"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="135" Foreground="{DynamicResource AccentOrangeBrush}" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="TCP" Foreground="{DynamicResource AccentZincBrush}" FontSize="9"/>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="RPC Endpoint Mapper — WMI &amp; CIM" Foreground="White" FontSize="10"/>
                                            <TextBlock Text="Enable: GPO → Computer Config → Windows Firewall → WMI-In rules" Foreground="#FF666666" FontSize="9" FontStyle="Italic"/>
                                        </StackPanel>
                                        <Border Grid.Column="3" Background="#FF3A2A1A" CornerRadius="3" Padding="4,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="⚠ GPO req." Foreground="{DynamicResource AccentOrangeBrush}" FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- SMB -->
                                <Border Background="#FF141414" CornerRadius="3" Padding="6,5" Margin="0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="76"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="445" Foreground="{DynamicResource AccentOrangeBrush}" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="TCP" Foreground="{DynamicResource AccentZincBrush}" FontSize="9"/>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="SMB — WMI transport &amp; file shares" Foreground="White" FontSize="10"/>
                                            <TextBlock Text="Enable: Usually open on domain PCs by default" Foreground="#FF666666" FontSize="9" FontStyle="Italic"/>
                                        </StackPanel>
                                        <Border Grid.Column="3" Background="#FF1A3A1A" CornerRadius="3" Padding="4,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="✓ Default" Foreground="#FF4CAF50" FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Dynamic RPC -->
                                <Border Background="#FF181818" CornerRadius="3" Padding="6,5" Margin="0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="76"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="49152+" Foreground="{DynamicResource AccentOrangeBrush}" FontSize="10" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="TCP" Foreground="{DynamicResource AccentZincBrush}" FontSize="9"/>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Dynamic RPC — WMI data channel" Foreground="White" FontSize="10"/>
                                            <TextBlock Text="Enable: GPO WMI-In rules or restrict via netsh" Foreground="#FF666666" FontSize="9" FontStyle="Italic"/>
                                        </StackPanel>
                                        <Border Grid.Column="3" Background="#FF3A2A1A" CornerRadius="3" Padding="4,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="⚠ GPO req." Foreground="{DynamicResource AccentOrangeBrush}" FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- ── GROUP: Remote Management ── -->
                                <TextBlock Text="REMOTE MANAGEMENT &amp; DEPLOYMENT" Foreground="#FF888888"
                                           FontSize="9" FontWeight="Bold" Margin="0,10,0,4"/>

                                <!-- WinRM HTTP -->
                                <Border Background="#FF181818" CornerRadius="3" Padding="6,5" Margin="0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="76"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="5985" Foreground="{DynamicResource AccentOrangeBrush}" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="TCP" Foreground="{DynamicResource AccentZincBrush}" FontSize="9"/>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="WinRM HTTP — PowerShell Remoting (primary)" Foreground="White" FontSize="10"/>
                                            <TextBlock Text="Enable: Enable-PSRemoting -Force  |  or GPO" Foreground="#FF666666" FontSize="9" FontStyle="Italic"/>
                                        </StackPanel>
