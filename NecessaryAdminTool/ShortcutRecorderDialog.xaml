<Window x:Class="NecessaryAdminTool.ShortcutRecorderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Record Keyboard Shortcut"
        Height="250" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#FF0D0D0D"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <!-- TAG: #AUTO_UPDATE_UI_ENGINE #USER_CONFIG #SETTINGS -->

    <Window.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#FF1A1A1A"/>
        <SolidColorBrush x:Key="BgCard" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="BorderDim" Color="#FF3C3C3C"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FFFF8533"/>
        <SolidColorBrush x:Key="TextMuted" Color="#FF888888"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Command Name -->
        <TextBlock Grid.Row="0" x:Name="TxtCommand" Text="Command Name"
                   Foreground="White" FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,8"/>

        <!-- Current Shortcut -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="Current Shortcut:" Foreground="{StaticResource TextMuted}" FontSize="11"/>
            <TextBlock x:Name="TxtCurrentShortcut" Text="Ctrl+K"
                       Foreground="{StaticResource AccentOrange}" FontSize="14" FontWeight="Bold"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Recording Area -->
        <Border Grid.Row="2" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                BorderThickness="2" CornerRadius="6" Padding="20" Margin="0,0,0,16">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Press any key combination..." Foreground="{StaticResource TextMuted}"
                           FontSize="12" TextAlignment="Center" Margin="0,0,0,12"/>

                <TextBlock x:Name="TxtRecordedKeys" Text="Press keys..."
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           TextAlignment="Center" Margin="0,0,0,8"/>

                <TextBlock x:Name="TxtConflictWarning" Text=""
                           Foreground="#FFFF6B6B" FontSize="10" FontWeight="SemiBold"
                           TextAlignment="Center" TextWrapping="Wrap"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Press ESC to cancel"
                       Foreground="{StaticResource TextMuted}" FontSize="9"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1" Content="CANCEL" Background="#FF2A2A2A" Foreground="White"
                    BorderThickness="0" Padding="16,8" FontSize="11" Margin="0,0,8,0"
                    Click="BtnCancel_Click" Cursor="Hand"/>

            <Button Grid.Column="2" x:Name="BtnAccept" Content="ACCEPT" Background="#FFFF8533" Foreground="White"
                    BorderThickness="0" Padding="16,8" FontSize="11" FontWeight="Bold"
                    Click="BtnAccept_Click" Cursor="Hand" IsEnabled="False"/>
        </Grid>
    </Grid>
</Window>
