<Window x:Class="NecessaryAdminTool.SuperAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔒 SuperAdmin Configuration"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource MicaBrush}"
        ResizeMode="CanResize"
        Icon="pack://application:,,,/Resources/icon.ico"
        Topmost="True"
        FontFamily="{StaticResource FluentFont}">

    <!-- TAG: #AUTO_UPDATE_UI_ENGINE #FLUENT_THEME -->

    <!-- TAG: #SUPERADMIN #WHITELABEL_GUI #ADVANCED_CONFIG -->

    <Window.Resources>
        <!-- Unified Theme Colors -->
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#FF6B35"/>
        <SolidColorBrush x:Key="AccentZincBrush" Color="#71797E"/>
        <SolidColorBrush x:Key="BgDarkBrush" Color="#1a1a1a"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="#2a2a2a"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3a3a3a"/>

        <!-- Fluent Button Styles -->
        <Style x:Key="ModernButton" TargetType="Button" BasedOn="{StaticResource FluentButtonPrimary}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource FluentButtonSecondary}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
        </Style>

        <!-- Danger Button Style -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource FluentButtonPrimary}">
            <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
        </Style>

        <!-- Fluent TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource MicaAltBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="{StaticResource FontBody}"/>
            <Setter Property="FontFamily" Value="{StaticResource FluentFont}"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentOrangeBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerRadius}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2a2a2a" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🔒" FontSize="32" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="SuperAdmin Configuration Panel"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Advanced white-label customization and system configuration"
                               FontSize="13"
                               Foreground="#CCCCCC"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content - TabControl -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border"
                                        Background="#2a2a2a"
                                        BorderThickness="0"
                                        CornerRadius="6,6,0,0"
                                        Margin="0,0,5,0"
                                        Padding="20,12">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#FF6B35"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#3a3a3a"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="True"/>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="Border" Property="Background" Value="#FF8555"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="14"/>
                </Style>
            </TabControl.Resources>

            <!-- Tab 1: White-Label Configuration -->
            <TabItem Header="🏷️ White-Label Branding">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Configuration Form -->
                        <Border Grid.Column="0" Background="#2a2a2a" CornerRadius="8" Padding="25">
                            <StackPanel>
                                <TextBlock Text="Company Branding Configuration"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,0,0,20"/>

                                <!-- Company Name -->
                                <TextBlock Text="Legal Company Name"
                                           Foreground="#CCCCCC"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtCompanyName"
                                         Style="{StaticResource ModernTextBox}"
                                         Text="{}{COMPANY_NAME}"
                                         ToolTip="Full legal entity name (e.g., 'Contoso Corporation', 'Acme LLC')"
                                         TextChanged="OnWhiteLabelFieldChanged"/>
                                <TextBlock Text="Used in: License agreements, warranty disclaimers, liability text"
                                           Foreground="#888888"
                                           FontSize="11"
                                           FontStyle="Italic"
                                           Margin="0,5,0,20"/>

                                <!-- Company Domain -->
                                <TextBlock Text="Company Email Domain"
                                           Foreground="#CCCCCC"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtCompanyDomain"
                                         Style="{StaticResource ModernTextBox}"
                                         Text="{}{COMPANY_DOMAIN}"
                                         ToolTip="Email domain without 'support@' prefix (e.g., 'contoso.com')"
                                         TextChanged="OnWhiteLabelFieldChanged"/>
                                <TextBlock Text="Used in: Support email links (support@domain)"
                                           Foreground="#888888"
                                           FontSize="11"
                                           FontStyle="Italic"
                                           Margin="0,5,0,20"/>

                                <!-- Support Email (Auto-Generated) -->
                                <TextBlock Text="Support Email (Auto-Generated)"
                                           Foreground="#CCCCCC"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,5"/>
                                <Border Background="#1a1a1a"
                                        BorderBrush="{StaticResource AccentOrangeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="12,10">
                                    <TextBlock x:Name="TxtSupportEmail"
                                               Text="{}support@{COMPANY_DOMAIN}"
                                               Foreground="#FF6B35"
                                               FontSize="14"
                                               FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="Automatically generated from domain above"
                                           Foreground="#888888"
                                           FontSize="11"
                                           FontStyle="Italic"
                                           Margin="0,5,0,20"/>

                                <!-- Support Phone (Optional) -->
                                <TextBlock Text="Support Phone (Optional)"
                                           Foreground="#CCCCCC"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtSupportPhone"
                                         Style="{StaticResource ModernTextBox}"
                                         Text="Contact your authorized representative"
                                         ToolTip="Support phone number or contact message"
                                         TextChanged="OnWhiteLabelFieldChanged"/>
                                <TextBlock Text="Used in: About window contact section"
                                           Foreground="#888888"
                                           FontSize="11"
                                           FontStyle="Italic"
                                           Margin="0,5,0,25"/>

                                <!-- Action Buttons -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            x:Name="BtnApplyWhiteLabel"
                                            Content="✓ Apply Changes"
                                            Style="{StaticResource ModernButton}"
                                            Click="BtnApplyWhiteLabel_Click"
                                            Height="45"/>

                                    <Button Grid.Column="2"
                                            x:Name="BtnResetWhiteLabel"
                                            Content="↺ Reset to Defaults"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="BtnResetWhiteLabel_Click"
                                            Height="45"/>
                                </Grid>

                                <TextBlock x:Name="TxtWhiteLabelStatus"
                                           Text=""
                                           Foreground="#4CAF50"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,15,0,0"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <!-- Right: Live Preview -->
                        <Border Grid.Column="2" Background="#2a2a2a" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="📋 Live Preview"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,0,0,15"/>

                                <!-- Preview: Warranty Disclaimer -->
                                <Border Background="#1a1a1a"
                                        BorderBrush="#3a3a3a"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="15"
                                        Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Warranty Disclaimer Preview:"
                                                   Foreground="#FF6B35"
                                                   FontWeight="Bold"
                                                   FontSize="12"
                                                   Margin="0,0,0,10"/>
                                        <TextBlock x:Name="PreviewWarranty"
                                                   TextWrapping="Wrap"
                                                   Foreground="#CCCCCC"
                                                   FontSize="11"
                                                   Text="{}THE SOFTWARE IS PROVIDED 'AS IS' WITHOUT WARRANTY OF ANY KIND. {COMPANY_NAME} DOES NOT WARRANT THAT THE SOFTWARE WILL MEET YOUR REQUIREMENTS..."/>
                                    </StackPanel>
                                </Border>

                                <!-- Preview: Contact Info -->
                                <Border Background="#1a1a1a"
                                        BorderBrush="#3a3a3a"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="15"
                                        Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Contact Information Preview:"
                                                   Foreground="#FF6B35"
                                                   FontWeight="Bold"
                                                   FontSize="12"
                                                   Margin="0,0,0,10"/>
                                        <TextBlock x:Name="PreviewContact"
                                                   TextWrapping="Wrap"
                                                   Foreground="#CCCCCC"
                                                   FontSize="11">
                                            <Run Text="Legal Department: "/><Run x:Name="PreviewCompanyName" Text="{}{COMPANY_NAME}" FontWeight="Bold"/><LineBreak/>
                                            <Run Text="Email: "/><Run x:Name="PreviewEmail" Text="{}support@{COMPANY_DOMAIN}" Foreground="#FF6B35"/><LineBreak/>
                                            <Run Text="Phone: "/><Run x:Name="PreviewPhone" Text="Contact your authorized representative"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Files Affected List -->
                                <Border Background="#1a1a1a"
                                        BorderBrush="#3a3a3a"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="15">
                                    <StackPanel>
                                        <TextBlock Text="📁 Files That Will Be Modified:"
                                                   Foreground="#FF6B35"
                                                   FontWeight="Bold"
                                                   FontSize="12"
                                                   Margin="0,0,0,10"/>
                                        <TextBlock Foreground="#CCCCCC" FontSize="11" FontFamily="Consolas">
                                            <Run Text="✓ AboutWindow.xaml" Foreground="#4CAF50"/><LineBreak/>
                                            <Run Text="✓ AboutWindow.xaml.cs" Foreground="#4CAF50"/><LineBreak/>
                                            <Run Text="✓ MainWindow.xaml.cs" Foreground="#4CAF50"/><LineBreak/><LineBreak/>
                                            <Run Text="⚠ Backups will be created automatically" Foreground="#FFC107"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Advanced Settings -->
            <TabItem Header="⚙️ Advanced Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Background="#2a2a2a" CornerRadius="8" Padding="25" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="Advanced System Configuration"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,20"/>

                            <!-- Debug Mode -->
                            <Border Background="#1a1a1a"
                                    BorderBrush="#3a3a3a"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="20"
                                    Margin="0,0,0,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="🐛 Debug Mode"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="14"/>
                                        <TextBlock Text="Enable verbose logging and diagnostic output"
                                                   Foreground="#CCCCCC"
                                                   FontSize="12"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <CheckBox Grid.Column="1"
                                              x:Name="ChkDebugMode"
                                              VerticalAlignment="Center"
                                              Checked="ChkDebugMode_Changed"
                                              Unchecked="ChkDebugMode_Changed"/>
                                </Grid>
                            </Border>

                            <!-- Show Hidden Features -->
                            <Border Background="#1a1a1a"
                                    BorderBrush="#3a3a3a"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="20"
                                    Margin="0,0,0,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="🔓 Unlock Hidden Features"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="14"/>
                                        <TextBlock Text="Show experimental and beta features in UI"
                                                   Foreground="#CCCCCC"
                                                   FontSize="12"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <CheckBox Grid.Column="1"
                                              x:Name="ChkHiddenFeatures"
                                              VerticalAlignment="Center"
                                              Checked="ChkHiddenFeatures_Changed"
                                              Unchecked="ChkHiddenFeatures_Changed"/>
                                </Grid>
                            </Border>

                            <!-- Reset All Settings -->
                            <Border Background="#1a1a1a"
                                    BorderBrush="#DC3545"
                                    BorderThickness="2"
                                    CornerRadius="6"
                                    Padding="20"
                                    Margin="0,0,0,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="⚠️ Reset All Application Settings"
                                                   Foreground="#DC3545"
                                                   FontWeight="Bold"
                                                   FontSize="14"/>
                                        <TextBlock Text="Delete all config files and return to factory defaults"
                                                   Foreground="#CCCCCC"
                                                   FontSize="12"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="Reset Settings"
                                            Style="{StaticResource DangerButton}"
                                            Click="BtnResetSettings_Click"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Export/Import Config -->
                            <TextBlock Text="Configuration Backup &amp; Restore"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,20,0,15"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="📤 Export Config"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BtnExportConfig_Click"
                                        Height="45"/>

                                <Button Grid.Column="2"
                                        Content="📥 Import Config"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BtnImportConfig_Click"
                                        Height="45"/>
                            </Grid>

                            <!-- TAG: #DEBUG_TESTING - Setup Wizard Access -->
                            <Border Background="#1a1a1a"
                                    BorderBrush="#FF6B35"
                                    BorderThickness="2"
                                    CornerRadius="6"
                                    Padding="20"
                                    Margin="0,20,0,0">
                                <StackPanel>
                                    <TextBlock Text="🧪 Debug Testing Tools"
                                               Foreground="#FF6B35"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Margin="0,0,0,10"/>
                                    <TextBlock Text="These tools are for development and testing only. Use with caution in production environments."
                                               Foreground="#CCCCCC"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,15"/>

                                    <Button Content="🔧 Run Initial Setup Wizard"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="BtnRunSetupWizard_Click"
                                            Height="45"
                                            Margin="0,0,0,10"
                                            ToolTip="Launch the first-run setup wizard for testing database configuration"/>

                                    <Button Content="📦 Build MSI Installer"
                                            Style="{StaticResource AccentButton}"
                                            Click="BtnBuildInstaller_Click"
                                            Height="45"
                                            ToolTip="Run build-installer.ps1 to create MSI package (requires WiX Toolset)"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 3: Database Management -->
            <TabItem Header="💾 Database">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Background="#2a2a2a" CornerRadius="8" Padding="25" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="Database Maintenance"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,20"/>

                            <!-- Database Stats -->
                            <Border Background="#1a1a1a"
                                    BorderBrush="#3a3a3a"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="20"
                                    Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="📊 Database Statistics"
                                               Foreground="#FF6B35"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Margin="0,0,0,15"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Database Type:" Foreground="#CCCCCC" Margin="0,0,15,10"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtDbType" Text="SQLite" Foreground="White" Margin="0,0,0,10"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Total Computers:" Foreground="#CCCCCC" Margin="0,0,15,10"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtDbComputers" Text="0" Foreground="White" Margin="0,0,0,10"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Database Size:" Foreground="#CCCCCC" Margin="0,0,15,10"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtDbSize" Text="0 MB" Foreground="White" Margin="0,0,0,10"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Database Actions -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="15"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Button Grid.Row="0" Grid.Column="0"
                                        Content="🔧 Optimize Database"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BtnOptimizeDb_Click"
                                        Height="45"/>

                                <Button Grid.Row="0" Grid.Column="2"
                                        Content="💾 Backup Database"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BtnBackupDb_Click"
                                        Height="45"/>

                                <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                        Content="🗑️ Clear All Data (Dangerous!)"
                                        Style="{StaticResource DangerButton}"
                                        Click="BtnClearDb_Click"
                                        Height="45"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 4: System Info -->
            <TabItem Header="ℹ️ System Info">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Background="#2a2a2a" CornerRadius="8" Padding="25" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="System Information"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,20"/>

                            <Border Background="#1a1a1a"
                                    BorderBrush="#3a3a3a"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="20">
                                <TextBlock x:Name="TxtSystemInfo"
                                           Foreground="#CCCCCC"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Text="Loading system information..."/>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#2a2a2a" CornerRadius="8" Padding="15" Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="⚠️ SuperAdmin mode active"
                           Foreground="#FFC107"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           x:Name="TxtFooterStatus"
                           Text="Make changes carefully - all modifications are logged"
                           Foreground="#888888"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="2"
                        Content="✖ Close"
                        Style="{StaticResource SecondaryButton}"
                        Click="BtnClose_Click"
                        Width="100"/>
            </Grid>
        </Border>
    </Grid>
</Window>
