<Window x:Class="NecessaryAdminTool.ToolConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Height="500" Width="600"
        Background="{DynamicResource BgDarkestBrush}" WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        MinHeight="400" MinWidth="500"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <!-- TAG: #TOOL_CONFIG #DIALOG -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="TxtTitle" FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource AccentOrangeBrush}" Margin="0,0,0,8"/>
            <TextBlock Text="Configure connection settings and credentials"
                       Foreground="{DynamicResource AccentZincBrush}" FontSize="10"/>
        </StackPanel>

        <!-- Configuration Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ConfigPanel">
                <!-- Dynamic content based on tool type -->
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="TEST CONNECTION" x:Name="BtnTest"
                    Background="{DynamicResource BgLightBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                    Padding="15,8" Margin="0,0,8,0" FontSize="10" Click="Test_Click"/>
            <Button Content="SAVE" x:Name="BtnSave"
                    Background="{DynamicResource AccentOrangeBrush}" Foreground="White" BorderThickness="0"
                    Padding="15,8" Margin="0,0,8,0" FontSize="10" Click="Save_Click"
                    IsDefault="True"/>
            <Button Content="CANCEL" x:Name="BtnCancel"
                    Background="{DynamicResource BgLightBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                    Padding="15,8" FontSize="10" Click="Cancel_Click"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
