<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- TAG: #AUTO_UPDATE_UI_ENGINE #FLUENT_DESIGN #THEME_SYSTEM #WINDOWS11 #MODULAR -->
    <!-- Fluent Design System Resources for Windows 11 Native Look -->
    <!-- Research: https://fluent2.microsoft.design/ -->

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- MATERIALS (Mica + Acrylic inspired) -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Mica Material (Primary Surfaces) - Opaque, wallpaper tint -->
    <SolidColorBrush x:Key="MicaBrush" Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="MicaAltBrush" Color="#FF1E1E1E"/>

    <!-- Acrylic Material (Transient Surfaces) - Semi-transparent -->
    <SolidColorBrush x:Key="AcrylicBrush" Color="#E61E1E1E" Opacity="0.9"/>
    <SolidColorBrush x:Key="AcrylicLightBrush" Color="#E62A2A2A" Opacity="0.85"/>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- GEOMETRY (Rounded Corners - Windows 11 signature) -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <CornerRadius x:Key="FluentCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="FluentCornerRadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="FluentCornerRadiusLarge">12</CornerRadius>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- ELEVATION SYSTEM (Depth with shadows) -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Elevation 2dp -->
    <DropShadowEffect x:Key="Elevation2dp"
                      Color="#000000"
                      BlurRadius="4"
                      ShadowDepth="2"
                      Opacity="0.2"/>

    <!-- Elevation 4dp -->
    <DropShadowEffect x:Key="Elevation4dp"
                      Color="#000000"
                      BlurRadius="8"
                      ShadowDepth="2"
                      Opacity="0.3"/>

    <!-- Elevation 8dp -->
    <DropShadowEffect x:Key="Elevation8dp"
                      Color="#000000"
                      BlurRadius="16"
                      ShadowDepth="4"
                      Opacity="0.4"/>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- TYPOGRAPHY SCALE (Segoe UI Variable) -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <FontFamily x:Key="FluentFont">Segoe UI Variable, Segoe UI Emoji, Segoe UI Symbol</FontFamily>
    <FontFamily x:Key="FluentFontDisplay">Segoe UI Variable Display</FontFamily>

    <!-- Font Sizes -->
    <sys:Double x:Key="FontHero" xmlns:sys="clr-namespace:System;assembly=mscorlib">32</sys:Double>
    <sys:Double x:Key="FontH1" xmlns:sys="clr-namespace:System;assembly=mscorlib">24</sys:Double>
    <sys:Double x:Key="FontH2" xmlns:sys="clr-namespace:System;assembly=mscorlib">20</sys:Double>
    <sys:Double x:Key="FontH3" xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Double>
    <sys:Double x:Key="FontBody" xmlns:sys="clr-namespace:System;assembly=mscorlib">14</sys:Double>
    <sys:Double x:Key="FontSmall" xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>
    <sys:Double x:Key="FontMicro" xmlns:sys="clr-namespace:System;assembly=mscorlib">10</sys:Double>

    <!-- Font Weights -->
    <FontWeight x:Key="FontWeightLight">Light</FontWeight>
    <FontWeight x:Key="FontWeightRegular">Normal</FontWeight>
    <FontWeight x:Key="FontWeightSemiBold">SemiBold</FontWeight>
    <FontWeight x:Key="FontWeightBold">Bold</FontWeight>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SPACING SCALE (4px base) -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Thickness x:Key="SpacingTight">4</Thickness>
    <Thickness x:Key="SpacingCompact">8</Thickness>
    <Thickness x:Key="SpacingDefault">12</Thickness>
    <Thickness x:Key="SpacingComfortable">16</Thickness>
    <Thickness x:Key="SpacingLoose">24</Thickness>
    <Thickness x:Key="SpacingSpaciou">32</Thickness>
    <Thickness x:Key="SpacingExtra">48</Thickness>
    <Thickness x:Key="SpacingHero">64</Thickness>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SEMANTIC COLORS (Success, Warning, Error, Info) -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <SolidColorBrush x:Key="SuccessBrush" Color="#FF10B981"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFF59E0B"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FFEF4444"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#FF3B82F6"/>
    <SolidColorBrush x:Key="MutedBrush" Color="#FF6B7280"/>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- FLUENT BUTTON STYLES -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Primary Button (Accent) -->
    <Style x:Key="FluentButtonPrimary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentOrangeBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="{StaticResource FontBody}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource FluentCornerRadiusSmall}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#FFFFAA66"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#FFCC6B29"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary Button (Outline) -->
    <Style x:Key="FluentButtonSecondary" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource AccentZincBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentZincBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="{StaticResource FontBody}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource FluentCornerRadiusSmall}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- FLUENT CARD STYLE -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style x:Key="FluentCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MicaAltBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerRadius}"/>
        <Setter Property="Padding" Value="{StaticResource SpacingDefault}"/>
        <Setter Property="Effect" Value="{StaticResource Elevation2dp}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- FLUENT FOCUS INDICATOR -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style x:Key="FluentFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border BorderBrush="{StaticResource AccentOrangeBrush}"
                            BorderThickness="2"
                            CornerRadius="{StaticResource FluentCornerRadiusSmall}">
                        <Border.Effect>
                            <DropShadowEffect Color="#FFFF8533"
                                            BlurRadius="8"
                                            ShadowDepth="0"
                                            Opacity="0.6"/>
                        </Border.Effect>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- FILTER TOGGLE BUTTON (TAG: #AUTO_UPDATE_UI_ENGINE #FILTER_SYSTEM) -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style x:Key="FilterToggleButton" TargetType="ToggleButton">
        <Setter Property="Background" Value="#FF2A2A2A"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#FF444"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Checked State (Active Filter) -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#FFFF8533"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#FFFF8533"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <!-- Hover State -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#FF333"/>
                        </Trigger>
                        <!-- Hover + Checked -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsChecked" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="Background" Value="#FFFFAA66"/>
                        </MultiTrigger>
                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
