<UserControl x:Class="NecessaryAdminTool.UI.Components.SkeletonLoader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="100" d:DesignWidth="800">

    <!-- TAG: #SKELETON_LOADER #MODULAR #PERCEIVED_PERFORMANCE #SHIMMER_ANIMATION -->
    <!-- Research: https://blog.logrocket.com/ux-design/skeleton-loading-screen-design/ -->
    <!-- NN/G: https://www.nngroup.com/articles/skeleton-screens/ -->

    <UserControl.Resources>
        <!-- Shimmer animation storyboard -->
        <Storyboard x:Key="ShimmerAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ShimmerTransform"
                           Storyboard.TargetProperty="X"
                           From="-200"
                           To="800"
                           Duration="0:0:1.5"
                           AutoReverse="False"/>
        </Storyboard>
    </UserControl.Resources>

    <Border Background="{DynamicResource BgCardBrush}"
            CornerRadius="6"
            Padding="16"
            Margin="0,0,0,8"
            BorderBrush="{DynamicResource BorderDimBrush}"
            BorderThickness="1">
        <Grid>
            <!-- Shimmer overlay with gradient -->
            <Border x:Name="Shimmer"
                    CornerRadius="6"
                    ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5" Opacity="0.3">
                        <LinearGradientBrush.GradientStops>
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#FFFFFFFF" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush.GradientStops>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ShimmerTransform" X="-200"/>
                </Border.RenderTransform>
            </Border>

            <!-- Skeleton content structure -->
            <StackPanel>
                <!-- Main title skeleton -->
                <Rectangle Fill="#FF3C3C3C"
                          Height="16"
                          Width="200"
                          RadiusX="3"
                          RadiusY="3"
                          Margin="0,0,0,8"
                          HorizontalAlignment="Left"/>

                <!-- Subtitle skeleton -->
                <Rectangle Fill="#FF3C3C3C"
                          Height="12"
                          Width="150"
                          RadiusX="3"
                          RadiusY="3"
                          Margin="0,0,0,12"
                          HorizontalAlignment="Left"/>

                <!-- Metadata row -->
                <StackPanel Orientation="Horizontal">
                    <Rectangle Fill="#FF3C3C3C"
                              Height="10"
                              Width="80"
                              RadiusX="3"
                              RadiusY="3"
                              Margin="0,0,12,0"/>

                    <Rectangle Fill="#FF3C3C3C"
                              Height="10"
                              Width="100"
                              RadiusX="3"
                              RadiusY="3"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
