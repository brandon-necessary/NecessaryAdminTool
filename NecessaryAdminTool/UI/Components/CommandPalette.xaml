<UserControl x:Class="NecessaryAdminTool.UI.Components.CommandPalette"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="600">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- COMMAND PALETTE - TAG: #AUTO_UPDATE_UI_ENGINE #COMMAND_PALETTE  -->
    <!-- Keyboard-driven command launcher (Ctrl+K)                       -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <Border Background="{DynamicResource AcrylicBrush}"
            CornerRadius="{StaticResource FluentCornerRadius}"
            BorderBrush="{DynamicResource AccentOrangeBrush}"
            BorderThickness="1"
            Width="600"
            MaxHeight="450">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.6"/>
        </Border.Effect>

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Search Box -->
                <RowDefinition Height="*"/>     <!-- Results -->
                <RowDefinition Height="Auto"/>  <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Search Input -->
            <Border Grid.Row="0"
                    Background="{DynamicResource BgMediumBrush}"
                    BorderBrush="{DynamicResource BorderDimBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Icon -->
                    <TextBlock Grid.Column="0"
                               Text="🔍"
                               FontSize="18"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>

                    <!-- Search TextBox -->
                    <TextBox x:Name="TxtSearch"
                             Grid.Column="1"
                             FontSize="16"
                             FontFamily="{StaticResource FluentFont}"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             VerticalAlignment="Center"
                             TextChanged="TxtSearch_TextChanged"
                             KeyDown="TxtSearch_KeyDown"
                             CaretBrush="{DynamicResource AccentOrangeBrush}"/>

                    <!-- Placeholder text (shown when TxtSearch is empty) -->
                    <TextBlock Grid.Column="1"
                               IsHitTestVisible="False"
                               Text="Type a command or search..."
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontStyle="Italic"
                               FontSize="16"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=TxtSearch}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Close Button -->
                    <Button Grid.Column="2"
                            Content="ESC"
                            FontSize="10"
                            Padding="8,4"
                            Background="{DynamicResource BgDarkBrush}"
                            Foreground="{DynamicResource TextMutedBrush}"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource BorderDimBrush}"
                            Click="BtnClose_Click"
                            ToolTip="Close command palette (ESC)"/>
                </Grid>
            </Border>

            <!-- Results List -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource BgDarkBrush}">
                <ItemsControl x:Name="ResultsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0,0,0,1"
                                    Padding="16,12"
                                    Cursor="Hand"
                                    MouseEnter="ResultItem_MouseEnter"
                                    MouseLeave="ResultItem_MouseLeave"
                                    MouseLeftButtonDown="ResultItem_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Icon}"
                                               FontSize="20"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>

                                    <!-- Command Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                    </StackPanel>

                                    <!-- Shortcut -->
                                    <Border Grid.Column="2"
                                            Background="{DynamicResource BgMediumBrush}"
                                            BorderBrush="{DynamicResource BorderDimBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Padding="6,3"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Shortcut}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{DynamicResource BgMediumBrush}"
                    BorderBrush="{DynamicResource BorderDimBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,8">
                <Grid>
                    <TextBlock HorizontalAlignment="Left"
                               FontSize="10"
                               Foreground="{DynamicResource TextMutedBrush}">
                        <Run Text="↑↓ Navigate"/>
                        <Run Text="  •  "/>
                        <Run Text="↵ Execute"/>
                        <Run Text="  •  "/>
                        <Run Text="ESC Close"/>
                    </TextBlock>
                    <TextBlock x:Name="TxtResultCount"
                               HorizontalAlignment="Right"
                               FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="0 commands"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
