<UserControl x:Class="NecessaryAdminTool.UI.Components.DeviceHeatmap"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:NecessaryAdminTool.UI.Converters">
    <!-- TAG: #AUTO_UPDATE_UI_ENGINE #DEVICE_HEATMAP #DASHBOARD -->
    <UserControl.Resources>
        <converters:HealthToColorConverter x:Key="HealthToColorConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <TextBlock x:Name="TxtHeader" Text="DEVICE HEALTH MAP" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentZincBrush}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Ellipse Width="8" Height="8" Fill="#FF10B981" Margin="0,0,4,0"/>
                <TextBlock Text="Online" FontSize="9" Foreground="#FF6B7280" Margin="0,0,10,0"/>
                <Ellipse Width="8" Height="8" Fill="#FFEF4444" Margin="0,0,4,0"/>
                <TextBlock Text="Offline" FontSize="9" Foreground="#FF6B7280" Margin="0,0,10,0"/>
                <Ellipse Width="8" Height="8" Fill="#FF6B7280" Margin="0,0,4,0"/>
                <TextBlock Text="Unknown" FontSize="9" Foreground="#FF6B7280"/>
            </StackPanel>
        </Grid>

        <!-- Heatmap Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="200">
            <ItemsControl x:Name="HeatmapItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="24" Height="24" CornerRadius="4" Margin="1"
                                Background="{Binding Status, Converter={StaticResource HealthToColorConverter}}"
                                Cursor="Hand"
                                MouseLeftButtonDown="DeviceTile_Click"
                                Tag="{Binding Hostname}">
                            <Border.ToolTip>
                                <StackPanel>
                                    <TextBlock FontWeight="Bold">
                                        <Run Text="{Binding Hostname, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="OS: "/><Run Text="{Binding DisplayOS, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Status: "/><Run Text="{Binding Status, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border.ToolTip>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Show All toggle -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
            <TextBlock x:Name="TxtDeviceCount" FontSize="9" Foreground="#FF6B7280" Margin="0,0,8,0"
                       VerticalAlignment="Center"/>
            <Button x:Name="BtnShowAll" Content="Show All" FontSize="9" Padding="8,3"
                    Background="#FF2A2A2A" Foreground="{DynamicResource AccentZincBrush}" BorderThickness="1"
                    BorderBrush="#FF444444" Cursor="Hand" Visibility="Collapsed"
                    Click="BtnShowAll_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
