<UserControl x:Class="NecessaryAdminTool.UI.Components.ADTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:NecessaryAdminTool.UI.Components"
             xmlns:models="clr-namespace:NecessaryAdminTool.Models"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400">

    <!-- TAG: #AUTO_UPDATE_UI_ENGINE #AD_TREE_VIEW #NATIVE_WPF #XAML -->

    <UserControl.Resources>
        <!--Hierarchical Data Template for Tree Nodes -->
        <HierarchicalDataTemplate DataType="{x:Type models:ADTreeNode}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="0,4">
                <!-- Icon -->
                <TextBlock Text="{Binding Icon}"
                          FontFamily="Segoe MDL2 Assets"
                          FontSize="16"
                          Foreground="{DynamicResource AccentBrush}"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"/>

                <!-- Name -->
                <TextBlock Text="{Binding Name}"
                          FontSize="14"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"/>

                <!-- Status Badge -->
                <Border Background="{Binding StatusColor}"
                       CornerRadius="{StaticResource FluentCornerRadiusSmall}"
                       Padding="8,2"
                       Margin="0"
                       Visibility="{Binding StatusText, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding StatusText}"
                              FontSize="10"
                              Foreground="White"
                              FontWeight="SemiBold"/>
                </Border>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- String to Visibility Converter -->
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource MicaBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Search Bar -->
            <RowDefinition Height="*"/>     <!-- Tree View -->
            <RowDefinition Height="Auto"/>  <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Search Bar -->
        <Border Grid.Row="0"
                Background="{StaticResource MicaAltBrush}"
                CornerRadius="{StaticResource FluentCornerRadius}"
                Margin="12,12,12,8"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search Icon -->
                <TextBlock Grid.Column="0"
                          Text="&#xE721;"
                          FontFamily="Segoe MDL2 Assets"
                          FontSize="16"
                          Foreground="Gray"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"/>

                <!-- Search TextBox -->
                <TextBox Grid.Column="1"
                        x:Name="TxtSearch"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="14"
                        VerticalAlignment="Center"
                        TextChanged="TxtSearch_TextChanged"/>

                <TextBlock Grid.Column="1"
                          Text="Search Active Directory..."
                          FontSize="14"
                          Foreground="Gray"
                          VerticalAlignment="Center"
                          IsHitTestVisible="False"
                          Visibility="{Binding ElementName=TxtSearch, Path=Text.IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Expand/Collapse All Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="BtnExpandAll"
                           Content="&#xE70D;"
                           FontFamily="Segoe MDL2 Assets"
                           ToolTip="Expand All"
                           Click="BtnExpandAll_Click"
                           Style="{StaticResource IconButtonStyle}"
                           Margin="4,0,0,0"/>

                    <Button x:Name="BtnCollapseAll"
                           Content="&#xE70E;"
                           FontFamily="Segoe MDL2 Assets"
                           ToolTip="Collapse All"
                           Click="BtnCollapseAll_Click"
                           Style="{StaticResource IconButtonStyle}"
                           Margin="4,0,0,0"/>

                    <Button x:Name="BtnRefresh"
                           Content="&#xE72C;"
                           FontFamily="Segoe MDL2 Assets"
                           ToolTip="Refresh"
                           Click="BtnRefresh_Click"
                           Style="{StaticResource IconButtonStyle}"
                           Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tree View -->
        <Border Grid.Row="1"
                Background="{StaticResource MicaAltBrush}"
                CornerRadius="{StaticResource FluentCornerRadius}"
                Margin="12,0,12,8">
            <TreeView x:Name="TreeAD"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="8"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">

                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                        <Setter Property="Padding" Value="4"/>
                        <Setter Property="Margin" Value="0,2"/>

                        <!-- Context Menu -->
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <!-- Computer Context Menu -->
                                    <MenuItem Header="Remote Desktop (RDP)"
                                             Tag="RDP"
                                             Click="ContextMenu_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE977;" FontFamily="Segoe MDL2 Assets"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="PowerShell Remote"
                                             Tag="PowerShell"
                                             Click="ContextMenu_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Services Manager"
                                             Tag="Services"
                                             Click="ContextMenu_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE950;" FontFamily="Segoe MDL2 Assets"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="Scan Computer"
                                             Tag="Scan"
                                             Click="ContextMenu_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Refresh Status"
                                             Tag="Refresh"
                                             Click="ContextMenu_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                    <!-- OU Context Menu -->
                                    <MenuItem Header="Scan All Computers in OU"
                                             Tag="ScanOU"
                                             Click="ContextMenu_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Export Computer List"
                                             Tag="Export"
                                             Click="ContextMenu_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{StaticResource MicaAltBrush}"
                CornerRadius="{StaticResource FluentCornerRadius}"
                Margin="12,0,12,12"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                          x:Name="TxtStatus"
                          Text="Ready"
                          FontSize="12"
                          Foreground="Gray"
                          VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="&#xE977;"
                              FontFamily="Segoe MDL2 Assets"
                              FontSize="14"
                              Foreground="{StaticResource SuccessBrush}"
                              VerticalAlignment="Center"
                              Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtOnlineCount"
                              Text="0"
                              FontSize="12"
                              Foreground="{StaticResource SuccessBrush}"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"/>

                    <TextBlock Text="&#xE977;"
                              FontFamily="Segoe MDL2 Assets"
                              FontSize="14"
                              Foreground="{StaticResource ErrorBrush}"
                              VerticalAlignment="Center"
                              Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtOfflineCount"
                              Text="0"
                              FontSize="12"
                              Foreground="{StaticResource ErrorBrush}"
                              VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
