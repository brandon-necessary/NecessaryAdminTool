<UserControl x:Class="NecessaryAdminTool.UI.Components.KpiCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:NecessaryAdminTool.UI.Components">
    <!-- TAG: #AUTO_UPDATE_UI_ENGINE #KPI_CARD #DASHBOARD -->
    <Border x:Name="CardBorder" Background="#FF1E1E1E" BorderBrush="#FF3C3C3C"
            BorderThickness="1" CornerRadius="8" Padding="16" Margin="4">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Left accent border -->
            <Border x:Name="AccentStripe" Grid.RowSpan="4" Width="3" HorizontalAlignment="Left"
                    Margin="-16,0,0,0" CornerRadius="8,0,0,8"/>

            <!-- Label -->
            <TextBlock x:Name="TxtLabel" Grid.Row="0" Grid.ColumnSpan="2"
                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"
                       Foreground="#FFA1A1AA"/>

            <!-- Big number -->
            <TextBlock x:Name="TxtValue" Grid.Row="1"
                       FontSize="32" FontWeight="Bold" Foreground="White"
                       Margin="0,0,0,2"/>

            <!-- Delta indicator -->
            <StackPanel x:Name="DeltaPanel" Grid.Row="1" Grid.Column="1"
                        Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,6">
                <TextBlock x:Name="TxtDelta" FontSize="11" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Subtitle -->
            <TextBlock x:Name="TxtSubtitle" Grid.Row="2" Grid.ColumnSpan="2"
                       FontSize="9" Foreground="#FF6B7280" Margin="0,0,0,4"/>

            <!-- Sparkline -->
            <components:SparklineControl x:Name="Sparkline" Grid.Row="3" Grid.ColumnSpan="2"
                                         Height="36" Margin="0,4,0,0"/>
        </Grid>
    </Border>
</UserControl>
