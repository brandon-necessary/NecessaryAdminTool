<UserControl x:Class="NecessaryAdminTool.UI.Components.ActivityFeed"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- TAG: #AUTO_UPDATE_UI_ENGINE #ACTIVITY_FEED #DASHBOARD -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with severity toggles -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="ACTIVITY FEED" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentZincBrush}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ToggleButton x:Name="BtnShowSuccess" IsChecked="True" Click="SeverityToggle_Click"
                              Content="&#x2713;" FontSize="10" Padding="6,2" Margin="2,0"
                              Background="#FF1A2E1A" Foreground="{DynamicResource SuccessBrush}" BorderThickness="1"
                              BorderBrush="{DynamicResource SuccessBrush}" Cursor="Hand"
                              ToolTip="Show/hide success events"/>
                <ToggleButton x:Name="BtnShowInfo" IsChecked="True" Click="SeverityToggle_Click"
                              Content="&#x2139;" FontSize="10" Padding="6,2" Margin="2,0"
                              Background="#FF1A1A2E" Foreground="{DynamicResource InfoBrush}" BorderThickness="1"
                              BorderBrush="{DynamicResource InfoBrush}" Cursor="Hand"
                              ToolTip="Show/hide info events"/>
                <ToggleButton x:Name="BtnShowWarning" IsChecked="True" Click="SeverityToggle_Click"
                              Content="&#x26A0;" FontSize="10" Padding="6,2" Margin="2,0"
                              Background="#FF2E2A1A" Foreground="#FFF59E0B" BorderThickness="1"
                              BorderBrush="#FFF59E0B" Cursor="Hand"
                              ToolTip="Show/hide warning events"/>
                <ToggleButton x:Name="BtnShowError" IsChecked="True" Click="SeverityToggle_Click"
                              Content="&#x2717;" FontSize="10" Padding="6,2" Margin="2,0"
                              Background="#FF2E1A1A" Foreground="{DynamicResource ErrorBrush}" BorderThickness="1"
                              BorderBrush="{DynamicResource ErrorBrush}" Cursor="Hand"
                              ToolTip="Show/hide error events"/>
            </StackPanel>
        </Grid>

        <!-- Event list -->
        <ListBox x:Name="EventList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 MaxHeight="300">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Timestamp -->
                        <TextBlock Grid.Column="0" Text="{Binding TimestampDisplay}"
                                   FontSize="9" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"
                                   FontFamily="Consolas"/>

                        <!-- Severity dot -->
                        <Ellipse Grid.Column="1" Width="8" Height="8" VerticalAlignment="Center">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{Binding SeverityColor}"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <!-- Message -->
                        <TextBlock Grid.Column="2" Text="{Binding Message}"
                                   FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" Margin="6,0,0,0"/>

                        <!-- Source -->
                        <TextBlock Grid.Column="3" Text="{Binding Source}"
                                   FontSize="8" Foreground="{DynamicResource BorderBrightBrush}" VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#11FFFFFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
    </Grid>
</UserControl>
