<Window x:Class="NecessaryAdminTool.UI.Dialogs.AdvancedFilterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Advanced Filter" Height="620" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgDarkestBrush}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <!-- TAG: #AUTO_UPDATE_UI_ENGINE #FILTER_SYSTEM #FLUENT_DESIGN #DIALOG -->

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BgLightBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BgLightBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{DynamicResource BgLightBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource MicaBrush}" Margin="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="&#128269; Advanced Filter" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                <TextBlock Text="Filter fleet inventory by any combination of criteria."
                           FontSize="13" Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>

            <!-- Fields -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Name Pattern -->
                    <Label Content="Computer Name (glob/contains)"/>
                    <TextBox x:Name="TxtNamePattern" Margin="0,0,0,12"
                             ToolTip="Supports wildcards: * (any), ? (single char). E.g. DESK-* or *LAP*"/>

                    <!-- Status -->
                    <Label Content="Status"/>
                    <ComboBox x:Name="CboStatus" Margin="0,0,0,12">
                        <ComboBoxItem Content="All" IsSelected="True"/>
                        <ComboBoxItem Content="Online"/>
                        <ComboBoxItem Content="Offline"/>
                        <ComboBoxItem Content="Warning"/>
                    </ComboBox>

                    <!-- OS Filter -->
                    <Label Content="Operating System (contains)"/>
                    <TextBox x:Name="TxtOSFilter" Margin="0,0,0,12"
                             ToolTip="Partial match. E.g. Windows 11, Server 2022"/>

                    <!-- OU Filter -->
                    <Label Content="Organizational Unit (contains)"/>
                    <TextBox x:Name="TxtOUFilter" Margin="0,0,0,12"
                             ToolTip="Partial OU path match. E.g. Workstations"/>

                    <!-- RAM Range -->
                    <Label Content="RAM Range (GB)"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtMinRam" Grid.Column="0" ToolTip="Minimum RAM in GB (leave blank for no limit)"/>
                        <TextBlock Grid.Column="1" Text=" – " Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="8,0" FontSize="14"/>
                        <TextBox x:Name="TxtMaxRam" Grid.Column="2" ToolTip="Maximum RAM in GB (leave blank for no limit)"/>
                    </Grid>

                    <!-- Last Seen After -->
                    <Label Content="Last Seen After"/>
                    <DatePicker x:Name="DpLastSeenAfter" Margin="0,0,0,12"
                                ToolTip="Only show devices last seen after this date"/>

                    <!-- Last Seen Before -->
                    <Label Content="Last Seen Before"/>
                    <DatePicker x:Name="DpLastSeenBefore" Margin="0,0,0,12"
                                ToolTip="Only show devices last seen before this date"/>

                    <!-- Logic Operator -->
                    <Label Content="Logic Operator"/>
                    <ComboBox x:Name="CboLogic" Margin="0,0,0,4"
                              ToolTip="AND: all criteria must match. OR: any criterion matches.">
                        <ComboBoxItem Content="AND" IsSelected="True"/>
                        <ComboBoxItem Content="OR"/>
                    </ComboBox>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer Buttons -->
            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="BtnClear" Content="Clear" Click="BtnClear_Click"
                        Background="{DynamicResource BorderBrightBrush}" Foreground="White"
                        BorderThickness="0" Padding="16,8" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="2" x:Name="BtnApply" Content="Apply Filter" Click="BtnApply_Click"
                        Background="{DynamicResource AccentPrimaryBrush}" Foreground="White"
                        BorderThickness="0" Padding="20,8" Cursor="Hand" Margin="0,0,8,0"
                        ToolTip="Apply these filter criteria to the fleet grid">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="3" x:Name="BtnClose" Content="Cancel" Click="BtnClose_Click"
                        Background="{DynamicResource BgLightBrush}" Foreground="White"
                        BorderThickness="0" Padding="16,8" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
