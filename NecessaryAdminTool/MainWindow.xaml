<Window x:Class="NecessaryAdminTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NecessaryAdminTool"
        xmlns:converters="clr-namespace:NecessaryAdminTool.UI.Converters"
        xmlns:components="clr-namespace:NecessaryAdminTool.UI.Components"
        Title="NecessaryAdminTool Suite"
        Height="900" Width="1500"
        MinHeight="700" MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        Background="#FF0D0D0D"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- Theme resources inherited from App.xaml            -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Window.Resources>
        <!-- TAG: #AUTO_UPDATE_UI_ENGINE #VALUE_CONVERTERS -->
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- MAIN LAYOUT - TAG: #AUTO_UPDATE_UI_ENGINE #GRID_OVERLAY    -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Main Content -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════ -->
        <!-- TOP HEADER BAR                         -->
        <!-- ══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource BgMediumBrush}"
                BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/> <!-- Bulk Operations -->
                </Grid.ColumnDefinitions>

                <!-- ══════════════════════════════════════════════════════════════ -->
                <!-- LOGO_PLACEMENT: Main Window Top Bar Logo                      -->
                <!-- To update: Edit LogoConfig class in MainWindow.xaml.cs        -->
                <!-- ══════════════════════════════════════════════════════════════ -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Icon with Orange/Zinc Gradient -->
                    <Border Width="36" Height="36"
                            CornerRadius="6"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFFF8533" Offset="0"/>
                                <GradientStop Color="#FFCC6B29" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#FFFF8533" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                        </Border.Effect>
                        <Viewbox Width="20" Height="20">
                            <Canvas Width="24" Height="24">
                                <!-- A Letter Icon -->
                                <Path Fill="White" Data="M12,2 L20,22 L16,22 L14.5,18 L9.5,18 L8,22 L4,22 Z M10.5,14 L13.5,14 L12,9 Z"/>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <!-- Brand Text with Orange/Zinc Gradient -->
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                        <TextBlock FontSize="22" FontWeight="Black" VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="2" Opacity="0.5"/>
                            </TextBlock.Effect>
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FFFF8533" Offset="0"/>
                                    <GradientStop Color="#FFA1A1AA" Offset="0.7"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                            <Run Text="Necessary" FontSize="24" FontWeight="ExtraBold"/>
                            <Run Text="Admin" FontSize="18" FontWeight="Light"/>
                        </TextBlock>
                        <TextBlock Text="I T   M A N A G E M E N T   S U I T E" FontSize="7"
                                   Foreground="{StaticResource AccentOrangeBrush}"
                                   FontWeight="Bold"
                                   Margin="2,0,0,0"
                                   Opacity="0.8"/>
                    </StackPanel>

                    <!-- Version Badge - TAG: #THEME_COLORS #BRANDING -->
                    <Border Background="#FF1A1A1A"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="6,2"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF8533" Offset="0"/>
                                <GradientStop Color="#A1A1AA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Grid>
                            <TextBlock x:Name="TxtVersionBadge" FontSize="10" FontWeight="Bold">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF8533" Offset="0"/>
                                        <GradientStop Color="#A1A1AA" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>

                            <!-- TAG: #SUPERADMIN #TOOLTIPS #CONFIGURATION - Invisible button overlay - Click 5x rapidly to access SuperAdmin -->
                            <Button x:Name="BtnSuperAdminTrigger"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Arrow"
                                    Click="BtnSuperAdminTrigger_Click"
                                    ToolTip="Hidden SuperAdmin access trigger. Rapidly click logo 5 times to unlock advanced system configuration features including direct database manipulation, registry editing, and developer tools. Use with caution - intended for administrators only."
                                    Opacity="0.01"
                                    IsTabStop="False"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Role Badge - TAG: #THEME_COLORS #AUTH_STATUS #ELEVATION -->
                <Border x:Name="RoleBadgeBorder" Grid.Column="1" Background="#FF2A2A2A"
                        CornerRadius="3" BorderThickness="1" BorderBrush="#FF3C3C3C"
                        Padding="8,3" Margin="20,0,0,0" VerticalAlignment="Center"
                        Cursor="Hand"
                        ToolTip="Double-click to restart as Administrator (when not elevated)">
                    <TextBlock x:Name="TxtRoleBadge" Text="GUEST" FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}" FontWeight="Bold"
                               MouseLeftButtonDown="TxtRoleBadge_MouseLeftButtonDown"/>
                </Border>

                <!-- Header separator: Logo/Role | Status group -->
                <Border Grid.Column="1" HorizontalAlignment="Right" Margin="12,0,0,0"
                        Width="1" Background="#FF333333" VerticalAlignment="Stretch"
                        Opacity="0.7"/>

                <!-- Split Error Indicator - TAG: #ERROR_TRACKING #STATUS_INDICATORS -->
                <StackPanel x:Name="ErrorIndicator" Grid.Column="2" Orientation="Horizontal" Margin="15,0,0,0"
                            VerticalAlignment="Center" Visibility="Collapsed">
                    <!-- Yellow: Warnings/Debug - TAG: #ERROR_TRACKING -->
                    <Border x:Name="WarningIndicator" Background="#FFCCAA00" CornerRadius="3,0,0,3"
                            Padding="6,3" ToolTip="Warnings detected - check debug log"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠" FontSize="10" Foreground="White" Margin="0,0,4,0"/>
                            <TextBlock x:Name="TxtWarningCount" Text="0" FontSize="10"
                                       Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <!-- Red: Critical Errors - TAG: #ERROR_TRACKING -->
                    <Border x:Name="CriticalIndicator" Background="#FFDD0000" CornerRadius="0,3,3,0"
                            Padding="6,3" ToolTip="Critical errors - check debug log"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✗" FontSize="10" Foreground="White" Margin="0,0,4,0"/>
                            <TextBlock x:Name="TxtCriticalCount" Text="0" FontSize="10"
                                       Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Master Log Status - TAG: #STATUS_INDICATORS #LOGGING -->
                <TextBlock x:Name="TxtLogPath" Grid.Column="3" Text="LOG: CHECKING..."
                           Foreground="{StaticResource TextMutedBrush}" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,15,0"/>

                <!-- Domain Badge - TAG: #DC_DISCOVERY #THEME_COLORS -->
                <Border x:Name="DomainBadge" Grid.Column="4"
                        Background="#FF1A1A1A"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="8,3"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        ToolTip="Detected Active Directory domain">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF8533" Offset="0"/>
                            <GradientStop Color="#A1A1AA" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtDomainName" Text="DOMAIN: CHECKING..."
                                   FontSize="10" FontWeight="Bold" VerticalAlignment="Center">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF8533" Offset="0"/>
                                    <GradientStop Color="#A1A1AA" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Auth Status with Login Button - TAG: #AUTH_STATUS #STATUS_INDICATORS -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock x:Name="TxtAuthStatus" Text="NOT AUTHENTICATED"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>

                    <!-- TAG: #TOOLTIPS #NAVIGATION - Login Button (appears in read-only mode) -->
                    <Button x:Name="BtnLoginFromReadOnly"
                            Content="🔑 LOGIN"
                            Click="BtnLoginFromReadOnly_Click"
                            Visibility="Collapsed"
                            Padding="8,3,8,3"
                            FontSize="9"
                            FontWeight="Bold"
                            Background="{StaticResource AccentOrangeBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Authenticate with Active Directory credentials to unlock full application functionality. In read-only mode, limited features are available. After login, access scanning, deployment, and management tools. Credentials stored securely in Windows Credential Manager.">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="3"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#FF8533" Offset="0"/>
                                                    <GradientStop Color="#A1A1AA" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Header separator: Status group | Actions group -->
                <Border Grid.Column="5" HorizontalAlignment="Right" Margin="0,0,-4,0"
                        Width="1" Background="#FF333333" VerticalAlignment="Stretch"
                        Opacity="0.7"/>

                <!-- TAG: #TOOLTIPS #NAVIGATION -->
                <!-- Auth Button -->
                <Button x:Name="BtnAuth" Grid.Column="6" Content="LOGIN"
                        Style="{StaticResource BtnGhost}" Click="BtnAuth_Click"
                        Padding="12,6" FontSize="11" Margin="0,0,8,0"
                        ToolTip="Authenticate with Active Directory domain credentials. Required for scanning AD computers and accessing fleet inventory features. Credentials are securely stored in Windows Credential Manager. Shows logout option when authenticated."/>

                <!-- Theme Toggle -->
                <Button x:Name="BtnTheme" Grid.Column="7" Content="🎨"
                        Style="{StaticResource BtnGhost}" Click="BtnTheme_Click"
                        Padding="8,6" FontSize="13" Margin="0,0,4,0"
                        ToolTip="Toggles between dark and light theme. Changes apply immediately to all windows and UI elements. Theme preference is saved and persists across application restarts. Uses 35+ theme resource keys for complete UI coverage."/>

                <!-- TAG: #TOOLTIPS #CONFIGURATION -->
                <!-- Options Button - TAG: #SETTINGS #OPTIONS_MENU -->
                <Button x:Name="BtnOptions" Grid.Column="8" Content="⚙️"
                        Style="{StaticResource BtnGhost}" Click="BtnOptions_Click"
                        Padding="8,6" FontSize="13" Margin="0,0,4,0"
                        ToolTip="Opens Options window to configure all application settings including database, deployment paths, theme colors, AD query methods, background service, bookmarks, connection profiles, and more. 21 configurable settings across 9 categories."/>

                <!-- TAG: #TOOLTIPS #NAVIGATION -->
                <!-- About Button -->
                <Button x:Name="BtnAbout" Grid.Column="9" Content="ℹ️"
                        Style="{StaticResource BtnGhost}" Click="BtnAbout_Click"
                        Padding="8,6" FontSize="13" Margin="0,0,4,0"
                        ToolTip="Opens About window with application version, build date, credits, and license information. Current version: 1.0 (1.2602.0.0). Check for updates, view change log, and access support resources."/>

                <!-- Check for Updates Button - TAG: #AUTO_UPDATE #VERSION_1_1 -->
                <Button x:Name="BtnCheckUpdates" Grid.Column="10" Content="🔄"
                        Style="{StaticResource BtnGhost}" Click="BtnCheckUpdates_Click"
                        Padding="8,6" FontSize="13" Margin="0,0,4,0"
                        ToolTip="Checks for application updates from GitHub releases. Uses Squirrel.Windows auto-update system. Respects enterprise GPO policies and DisableAutoUpdates setting. Update checks can be disabled in Options or via registry."/>

                <!-- TAG: #TOOLTIPS #FILE_OPERATIONS -->
                <!-- Debug Log -->
                <Button x:Name="BtnOpenDebugLog" Grid.Column="11" Content="📋 DEBUG LOG"
                        Style="{StaticResource BtnGhost}" Click="BtnOpenLog_Click"
                        Padding="8,6" FontSize="10"
                        ToolTip="Opens application debug log file in default text editor. Logs are stored at %APPDATA%\NecessaryAdminTool\Logs\. Contains detailed information about application operations, errors, and diagnostic data. Useful for troubleshooting issues."/>

                <!-- TAG: #FEATURE_BULK_OPERATIONS #TOOLTIPS -->
                <!-- Bulk Operations -->
                <Button x:Name="BtnBulkOperations" Grid.Column="12" Content="⚡ BULK OPS"
                        Style="{StaticResource BtnGhost}" Click="BtnBulkOperations_Click"
                        Padding="8,6" FontSize="10"
                        ToolTip="Opens Bulk Operations window for executing commands on multiple computers simultaneously. Supports restart, PowerShell scripts, service control, inventory collection, and more. Execute operations in parallel with configurable thread count and retry logic."/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════ -->
        <!-- MAIN CONTENT GRID WITH BOTTOM DOCKING  -->
        <!-- ══════════════════════════════════════ -->
        <DockPanel Grid.Row="1">

        <!-- ══════════════════════════════════════ -->
        <!-- COLLAPSIBLE TERMINAL (BOTTOM)          -->
        <!-- ══════════════════════════════════════ -->
        <Border x:Name="TerminalPanel" DockPanel.Dock="Bottom"
                Background="{StaticResource BgDarkBrush}"
                BorderBrush="{StaticResource BorderDimBrush}"
                BorderThickness="0,1,0,0" Height="0"
                MinHeight="100" MaxHeight="500"
                Visibility="Collapsed">
            <DockPanel>
                <!-- Resizable Splitter (Top drag bar) -->
                <GridSplitter DockPanel.Dock="Top" Height="5"
                              HorizontalAlignment="Stretch"
                              Background="{StaticResource BorderDimBrush}"
                              Cursor="SizeNS"
                              ResizeBehavior="PreviousAndNext"
                              ToolTip="Drag to resize terminal"/>

                <!-- Terminal Header -->
                <Border DockPanel.Dock="Top" Background="{StaticResource BgMediumBrush}"
                        Padding="10,6">
                    <Grid>
                        <TextBlock Text="LIVE TERMINAL &amp; DEBUG OUTPUT" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                        <!-- TAG: #TOOLTIPS #NAVIGATION -->
                        <Button Content="✕" HorizontalAlignment="Right" Style="{StaticResource BtnGhost}"
                                Padding="6,2" FontSize="12" Click="BtnToggleTerminal_Click"
                                ToolTip="Closes the terminal/debug output panel. Terminal shows real-time WMI queries, PowerShell commands, and diagnostic information. Click 'TERMINAL' button to reopen."/>
                    </Grid>
                </Border>
                <!-- Terminal Output -->
                <RichTextBox x:Name="RtbTerminal" Background="Black"
                             Foreground="LimeGreen" FontFamily="Consolas" FontSize="11"
                             IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                             BorderThickness="0" Padding="10,5"/>
            </DockPanel>
        </Border>

        <!-- Terminal Toggle Bar - TAG: #BOTTOM_BAR -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource BgMediumBrush}"
                BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="0,1,0,0"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- TAG: #TOOLTIPS #NAVIGATION -->
                <Button x:Name="BtnToggleTerminal" Grid.Column="0" Content="▼ TERMINAL"
                        Style="{StaticResource BtnGhost}" Click="BtnToggleTerminal_Click"
                        Padding="12,6" FontSize="11" FontWeight="Bold"
                        ToolTip="Toggles live terminal/debug output panel visibility. Shows real-time WMI queries, PowerShell commands, system operations, and diagnostic information. Useful for troubleshooting and monitoring background operations."/>

                <!-- Integrated Status & Progress -->
                <StackPanel Grid.Column="1" Margin="15,0,15,0" VerticalAlignment="Center">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Main Status Text -->
                        <TextBlock Grid.Column="0" x:Name="TxtScanProgress" Text="System Ready"
                                   Foreground="White" FontSize="11" FontWeight="Bold"
                                   Margin="0,0,12,0" VerticalAlignment="Center"/>

                        <!-- Terminal Activity Indicator -->
                        <TextBlock Grid.Column="1" x:Name="TxtTerminalStatus" Text=""
                                   Foreground="{StaticResource AccentOrangeBrush}" FontSize="10"
                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                   ToolTip="Recent activity - click ▼ TERMINAL to view all logs"/>

                        <!-- Status Message - TAG: #VERSION_7 #AUTO_SAVE #NOTIFICATIONS -->
                        <TextBlock Grid.Column="2" x:Name="StatusMessage" Text=""
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"
                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                    </Grid>

                    <!-- Progress Bar (shows during scans/operations) -->
                    <ProgressBar x:Name="ProgressScan" Height="8"
                                 Background="#FF2A2A2A"
                                 BorderThickness="0"
                                 Value="0" Maximum="100" Visibility="Collapsed">
                        <ProgressBar.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF8533" Offset="0"/>
                                <GradientStop Color="#FFAA6633" Offset="1"/>
                            </LinearGradientBrush>
                        </ProgressBar.Foreground>
                    </ProgressBar>
                </StackPanel>

                <!-- Remote Console Input -->
                <TextBox x:Name="TxtConsoleInput" Grid.Column="2" Width="300"
                         Background="#FF1A1A1A" Foreground="LimeGreen"
                         FontFamily="Consolas" FontSize="11"
                         Padding="8,5" Margin="0,0,4,0"
                         ToolTip="Remote PowerShell command (Enter to execute)"/>

                <!-- TAG: #TOOLTIPS #ACTIONS -->
                <Button x:Name="BtnConsoleExec" Grid.Column="3" Content="EXEC"
                        Style="{StaticResource BtnPrimary}" Click="BtnConsole_Click"
                        Padding="12,4" FontSize="10"
                        ToolTip="Executes PowerShell command on target computer via PowerShell Remoting. Type command in text box and click EXEC or press Enter. Requires WinRM enabled and admin credentials. Output appears in terminal below."/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════ -->
        <!-- MAIN CONTENT AREA                      -->
        <!-- Ultrawide: content stays readable,     -->
        <!-- dark bg fills edges on 3440px+ screens  -->
        <!-- ══════════════════════════════════════ -->
        <Grid MaxWidth="1920" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" MinWidth="320" MaxWidth="480"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2.5*" MinWidth="700"/>
            </Grid.ColumnDefinitions>

            <!-- ════════════════════════════════ -->
            <!-- LEFT SIDEBAR                     -->
            <!-- ════════════════════════════════ -->
            <Border Grid.Column="0" Background="{StaticResource BgDarkBrush}"
                    BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="0,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                    <StackPanel>

                        <!-- PINNED DEVICES MONITOR -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <!-- TAG: #THEME_COLORS #SECTION_HEADERS -->
                                <TextBlock Text="📌 PINNED DEVICES MONITOR"
                                           Foreground="{StaticResource AccentOrangeBrush}"
                                           FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>

                                <TextBlock Text="Pin up to 10 devices for quick status monitoring:"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="9" Margin="0,0,0,8"/>

                                <!-- Add Device Input -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtPinnedDeviceInput" Grid.Column="0"
                                             Margin="0,0,6,0"
                                             Foreground="White" FontSize="11"
                                             ToolTip="Enter hostname or IP address"
                                             Background="#FF2A2A2A" BorderBrush="#FF444444"
                                             Padding="6,4"/>
                                    <!-- TAG: #TOOLTIPS #ACTIONS -->
                                    <Button Grid.Column="1" Content="+ ADD"
                                            Style="{StaticResource BtnPrimary}"
                                            Click="BtnAddPinnedDevice_Click"
                                            Padding="12,4" FontSize="10" FontWeight="Bold"
                                            ToolTip="Adds computer to pinned devices list for quick access and monitoring. Enter hostname or IP address in text box. Pinned devices are continuously monitored for online/offline status with ping checks every 30 seconds."/>
                                </Grid>

                                <!-- Pinned Devices DataGrid -->
                                <DataGrid x:Name="GridPinnedDevices"
                                          ItemsSource="{Binding}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeRows="False"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          SelectionMode="Single"
                                          Background="#FF1E1E1E"
                                          BorderBrush="#FF3C3C3C"
                                          BorderThickness="1"
                                          RowBackground="#FF2A2A2A"
                                          AlternatingRowBackground="#FF252525"
                                          FontSize="10"
                                          Height="180"
                                          Margin="0,0,0,8"
                                          MouseDoubleClick="GridPinnedDevices_MouseDoubleClick">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#FF1A1A1A"/>
                                            <Setter Property="Foreground" Value="#FFFF8533"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                            <Setter Property="BorderBrush" Value="#FF3C3C3C"/>
                                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="PC Name" Binding="{Binding Input}" Width="125" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="Padding" Value="6,2"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="70" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{Binding StatusColor}"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Padding" Value="6,2"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Last Ping" Binding="{Binding LastChecked}" Width="80" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FFA1A1AA"/>
                                                    <Setter Property="Padding" Value="6,2"/>
                                                    <Setter Property="FontSize" Value="10"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
