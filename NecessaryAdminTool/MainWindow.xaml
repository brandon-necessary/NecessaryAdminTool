                                    <StackPanel>
                                        <TextBlock Text="💿 OS DISTRIBUTION" Foreground="{DynamicResource AccentOrangeBrush}"
                                                   FontSize="12" FontWeight="Bold" Margin="0,0,0,16"/>

                                        <!-- Win11 -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
