                                        BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="💿 OS DISTRIBUTION" Foreground="{StaticResource AccentOrangeBrush}"
                                                   FontSize="12" FontWeight="Bold" Margin="0,0,0,16"/>

                                        <!-- Win11 -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Windows 11" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                                            <ProgressBar Grid.Column="1" x:Name="BarWin11" Height="20" Background="#FF2A2A2A"
                                                         Foreground="LimeGreen" Margin="8,0" Maximum="100"/>
                                            <TextBlock Grid.Column="2" x:Name="TxtWin11Count" Text="0 (0%)" Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="10" VerticalAlignment="Center" MinWidth="60"/>
                                        </Grid>

                                        <!-- Win10 -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Windows 10" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                                            <ProgressBar Grid.Column="1" x:Name="BarWin10" Height="20" Background="#FF2A2A2A"
                                                         Foreground="#FF4FC3F7" Margin="8,0" Maximum="100"/>
                                            <TextBlock Grid.Column="2" x:Name="TxtWin10Count" Text="0 (0%)" Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="10" VerticalAlignment="Center" MinWidth="60"/>
                                        </Grid>

                                        <!-- Win7 -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Windows 7" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                                            <ProgressBar Grid.Column="1" x:Name="BarWin7" Height="20" Background="#FF2A2A2A"
                                                         Foreground="#FFFF6B6B" Margin="8,0" Maximum="100"/>
                                            <TextBlock Grid.Column="2" x:Name="TxtWin7Count" Text="0 (0%)" Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="10" VerticalAlignment="Center" MinWidth="60"/>
                                        </Grid>

                                        <!-- Legacy/Other -->
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Legacy/Other" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                                            <ProgressBar Grid.Column="1" x:Name="BarLegacy" Height="20" Background="#FF2A2A2A"
                                                         Foreground="#FFFFA726" Margin="8,0" Maximum="100"/>
                                            <TextBlock Grid.Column="2" x:Name="TxtLegacyCount" Text="0 (0%)" Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="10" VerticalAlignment="Center" MinWidth="60"/>
                                        </Grid>

                                        <!-- Detailed Version Breakdown -->
                                        <Border Background="#FF2A2A2A" BorderBrush="#FF3C3C3C" BorderThickness="1"
                                                CornerRadius="4" Padding="12,10" Margin="0,0,0,0">
                                            <Expander Header="📋 DETAILED VERSION BREAKDOWN" Foreground="{StaticResource AccentOrangeBrush}"
                                                      FontSize="10" FontWeight="SemiBold" IsExpanded="False">
                                                <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                                                    <ItemsControl x:Name="ListDetailedVersions">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,6">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="120"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="60"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding Version}" Foreground="White"
                                                                               FontSize="9" VerticalAlignment="Center"/>
                                                                    <ProgressBar Grid.Column="1" Value="{Binding Percentage}" Height="12"
                                                                                 Background="#FF1A1A1A" Foreground="{Binding Color}"
                                                                                 Margin="4,0" Maximum="100"/>
                                                                    <TextBlock Grid.Column="2" Text="{Binding CountText}" Foreground="{StaticResource TextMutedBrush}"
                                                                               FontSize="9" VerticalAlignment="Center" TextAlignment="Right"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Expander>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- DC Health Monitor - TAG: #DC_HEALTH #DASHBOARD #DOMAIN_CONTROLLERS -->
                                <Border Grid.Column="1" Background="#FF1E1E1E" BorderBrush="{StaticResource AccentOrangeBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="16" Margin="4,0">
                                    <StackPanel>
                                        <!-- Header with Domain Suffix - TAG: #DC_HEALTH #UI_IMPROVEMENT -->
                                        <Grid Margin="0,0,0,12">
                                            <TextBlock Text="🌐 DOMAIN CONTROLLERS" Foreground="{StaticResource AccentOrangeBrush}"
                                                       FontSize="11" FontWeight="Bold" HorizontalAlignment="Left"/>
                                            <TextBlock x:Name="TxtDCDomainSuffix" Text="" Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="9" FontWeight="Normal" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                        </Grid>

                                        <!-- DC Count Summary -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="🖥️" FontSize="24" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock x:Name="TxtDCCount" Text="0 Detected" Foreground="White"
                                                           FontSize="18" FontWeight="Bold"/>
                                                <TextBlock x:Name="TxtDCLastScan" Text="Never scanned"
                                                           Foreground="{StaticResource TextMutedBrush}" FontSize="9"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- DC Health List - TAG: #DC_HEALTH #UI_IMPROVEMENT #RESPONSIVE_LAYOUT - Auto-expanding cards -->
                                        <Border Background="#FF2A2A2A" BorderBrush="#FF3C3C3C" BorderThickness="1"
                                                CornerRadius="4" Padding="12">
                                            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl x:Name="ListDCHealth">
                                                    <!-- TAG: #DC_HEALTH #UI_IMPROVEMENT - WrapPanel with responsive card sizing -->
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal" ItemWidth="200" ItemHeight="120"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <!-- DC Card - TAG: #DC_HEALTH #UI_IMPROVEMENT #READABILITY_ENHANCED #RESPONSIVE #FAVORITES -->
                                                            <Border Background="#FF2C2C2C" BorderBrush="#FF4A4A4A"
                                                                    BorderThickness="1.5" CornerRadius="8" Padding="16,14"
                                                                    Margin="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                                                    AllowDrop="True" Tag="{Binding Hostname}">
                                                                <Grid>
                                                                    <!-- Favorite Star Button - Top Right -->
                                                                    <Button x:Name="BtnFavoriteDC"
                                                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                            Width="24" Height="24" Padding="0" Margin="-8,-8,0,0"
                                                                            Background="Transparent" BorderThickness="0"
                                                                            Cursor="Hand"
                                                                            Click="BtnFavoriteDC_Click"
                                                                            Tag="{Binding Hostname}"
                                                                            ToolTip="Click to favorite/unfavorite this DC">
                                                                        <TextBlock Text="{Binding FavoriteIcon}" FontSize="16"/>
                                                                    </Button>

                                                                    <StackPanel>
                                                                        <!-- DC Hostname - Larger, more prominent -->
                                                                        <TextBlock Text="{Binding Hostname, Mode=OneWay}"
                                                                                   Foreground="#FFEEEEEE" FontSize="13" FontWeight="Bold"
                                                                                   TextAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                                   Margin="0,0,0,10"/>

                                                                        <!-- Latency Badge - Larger, primary metric -->
                                                                        <Border Background="{Binding LatencyBg, Mode=OneWay}"
                                                                                CornerRadius="12" Padding="14,6"
                                                                                HorizontalAlignment="Center" Margin="0,0,0,10">
                                                                            <TextBlock Foreground="{Binding LatencyColor, Mode=OneWay}"
                                                                                       FontSize="14" FontWeight="Bold" TextAlignment="Center">
                                                                                <Run Text="{Binding AvgLatency, Mode=OneWay, StringFormat={}{0}ms}"/>
                                                                            </TextBlock>
                                                                        </Border>

                                                                        <!-- Health Icon - Larger for better visibility -->
                                                                        <TextBlock Text="{Binding HealthIcon, Mode=OneWay}"
                                                                                   FontSize="24" TextAlignment="Center"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>

                                        <!-- TAG: #DC_HEALTH #FAVORITES #EXPAND_COLLAPSE -->
                                        <!-- Expand/Collapse Button -->
                                        <Button x:Name="BtnToggleDCHealth" Click="BtnToggleDCHealth_Click"
                                                Background="Transparent" BorderThickness="0" Padding="6,4"
                                                Margin="0,8,0,0" HorizontalAlignment="Center" Cursor="Hand"
                                                Visibility="Collapsed"
                                                ToolTip="Show more / Show less domain controllers">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="TxtToggleDCHealth" Text="▼ SHOW MORE"
                                                           Foreground="{StaticResource AccentOrangeBrush}"
                                                           FontSize="9" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Refresh Button -->
                                        <Button x:Name="BtnRefreshDCHealth" Content="🔄 REFRESH DCs"
                                                Click="BtnRefreshDCHealth_Click"
                                                Background="#FF2A2A2A" Foreground="White" BorderBrush="#FF444444"
                                                BorderThickness="1" Padding="8,6" FontSize="9" FontWeight="SemiBold"
                                                Margin="0,10,0,0" HorizontalAlignment="Stretch"
                                                ToolTip="Refresh domain controller list and health status. Checks connectivity and latency to all detected DCs in the domain."/>
                                    </StackPanel>
                                </Border>

                                <!-- Critical Alerts -->
                                <Border Grid.Column="2" Background="#FF1E1E1E" BorderBrush="#FF3C3C3C"
                                        BorderThickness="1" CornerRadius="8" Padding="20" Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="⚠️ CRITICAL ALERTS" Foreground="#FFFF6B6B"
                                                   FontSize="12" FontWeight="Bold" Margin="0,0,0,16"/>

                                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="ListCriticalAlerts">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#FF2A2A2A" BorderBrush="#FFFF6B6B" BorderThickness="1"
                                                                CornerRadius="4" Padding="12,8" Margin="0,0,0,8">
                                                            <TextBlock Text="{Binding}" Foreground="White" FontSize="10"
                                                                       TextWrapping="Wrap"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <TextBlock x:Name="TxtNoAlerts" Text="✅ No critical alerts" Foreground="LimeGreen"
                                                   FontSize="11" FontStyle="Italic" Visibility="Collapsed"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Recent Activity / Top Issues -->
                            <Border Grid.Row="3" Background="#FF1E1E1E" BorderBrush="#FF3C3C3C"
                                    BorderThickness="1" CornerRadius="8" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="🔝 TOP COMPUTERS BY UPTIME" Foreground="{StaticResource AccentOrangeBrush}"
                                               FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>

                                    <DataGrid x:Name="GridTopComputers" AutoGenerateColumns="False" IsReadOnly="True"
                                              Background="#FF1A1A1A" Foreground="White" BorderThickness="0"
                                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#FF2A2A2A"
                                              HeadersVisibility="Column" MaxHeight="250">

                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#FF2A2A2A"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentOrangeBrush}"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="FontSize" Value="10"/>
                                                <Setter Property="Padding" Value="10,8"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>

                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Rank" Binding="{Binding Rank}" Width="50"/>
                                            <DataGridTextColumn Header="Computer" Binding="{Binding Hostname}" Width="*" MinWidth="150"/>
                                            <DataGridTextColumn Header="OS" Binding="{Binding OS}" Width="120"/>
                                            <DataGridTextColumn Header="Uptime" Binding="{Binding Uptime}" Width="150"/>
                                            <DataGridTextColumn Header="Last Boot" Binding="{Binding LastBoot}" Width="130"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- ══════════════════════════════ -->
                <!-- TAB 1: SINGLE SYSTEM INSPECTOR -->
                <!-- ══════════════════════════════ -->
                <TabItem Header="SINGLE SYSTEM INSPECTOR">
                    <Grid Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.8*" MinWidth="450"/>
                            <ColumnDefinition Width="*" MinWidth="280" MaxWidth="320"/>
                            <ColumnDefinition Width="1.3*" MinWidth="380"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT COLUMN: SCAN RESULTS -->
                        <Border Grid.Column="0" Background="{StaticResource BgDarkestBrush}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,15">
                                <StackPanel>
                                    <!-- Status Header - TAG: #STATUS_INDICATORS #ANIMATION -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <Ellipse x:Name="StatusDot" Width="14" Height="14"
                                                 Fill="{StaticResource TextMutedBrush}" Margin="0,0,10,0">
                                            <Ellipse.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard x:Name="PulseAnimation">
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                           From="1.0" To="0.3" Duration="0:0:1"
                                                                           AutoReverse="True"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                        <TextBlock x:Name="TxtTargetName" Text="NO TARGET"
                                                   Foreground="White" FontSize="22" FontWeight="Bold"/>
                                        <TextBlock x:Name="TxtStatus" Text="" Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="14" VerticalAlignment="Bottom" Margin="12,0,0,2"/>
                                        <ProgressBar x:Name="StatusProgressBar" Width="100" Height="3"
                                                    IsIndeterminate="True" Margin="10,0,0,0"
                                                    VerticalAlignment="Center" Visibility="Collapsed"
                                                    Foreground="#FFFF8533" Background="#1A1A1A"/>
                                    </StackPanel>

                                    <!-- IDENTITY & ACCESS -->
                                    <TextBlock Text="IDENTITY &amp; ACCESS" Foreground="#FFFF6B00"
                                               FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <TextBlock Text="Current User:" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                                    <TextBlock x:Name="TxtUser" Text="--" Foreground="{StaticResource AccentCyanBrush}"
                                               FontSize="14" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Service Tag / Serial:" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                                    <TextBlock x:Name="TxtServiceTag" Text="--" Foreground="#FFFF4444"
                                               FontSize="14" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <!-- TAG: #TOOLTIPS #UTILITIES -->
                                    <Button x:Name="BtnWarranty" Content="Check Warranty Status"
                                            Style="{StaticResource BtnPrimary}" Click="BtnWarranty_Click"
                                            HorizontalAlignment="Left" Padding="20,6" FontSize="11"
                                            IsEnabled="False" Margin="0,0,0,16"
                                            ToolTip="Checks hardware warranty status using service tag/serial number. Queries manufacturer APIs (Dell, HP, Lenovo) for warranty coverage dates, support tier, and service entitlements. Requires valid service tag and target computer to be scanned first."/>

                                    <!-- NETWORK CONFIG -->
                                    <TextBlock Text="NETWORK CONFIGURATION" Foreground="{StaticResource AccentGreenBrush}"
                                               FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="IP Address:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                        <TextBlock x:Name="TxtIP1" Grid.Row="0" Grid.Column="1" Text="--" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="MAC Address:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3,0,0"/>
                                        <TextBlock x:Name="TxtMAC" Grid.Row="1" Grid.Column="1" Text="--" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,3,0,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="DNS Servers:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3,0,0"/>
                                        <TextBlock x:Name="TxtDNS" Grid.Row="2" Grid.Column="1" Text="--" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                    </Grid>

                                    <!-- HARDWARE & OS -->
                                    <TextBlock Text="HARDWARE &amp; OS" Foreground="#FFFF6B00"
                                               FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="TxtModel" Text="Model: --" Foreground="White" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtBattery" Text="Power: --" Foreground="{StaticResource AccentGreenBrush}" FontSize="12"/>
                                    <TextBlock x:Name="TxtCores" Text="Core Logic: --" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                    <TextBlock x:Name="TxtCPU" Text="--" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                    <TextBlock x:Name="TxtRAM" Text="RAM: --" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,4,0,6"/>
                                    <TextBlock x:Name="TxtOS" Text="--" Foreground="White" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtUptime" Text="Uptime: --" Foreground="{StaticResource AccentGreenBrush}" FontSize="12" Margin="0,0,0,16"/>

                                    <!-- LOCAL STORAGE -->
                                    <TextBlock Text="LOCAL STORAGE" Foreground="#FFFF6B00"
                                               FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <StackPanel x:Name="StkDrives">
                                        <TextBlock Text="No data — scan a target to populate." Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- CENTER COLUMN: CONTROL PANEL -->
                        <Border Grid.Column="1" Background="#FF1E1E1E" BorderBrush="#FF3C3C3C" BorderThickness="1,0,1,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,14">
                                <StackPanel>
                                    <!-- TARGET SYSTEM SECTION -->
                                    <Border Background="#FF252525" CornerRadius="6" Padding="14" Margin="0,0,0,14"
                                            BorderThickness="1">
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF8533" Offset="0"/>
                                                <GradientStop Color="#A1A1AA" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <StackPanel>
                                            <TextBlock Text="🎯 TARGET SYSTEM" Foreground="{StaticResource AccentOrangeBrush}"
                                                       FontSize="11" FontWeight="Bold" Margin="0,0,0,12"
                                                       HorizontalAlignment="Center"/>

                                            <TextBlock Text="Hostname or IP Address:" Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="9" Margin="0,0,0,4"/>

                                            <ComboBox x:Name="ComboTarget" IsEditable="True"
                                                      Margin="0,0,0,10" KeyDown="ComboTarget_KeyDown"
                                                      SelectionChanged="ComboTarget_SelectionChanged"
                                                      Foreground="White" FontWeight="SemiBold" FontSize="11"
                                                      ToolTip="Enter hostname or IP address"
                                                      Background="#FF2A2A2A" BorderBrush="#FF555555"
                                                      Height="32"/>

                                            <!-- TAG: #TOOLTIPS #ACTIONS -->
                                            <Button x:Name="BtnManualScan" Content="🔍 SCAN SYSTEM"
                                                    Click="BtnScan_Click" Cursor="Hand"
                                                    Margin="0,0,0,0" Height="38" FontSize="12" FontWeight="Bold"
                                                    Foreground="White" BorderThickness="0"
                                                    ToolTip="Scans the specified computer using WMI/CIM queries. Retrieves hardware, software, network, and system information. Results are displayed in tabs below and automatically saved to database. Requires valid hostname or IP address. (F5)">
                                                <Button.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#FF8533" Offset="0"/>
                                                        <GradientStop Color="#CC6B29" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Button.Background>
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                        VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Opacity" Value="0.9"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsPressed" Value="True">
                                                                            <Setter Property="Opacity" Value="0.8"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                    <!-- DEPLOYMENT CENTER SECTION -->
                                    <Border Background="#FF252525" CornerRadius="6" Padding="14" Margin="0,0,0,14"
                                            BorderThickness="1" BorderBrush="#FF8B0000" x:Name="PanelDeployment">
                                        <StackPanel>
                                            <TextBlock Text="🚀 DEPLOYMENT CENTER" Foreground="#FFFF6B6B"
                                                       FontSize="11" FontWeight="Bold" Margin="0,0,0,12"
                                                       HorizontalAlignment="Center"/>

                                            <TextBlock Text="Update Package:" Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="9" Margin="0,0,0,4"/>

                                            <ComboBox x:Name="ComboScripts" Margin="0,0,0,10"
                                                      Foreground="White" FontWeight="SemiBold" FontSize="10"
                                                      Background="#FF2A2A2A" BorderBrush="#FF555555" Height="30">
                                                <ComboBoxItem Content="General Update (Drivers + Firmware + Patches)" IsSelected="True"/>
                                                <ComboBoxItem Content="Feature Update (Major OS In-Place Upgrade)"/>
                                            </ComboBox>

                                            <!-- TAG: #TOOLTIPS #DEPLOYMENT -->
                                            <Button x:Name="BtnPush" Content="⚡ PUSH UPDATE PAYLOAD"
                                                    Style="{StaticResource BtnDanger}" Click="BtnPush_Click"
                                                    Height="36" FontSize="11" FontWeight="Bold"
                                                    Margin="0,0,0,8" IsEnabled="False"
                                                    ToolTip="Pushes selected update package (General Update or Feature Update) to the target computer via PowerShell Remoting. Requires WinRM enabled and admin credentials. Script runs with configured deployment paths and ISO settings. Disabled until target is scanned and online."/>

                                            <Button Content="📤 SYNC SCRIPTS TO SERVER" Style="{StaticResource BtnGhost}"
                                                    Click="BtnSync_Click" Height="30" FontSize="10"
                                                    Margin="0,0,0,6"
                                                    ToolTip="Synchronizes PowerShell deployment scripts to configured server share for RMM distribution. Scripts are uploaded with current deployment configuration (log paths, ISO paths, hostname patterns). Useful for ManageEngine or GPO-based deployments."/>

                                            <Button Content="📥 DOWNLOAD SCRIPTS (Latest)" Style="{StaticResource BtnGhost}"
                                                    Click="BtnDownloadScripts_Click" Height="30" FontSize="10"
                                                    ToolTip="Downloads latest PowerShell update scripts (GeneralUpdate.ps1 and FeatureUpdate.ps1) from embedded resources to your Downloads folder. Scripts include current deployment settings and theme colors. Opens Explorer when complete."/>
                                        </StackPanel>
                                    </Border>

                                    <!-- PRE-FLIGHT SECTION -->
                                    <Border Background="#FF252525" CornerRadius="6" Padding="14"
                                            BorderThickness="1" BorderBrush="#FF555555" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="&#x2708; PRE-FLIGHT TOOLS" Foreground="#FF6BC5FF"
                                                       FontSize="11" FontWeight="Bold" Margin="0,0,0,4"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="9" Margin="0,0,0,10"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="Deploy BEFORE Feature Update. Reboots machines with pending updates so FeatureUpdate.ps1 runs clean. ME sees full visibility for both steps."/>
                                            <!-- TAG: #TOOLTIPS #DEPLOYMENT -->
                                            <Button Content="📥 DOWNLOAD PREFLIGHT REBOOT CHECK"
                                                    Style="{StaticResource BtnGhost}"
                                                    Click="BtnDownloadPreflightScript_Click" Height="30" FontSize="10"
                                                    ToolTip="Downloads PreflightReboot.ps1 - deploy this via ManageEngine BEFORE FeatureUpdate.ps1. Checks for pending reboots; if found, reboots the machine (exit 0) so ME marks it complete. Push FeatureUpdate.ps1 after machines are back online."/>
                                        </StackPanel>
                                    </Border>

                                    <!-- UTILITIES SECTION -->
                                    <Border Background="#FF252525" CornerRadius="6" Padding="14"
                                            BorderThickness="1" BorderBrush="#FF555555">
                                        <StackPanel>
                                            <!-- TAG: #TOOLTIPS #UTILITIES -->
                                            <TextBlock Text="🔧 UTILITIES" Foreground="{StaticResource AccentOrangeBrush}"
                                                       FontSize="11" FontWeight="Bold" Margin="0,0,0,12"
                                                       HorizontalAlignment="Center"/>

                                            <Button Content="⚡ WAKE ON LAN" Style="{StaticResource BtnGhost}"
                                                    Click="BtnWOL_Click" Height="32" FontSize="10"
                                                    Margin="0,0,0,6"
                                                    ToolTip="Sends Wake-on-LAN magic packet to target computer's MAC address. Requires computer to support WoL and be configured in BIOS. Computer must be on same subnet or have WoL forwarding configured on router. Useful for powering on remote systems."/>

                                            <Button Content="🔌 ENABLE WinRM" Style="{StaticResource BtnGhost}"
                                                    Click="Tool_EnableWinRM_Click" Height="32" FontSize="10"
                                                    Margin="0,0,0,6"
                                                    ToolTip="Remotely enables Windows Remote Management (WinRM) service via WMI. Required for PowerShell Remoting and deployment scripts. Creates firewall rules and starts service. Requires admin credentials and WMI access to target computer."/>

                                            <Button x:Name="BtnKillFirewall" Content="🔥 KILL FIREWALL (WMI)"
                                                    Style="{StaticResource BtnWarning}"
                                                    Click="Tool_Firewall_Click" Height="32" FontSize="10"
                                                    ToolTip="Disables all Windows Firewall profiles (Domain, Private, Public) remotely via WMI. WARNING: This reduces system security and should only be used temporarily for troubleshooting network connectivity issues. Requires admin credentials and WMI access."/>
                                        </StackPanel>
                                    </Border>

                                    <!-- TAG: #RMM_INTEGRATION #REMOTE_CONTROL #VERSION_7 #PHASE_3 -->
                                    <!-- RMM QUICK LAUNCH SECTION - Moved from right column to left for cleaner UI -->
                                    <Border Background="#FF252525" CornerRadius="6" Padding="14"
                                            BorderThickness="1" BorderBrush="#FF555555" Margin="0,14,0,0">
                                        <StackPanel>
                                            <TextBlock Text="🖥️ RMM QUICK LAUNCH" Foreground="{StaticResource AccentOrangeBrush}"
                                                       FontSize="11" FontWeight="Bold" Margin="0,0,0,12"
                                                       HorizontalAlignment="Center"/>

                                            <!-- Enabled RMM tools displayed as quick-launch buttons -->
                                            <ItemsControl x:Name="RmmQuickLaunchButtons">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding DisplayName}"
                                                                Tag="{Binding ToolType}"
                                                                Style="{StaticResource BtnGhost}"
                                                                Click="RmmQuickLaunch_Click"
                                                                Height="32" FontSize="10"
                                                                Margin="0,0,0,6"
                                                                ToolTip="{Binding ToolTip}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Message when no RMM tools enabled -->
                                            <TextBlock x:Name="TxtNoRmmTools"
                                                       Text="⚠️ No RMM tools enabled."
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="9" TextAlignment="Center"
                                                       Margin="0,4,0,8"
                                                       Visibility="Collapsed"/>

                                            <!-- TAG: #TOOLTIPS #RMM_TOOLS -->
                                            <!-- Configure button -->
                                            <Button Content="⚙️  CONFIGURE RMM TOOLS"
                                                    Style="{StaticResource BtnGhost}"
                                                    Click="BtnConfigureRmm_Click"
                                                    Height="28" FontSize="9"
                                                    ToolTip="Opens RMM Tools configuration window. Enable/disable remote management tools (TeamViewer, ScreenConnect, ManageEngine, etc.) and configure connection settings. Enabled tools appear as quick-launch buttons above for fast access."/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- RIGHT COLUMN: REMOTE MANAGEMENT TOOLS -->
                        <Border Grid.Column="2" Background="{StaticResource BgDarkBrush}"
                                BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="0,0,0,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18,16,22,16">
                                <StackPanel x:Name="GridTools" IsEnabled="False">
                                    <TextBlock Text="REMOTE MANAGEMENT TOOLS" Foreground="White"
                                               FontSize="13" FontWeight="Bold" Margin="0,0,0,14"
                                               HorizontalAlignment="Center"/>

                                    <!-- TAG: #TOOLTIPS #SYSTEM_TOOLS -->
                                    <!-- Collapsible tool category groups -->

                                    <!-- FILE & SOFTWARE -->
                                    <Expander IsExpanded="True" Margin="0,0,0,6">
                                        <Expander.Header>
                                            <TextBlock Text="FILE &amp; SOFTWARE" Foreground="{StaticResource AccentOrangeBrush}"
                                                       FontSize="10" FontWeight="Bold"/>
                                        </Expander.Header>
                                        <UniformGrid Columns="2" Margin="0,6,0,0">
                                            <Button Content="📁  BROWSE C$ SHARE" Style="{StaticResource BtnTool}"
                                                    Click="Tool_Browse_Click" Margin="0,0,4,5"
                                                    ToolTip="Opens Windows Explorer to the target computer's C$ administrative share. Provides direct file system access for copying files, viewing logs, or managing configurations. Requires admin credentials and File Sharing enabled on target."/>
                                            <Button Content="📦  SOFTWARE INVENTORY" Style="{StaticResource BtnTool}"
                                                    Click="Tool_Soft_Click" Margin="4,0,0,5"
                                                    ToolTip="Displays complete list of installed software on target computer. Queries registry (Uninstall keys) and Windows Installer database. Shows application names, versions, publishers, and install dates. Export to CSV for reporting."/>
                                            <Button Content="📋  INSTALLED HOTFIXES" Style="{StaticResource BtnTool}"
                                                    Click="Tool_Hotfix_Click" Margin="0,0,4,5"
                                                    ToolTip="Lists all installed Windows Updates and hotfixes on target computer. Shows KB numbers, install dates, and update descriptions. Useful for verifying patch compliance and troubleshooting update-related issues."/>
                                            <Button Content="🗑  DISK CLEANUP" Style="{StaticResource BtnTool}"
                                                    Click="Tool_DiskCleanup_Click" Margin="4,0,0,5"
                                                    ToolTip="Launches Disk Cleanup wizard on target computer to free up disk space. Removes temporary files, Windows Update cleanup, recycle bin contents, and other safe-to-delete items. Runs interactively on target system."/>
                                        </UniformGrid>
                                    </Expander>

                                    <!-- PROCESS & SERVICE MANAGEMENT -->
                                    <Expander IsExpanded="True" Margin="0,0,0,6">
                                        <Expander.Header>
                                            <TextBlock Text="PROCESS &amp; SERVICE MANAGEMENT" Foreground="{StaticResource AccentOrangeBrush}"
                                                       FontSize="10" FontWeight="Bold"/>
                                        </Expander.Header>
                                        <UniformGrid Columns="2" Margin="0,6,0,0">
                                            <Button Content="⚙  PROCESS MANAGER" Style="{StaticResource BtnTool}"
                                                    Click="Tool_Proc_Click" Margin="0,0,4,5"
                                                    ToolTip="Opens Task Manager on target computer to view and manage running processes. Kill unresponsive applications, check CPU/memory usage, and monitor system performance. Launches remotely via WMI or PowerShell Remoting."/>
                                            <Button Content="🔧  SERVICES MANAGER" Style="{StaticResource BtnTool}"
                                                    Click="Tool_Svc_Click" Margin="4,0,0,5"
                                                    ToolTip="Opens Services management console (services.msc) for target computer. Start, stop, restart, or configure Windows services remotely. View service status, startup type, and dependencies. Requires admin credentials."/>
                                            <Button Content="📊  STARTUP PROGRAMS" Style="{StaticResource BtnTool}"
                                                    Click="Tool_Startup_Click" Margin="0,0,4,5"
                                                    ToolTip="Displays programs configured to run at system startup on target computer. Shows startup location (Registry, Startup folder, Task Scheduler), program name, and path. Disable unwanted startup items to improve boot time and performance."/>
                                            <Button Content="📝  SCHEDULED TASKS" Style="{StaticResource BtnTool}"
                                                    Click="Tool_SchedTask_Click" Margin="4,0,0,5"
                                                    ToolTip="Opens Task Scheduler for target computer. View, create, modify, or delete scheduled tasks. Useful for managing automated scripts, maintenance jobs, and Windows Update schedules. Full remote task management capabilities."/>
                                        </UniformGrid>
                                    </Expander>

                                    <!-- DIAGNOSTICS & REPAIR -->
                                    <Expander IsExpanded="True" Margin="0,0,0,6">
                                        <Expander.Header>
                                            <TextBlock Text="DIAGNOSTICS &amp; REPAIR" Foreground="{StaticResource AccentOrangeBrush}"
                                                       FontSize="10" FontWeight="Bold"/>
                                        </Expander.Header>
                                        <UniformGrid Columns="2" Margin="0,6,0,0">
                                            <Button Content="📄  EVENT LOGS (SYSTEM)" Style="{StaticResource BtnTool}"
                                                    Click="Tool_Evt_Click" Margin="0,0,4,5"
                                                    ToolTip="Opens Event Viewer to view System event logs on target computer. Review errors, warnings, and information events for troubleshooting boot issues, driver problems, and system crashes. Filter by event ID or source."/>
                                            <Button Content="🛡  OS REPAIR (DISM+SFC)" Style="{StaticResource BtnTool}"
                                                    Click="Tool_Repair_Click" Margin="4,0,0,5"
                                                    ToolTip="Runs Windows system file repair tools (DISM and SFC) on target computer. Repairs corrupted system files, Windows component store issues, and OS integrity problems. Requires elevation and may take 15-30 minutes. System restore point recommended."/>
                                            <Button Content="🔍  DEFENDER QUICK SCAN" Style="{StaticResource BtnTool}"
                                                    Click="Tool_DefenderScan_Click" Margin="0,0,4,5"
                                                    ToolTip="Initiates Windows Defender Quick Scan on target computer. Scans common malware locations (Downloads, Temp, Startup folders). Faster than full scan. Results available in Windows Security. Requires Defender enabled and up-to-date."/>
                                            <Button Content="🌐  NETWORK DIAGNOSTICS" Style="{StaticResource BtnTool}"
                                                    Click="Tool_NetDiag_Click" Margin="4,0,0,5"
                                                    ToolTip="Runs comprehensive network diagnostics on target computer including ping tests, trace routes, DNS resolution, and connectivity checks. Useful for troubleshooting internet access, VPN issues, and network performance problems."/>
                                            <Button Content="🔄  RENEW IP ADDRESS" Style="{StaticResource BtnTool}"
                                                    Click="Tool_RenewIP_Click" Margin="0,0,4,5"
                                                    ToolTip="Releases and renews DHCP IP address on target computer (ipconfig /release + /renew). Fixes IP conflicts, stale DHCP leases, and network connectivity issues. Network connection briefly interrupted during renewal."/>
                                        </UniformGrid>
                                    </Expander>

                                    <!-- REMOTE ACCESS -->
                                    <Expander IsExpanded="True" Margin="0,0,0,6">
                                        <Expander.Header>
                                            <TextBlock Text="REMOTE ACCESS" Foreground="{StaticResource AccentOrangeBrush}"
                                                       FontSize="10" FontWeight="Bold"/>
                                        </Expander.Header>
                                        <UniformGrid Columns="2" Margin="0,6,0,0">
                                            <Button Content="🖥  REMOTE DESKTOP" Style="{StaticResource BtnTool}"
                                                    Click="Tool_RDP_Click" Margin="0,0,4,5"
                                                    ToolTip="Launches Remote Desktop Connection (mstsc.exe) to target computer. Provides full interactive desktop access. Requires RDP enabled on target, network access to port 3389, and valid user credentials. Network Level Authentication recommended."/>
                                            <Button Content="💻  REMOTE ASSIST" Style="{StaticResource BtnTool}"
                                                    Click="Tool_RemoteAssist_Click" Margin="4,0,0,5"
                                                    ToolTip="Opens Windows Remote Assistance connection to target computer. Allows viewing and optionally controlling user's desktop with their permission. Useful for user support and troubleshooting. Requires user acceptance to establish connection."/>
                                            <Button Content="📡  REMOTE REGISTRY" Style="{StaticResource BtnTool}"
                                                    Click="Tool_RemoteReg_Click" Margin="0,0,4,5"
                                                    ToolTip="Opens Registry Editor connected to target computer's registry. Full read/write access to HKLM and HKU hives. Modify system settings, troubleshoot configuration issues, and manage registry keys remotely. CAUTION: Incorrect changes can break system."/>
                                            <Button Content="🔌  REMOTE CMD" Style="{StaticResource BtnTool}"
                                                    Click="Tool_PsExec_Click" Margin="4,0,0,5"
                                                    ToolTip="Opens command prompt on target computer using PsExec (if available) or PowerShell Remoting. Execute commands remotely with SYSTEM or user context. Requires PsExec in PATH or PowerShell Remoting enabled. Full command-line access."/>
                                        </UniformGrid>
                                    </Expander>

                                    <!-- SYSTEM ACTIONS -->
                                    <Expander IsExpanded="True" Margin="0,0,0,6">
                                        <Expander.Header>
                                            <TextBlock Text="SYSTEM ACTIONS" Foreground="{StaticResource AccentOrangeBrush}"
                                                       FontSize="10" FontWeight="Bold"/>
                                        </Expander.Header>
                                        <StackPanel Margin="0,6,0,0">
                                            <UniformGrid Columns="2" Margin="0,0,0,8">
                                                <Button x:Name="BtnGP" Content="⚡  FORCE GPUPDATE"
                                                        Style="{StaticResource BtnTool}" Click="Tool_GP_Click"
                                                        IsEnabled="False" Margin="0,0,4,5"
                                                        ToolTip="Forces immediate Group Policy update on target computer (gpupdate /force). Applies latest GPO settings without waiting for background refresh interval. Useful after policy changes. Takes 1-2 minutes. May require reboot for some policies."/>
                                                <Button Content="🔄  FLUSH DNS" Style="{StaticResource BtnTool}"
                                                        Click="Tool_FlushDNS_Click" Margin="4,0,0,5"
                                                        ToolTip="Clears DNS resolver cache on target computer (ipconfig /flushdns). Fixes DNS resolution issues, stale cached entries, and website access problems after DNS changes. Takes effect immediately without reboot."/>
                                            </UniformGrid>

                                            <Button x:Name="BtnReboot" Content="⚠  REBOOT SYSTEM"
                                                    Style="{StaticResource BtnDanger}" Click="Tool_Reboot_Click"
                                                    IsEnabled="False" Margin="0,4,0,0" Padding="6,12"
                                                    FontSize="13" FontWeight="Bold"
                                                    ToolTip="Immediately reboots the target computer. WARNING: All unsaved work will be lost. Users will be logged off without warning. Use for applying critical updates, completing installations, or troubleshooting. Requires admin credentials and WMI access."/>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ══════════════════════════════ -->
                <!-- TAB 2: AD FLEET INVENTORY      -->
                <!-- ══════════════════════════════ -->
                <TabItem Header="AD FLEET INVENTORY">
                    <DockPanel Margin="15">
                        <!-- DC Selection Section -->
                        <Border DockPanel.Dock="Top" Background="#FF1E1E1E" BorderBrush="#FF3C3C3C"
                                BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <!-- LEFT: DC Controller Selection -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🌐 DOMAIN CONTROLLER"
                                               Foreground="{StaticResource AccentOrangeBrush}"
                                               FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>

                                    <!-- DC Dropdown (Same style as DOMAIN & DIRECTORY tab) -->
                                    <Border Background="#2D2D2D" CornerRadius="6" BorderThickness="1" Margin="0,0,0,10">
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF8533" Offset="0"/>
                                                <GradientStop Color="#A1A1AA" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <ComboBox x:Name="ComboDCFleet"
                                                  Foreground="White" FontWeight="SemiBold" FontSize="12"
                                                  Background="Transparent" BorderThickness="0"
                                                  Padding="10,8"
                                                  SelectionChanged="ComboDCFleet_SelectionChanged">
                                            <ComboBox.Resources>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="Background" Value="#1A1A1A"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="Padding" Value="10,6"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ComboBoxItem">
                                                                <Border Name="Border" Background="{TemplateBinding Background}"
                                                                        Padding="{TemplateBinding Padding}" CornerRadius="3" Margin="2">
                                                                    <ContentPresenter/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsHighlighted" Value="True">
                                                                        <Setter TargetName="Border" Property="Background">
                                                                            <Setter.Value>
                                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                                    <GradientStop Color="#FF8533" Offset="0"/>
                                                                                    <GradientStop Color="#A1A1AA" Offset="1"/>
                                                                                </LinearGradientBrush>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter TargetName="Border" Property="Background" Value="#FF8533"/>
                                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                    </Border>

                                    <!-- TAG: #TOOLTIPS #ACTIONS -->
                                    <Button x:Name="BtnRefreshDCsFleet" Click="BtnRefreshDCsFleet_Click"
                                            Foreground="White" FontSize="10" FontWeight="SemiBold"
                                            Margin="0,0,0,0" Padding="0" BorderThickness="0" Cursor="Hand"
                                            ToolTip="Refreshes list of available domain controllers in your Active Directory environment. Queries AD for all DCs including PDC emulator, GCs, and read-only DCs. Useful when DCs are added/removed or experiencing connectivity issues. (F5)">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" CornerRadius="4" Padding="10,7">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#FF8533" Offset="0"/>
                                                            <GradientStop Color="#CC6B29" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="🔄" FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock Text="REFRESH CONTROLLERS"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <!-- RIGHT: Quick Actions -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="⚡ QUICK ACTIONS"
                                               Foreground="{StaticResource AccentOrangeBrush}"
                                               FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>

                                    <!-- AD Query Method Selector -->
                                    <TextBlock Text="AD Query Method:" Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="9" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="ComboADQueryMethod" Foreground="White" Background="#FF2A2A2A"
                                              BorderBrush="#FF444444" FontSize="10" Padding="8,4" Margin="0,0,0,8"
                                              SelectionChanged="ComboADQueryMethod_SelectionChanged">
                                        <ComboBoxItem Content="DirectorySearcher (Fast)" Tag="DirectorySearcher" IsSelected="True"/>
                                        <ComboBoxItem Content="ActiveDirectoryManager (Detailed)" Tag="ActiveDirectoryManager"/>
                                    </ComboBox>

                                    <!-- TAG: #TOOLTIPS #ACTIONS -->
                                    <Button x:Name="BtnLoadADObjects" Content="🌳 LOAD AD OBJECTS"
                                            Style="{StaticResource BtnPrimary}" Click="BtnLoadADObjects_Click"
                                            Padding="12,8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"
                                            ToolTip="Loads Active Directory hierarchical tree view showing Users, Groups, Organizational Units, and Computers in RSAT-style interface. Browse entire AD structure, view object properties, create/edit/delete AD objects. Uses selected query method (DirectorySearcher for speed, ActiveDirectoryManager for details)."/>

                                    <Button Grid.Column="3" Content="📊 EXPORT CSV" Style="{StaticResource BtnGhost}"
                                            Click="BtnExportInventory_Click" Padding="12,6" FontSize="10"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- AD Object Browser (RSAT ADUC-like interface) -->
                        <local:ADObjectBrowser x:Name="ADObjectBrowserControl" DockPanel.Dock="Top"
                                               Margin="0,0,0,15" Height="400" Visibility="Collapsed"/>

                        <!-- Toolbar -->
                        <Border DockPanel.Dock="Top" Margin="0,0,0,10">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- TAG: #TOOLTIPS #ACTIONS -->
                                    <Button x:Name="BtnScanFleet" Grid.Column="0" Content="🔍 SCAN DOMAIN (LEGACY)"
                                            Style="{StaticResource BtnGhost}" Click="BtnInvScan_Click"
                                            Padding="16,8" FontSize="11" FontWeight="Bold"
                                            ToolTip="Legacy fleet scanner that queries AD computers and performs flat-list WMI scan of entire domain. Shows progress bar with online/offline stats. NOTE: For modern tree-based browsing with OU structure, use 'LOAD AD OBJECTS' button instead. This method scans all computers sequentially."/>

                                    <TextBox x:Name="TxtInventorySearch" Grid.Column="1"
                                             Margin="10,0,10,0" TextChanged="TxtInventorySearch_TextChanged"
                                             Tag="Search by hostname, user, or OS..."/>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <!-- TAG: #AUTO_UPDATE_UI_ENGINE #VIEW_TOGGLE -->
                                        <Button x:Name="BtnToggleView" Content="📇 CARD VIEW"
                                                Style="{StaticResource BtnGhost}"
                                                Click="BtnToggleView_Click"
                                                Padding="10,6" FontSize="10" Margin="0,0,8,0"
                                                ToolTip="Toggle between grid view and card view layouts. Card view provides a visual card-based interface for easier scanning of computer information."/>
                                        <Button Content="SYNC TO DB" Style="{StaticResource BtnGhost}"
                                                Click="BtnSyncDB_Click" Padding="12,6" FontSize="10"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Progress Bar and Status -->
                                <Border x:Name="ScanProgressPanel" Visibility="Collapsed" Margin="0,10,0,0"
                                        Background="#FF1E1E1E" BorderBrush="{StaticResource BorderDimBrush}"
                                        BorderThickness="1" CornerRadius="4" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Animated Scanning Icon -->
                                        <TextBlock x:Name="ScanningIcon" Grid.Column="0" Text="🔄" FontSize="18"
                                                   VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock.RenderTransform>
                                                <RotateTransform x:Name="IconRotation" CenterX="9" CenterY="9"/>
                                            </TextBlock.RenderTransform>
                                        </TextBlock>

                                        <!-- Progress Bar - TAG: #STATUS_INDICATORS #THEME_COLORS #LOADING -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock x:Name="TxtScanStatus" Text="Scanning domain..."
                                                           Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock x:Name="TxtScanPercentage" Text="0%" HorizontalAlignment="Right"
                                                           Foreground="{StaticResource AccentCyanBrush}" FontSize="11" FontWeight="Bold"/>
                                            </Grid>
                                            <ProgressBar x:Name="ScanProgressBar" Height="8" Minimum="0" Maximum="100" Value="0"
                                                         Background="#FF2A2A2A" Foreground="{StaticResource AccentCyanBrush}"
                                                         BorderThickness="0"/>
                                            <Grid Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="TxtScanDetails" Grid.Column="0" Text="0 / 0 computers scanned"
                                                           Foreground="{StaticResource TextMutedBrush}" FontSize="9"/>
                                                <TextBlock x:Name="TxtScanTime" Grid.Column="1" Text="Elapsed: 0s | Est: --"
                                                           Foreground="{StaticResource TextMutedBrush}" FontSize="9"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Stats -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <Border Background="#FF006600" CornerRadius="3" Padding="6,3" Margin="0,0,4,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="✓" Foreground="LimeGreen" FontSize="10" Margin="0,0,4,0"/>
                                                    <TextBlock x:Name="TxtOnlineCount" Text="0" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#FF660000" CornerRadius="3" Padding="6,3">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="✗" Foreground="Red" FontSize="10" Margin="0,0,4,0"/>
                                                    <TextBlock x:Name="TxtOfflineCount" Text="0" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Filter Panel Temporarily Removed for Debugging -->


                        <!-- Fleet Grid Container - TAG: #AUTO_UPDATE_UI_ENGINE #VIEW_TOGGLE -->
                        <Grid x:Name="FleetViewContainer">
                            <!-- DataGrid View (Default) -->
                            <DataGrid x:Name="GridInventory" AutoGenerateColumns="False"
                                      IsReadOnly="True" SelectionChanged="GridInventory_SelectionChanged"
                                      Visibility="Visible">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}" Width="2*" MinWidth="120"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*" MinWidth="70"/>
                                <DataGridTextColumn Header="Current User" Binding="{Binding CurrentUser}" Width="2*" MinWidth="100"/>
                                <DataGridTextColumn Header="OS" Binding="{Binding DisplayOS}" Width="3*" MinWidth="100"/>

                                <!-- Windows Version with Color Coding -->
                                <DataGridTemplateColumn Header="Version" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding WindowsVersion}"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       FontSize="10">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <!-- Server Versions -->
                                                            <!-- Green for Server 2019/2022/2025 -->
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="Server2025">
                                                                <Setter Property="Foreground" Value="LimeGreen"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="Server2022">
                                                                <Setter Property="Foreground" Value="LimeGreen"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="Server2019">
                                                                <Setter Property="Foreground" Value="LimeGreen"/>
                                                            </DataTrigger>
                                                            <!-- Yellow for Server 2016 -->
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="Server2016">
                                                                <Setter Property="Foreground" Value="Yellow"/>
                                                            </DataTrigger>
                                                            <!-- Red for Server 2012 R2 or older -->
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="Server2012R2">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="Server2012">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="Server2008R2">
                                                                <Setter Property="Foreground" Value="DarkRed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="ServerLegacy">
                                                                <Setter Property="Foreground" Value="DarkRed"/>
                                                            </DataTrigger>

                                                            <!-- Desktop Windows Versions -->
                                                            <!-- Green for 25H2 or newer -->
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="25H2">
                                                                <Setter Property="Foreground" Value="LimeGreen"/>
                                                            </DataTrigger>
                                                            <!-- Yellow for 24H2 -->
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="24H2">
                                                                <Setter Property="Foreground" Value="Yellow"/>
                                                            </DataTrigger>
                                                            <!-- Red for 23H2 or older -->
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="23H2">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="22H2">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="21H2">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="21H1">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="20H2">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="2004">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="1909">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="1903">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                            <!-- Windows 7/8/8.1 -->
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="Win8.1">
                                                                <Setter Property="Foreground" Value="DarkRed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="Win8">
                                                                <Setter Property="Foreground" Value="DarkRed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="Win7">
                                                                <Setter Property="Foreground" Value="DarkRed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WindowsVersion}" Value="Legacy">
                                                                <Setter Property="Foreground" Value="DarkRed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Chassis" Binding="{Binding Chassis}" Width="80"/>
                                <DataGridTextColumn Header="BitLocker" Binding="{Binding BitLockerStatus}" Width="80"/>
                            </DataGrid.Columns>
                            <DataGrid.ContextMenu>
                                <ContextMenu x:Name="GridInventoryContextMenu" Opened="GridInventoryContextMenu_Opened">
                                    <!-- Copy Row - Always at top for easy access -->
                                    <MenuItem Header="📋 Copy Row" Click="Ctx_CopyRow_Click" FontWeight="Bold"/>
                                    <Separator/>

                                    <!-- Quick Actions -->
                                    <MenuItem Header="🔍 Inspect (Deep Scan)" Click="Ctx_Inspect_Click"/>
                                    <MenuItem Header="🔄 Refresh Node" Click="Ctx_RefreshNode_Click"/>
                                    <MenuItem Header="📌 Pin Device" Click="Ctx_PinDevice_Click" FontWeight="SemiBold" Foreground="#FFFF8533"/>

                                    <!-- TAG: #VERSION_7 #BOOKMARKS - Favorites/Bookmarks -->
                                    <MenuItem Header="⭐ Add to Favorites" x:Name="CtxAddFavorite" Click="Ctx_AddToFavorites_Click" FontWeight="SemiBold" Foreground="LimeGreen"/>
                                    <MenuItem Header="💔 Remove from Favorites" x:Name="CtxRemoveFavorite" Click="Ctx_RemoveFromFavorites_Click" Visibility="Collapsed"/>
                                    <Separator/>

                                    <!-- Remote Management Tools (Admin Only) -->
                                    <MenuItem Header="🖥 Remote Desktop" Click="Ctx_RDP_Click" x:Name="CtxRDP"/>
                                    <MenuItem Header="⚙ Process Manager" Click="Ctx_ProcessManager_Click" x:Name="CtxProcess"/>
                                    <MenuItem Header="🔧 Services Manager" Click="Ctx_ServicesManager_Click" x:Name="CtxServices"/>
                                    <MenuItem Header="📁 Browse C$ Share" Click="Ctx_BrowseShare_Click" x:Name="CtxBrowse"/>
                                    <MenuItem Header="📄 Event Logs" Click="Ctx_EventLogs_Click" x:Name="CtxEvents"/>

                                    <!-- TAG: #RMM_INTEGRATION #VERSION_7 -->
                                    <MenuItem Header="🖥️ Connect with RMM Tool" x:Name="MenuRemoteConnect">
                                        <!-- Dynamic submenu populated at runtime -->
                                    </MenuItem>

                                    <!-- TAG: #VERSION_7.1 #REMEDIATION #AUTOMATION -->
                                    <MenuItem Header="🔧 Quick Fix" x:Name="MenuQuickFix" FontWeight="SemiBold" Foreground="#FFFFAA00">
                                        <MenuItem Header="🔄 Restart Windows Update" Click="Ctx_FixWindowsUpdate_Click" ToolTip="Restart Windows Update service and clear cache"/>
                                        <MenuItem Header="🌐 Clear DNS Cache" Click="Ctx_FixDNS_Click" ToolTip="Flush DNS resolver cache (ipconfig /flushdns)"/>
                                        <MenuItem Header="🖨️ Restart Print Spooler" Click="Ctx_FixPrintSpooler_Click" ToolTip="Restart Print Spooler service"/>
                                        <MenuItem Header="⚡ Enable WinRM" Click="Ctx_FixWinRM_Click" ToolTip="Enable WinRM for remote management"/>
                                        <MenuItem Header="🕐 Fix Time Sync" Click="Ctx_FixTimeSync_Click" ToolTip="Synchronize time with domain controller"/>
                                        <MenuItem Header="🗑️ Clear Event Logs" Click="Ctx_FixEventLogs_Click" ToolTip="Clear Application, System, and Security logs"/>
                                    </MenuItem>
                                    <MenuItem Header="📜 Run Custom Script" Click="Ctx_RunScript_Click" FontWeight="SemiBold" Foreground="#FF00BFFF" ToolTip="Execute PowerShell scripts on selected computers"/>
                                    <MenuItem Header="🏷️ Tags" x:Name="MenuTags" FontWeight="SemiBold" Foreground="#FFFFAA00">
                                        <MenuItem Header="➕ Add Tag" x:Name="MenuAddTag"/>
                                        <MenuItem Header="➖ Remove Tag" x:Name="MenuRemoveTag"/>
                                        <Separator/>
                                        <MenuItem Header="🔧 Manage Tags..." Click="Ctx_ManageTags_Click"/>
                                    </MenuItem>
                                    <MenuItem Header="🔄 Windows Update" x:Name="MenuWindowsUpdate" FontWeight="SemiBold" Foreground="#FF00CED1">
                                        <MenuItem Header="🔍 Force Update Check" Click="Ctx_ForceUpdateCheck_Click" ToolTip="Force Windows Update to check for updates"/>
                                        <MenuItem Header="📊 View Update Status" Click="Ctx_ViewUpdateStatus_Click" ToolTip="Check if updates are available or pending"/>
                                        <MenuItem Header="🔄 Check Pending Reboot" Click="Ctx_CheckPendingReboot_Click" ToolTip="Check if computer needs reboot for updates"/>
                                    </MenuItem>
                                    <Separator x:Name="CtxSep1"/>

                                    <!-- System Actions (Admin Only) -->
                                    <MenuItem Header="⚡ Force GP Update" Click="Ctx_GPUpdate_Click" x:Name="CtxGP"/>
                                    <MenuItem Header="🔥 Kill Firewall" Click="Ctx_KillFirewall_Click" x:Name="CtxFirewall"/>
                                    <MenuItem Header="🔌 Enable WinRM" Click="Ctx_EnableWinRM_Click" x:Name="CtxWinRM"/>
                                    <Separator x:Name="CtxSep2"/>

                                    <!-- Deployment (Admin Only) -->
                                    <MenuItem Header="🚀 Push General Update" Click="Ctx_PushGeneral_Click" x:Name="CtxPushGeneral"/>
                                    <MenuItem Header="🎯 Push Feature Update" Click="Ctx_PushFeature_Click" x:Name="CtxPushFeature"/>
                                    <Separator x:Name="CtxSep3"/>

                                    <!-- Power Options (Admin Only) -->
                                    <MenuItem Header="⚠ Reboot System" Click="Ctx_Reboot_Click" x:Name="CtxReboot" Foreground="#FFFF6B6B"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>

                            <!-- Card View (Alternative Layout) - TAG: #AUTO_UPDATE_UI_ENGINE #CARD_VIEW -->
                            <ScrollViewer x:Name="CardViewContainer"
                                          VerticalScrollBarVisibility="Auto"
                                          Visibility="Collapsed">
                                <ItemsControl x:Name="CardViewItems" ItemsSource="{Binding ElementName=GridInventory, Path=ItemsSource}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" Margin="10"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Computer Card Component -->
                                            <Border Width="300" Height="180"
                                                    Background="{StaticResource BgMediumBrush}"
                                                    BorderBrush="{StaticResource BorderDimBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Margin="6"
                                                    Cursor="Hand">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.3"/>
                                                </Border.Effect>
                                                <Grid Margin="12">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Header: Hostname + Status -->
                                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                                        <TextBlock Text="{Binding Hostname}"
                                                                   FontSize="14" FontWeight="Bold"
                                                                   Foreground="White"
                                                                   VerticalAlignment="Center"/>
                                                        <Border HorizontalAlignment="Right"
                                                                Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                                CornerRadius="10" Padding="8,3">
                                                            <TextBlock Text="{Binding Status}"
                                                                       FontSize="9" FontWeight="Bold"
                                                                       Foreground="White"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- OS Info -->
                                                    <TextBlock Grid.Row="1" Text="{Binding DisplayOS}"
                                                               FontSize="11" Foreground="#AAA"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,0,8"/>

                                                    <!-- Details -->
                                                    <StackPanel Grid.Row="2" Margin="0,0,0,8">
                                                        <TextBlock FontSize="10" Foreground="#888" Margin="0,2">
                                                            <Run Text="👤 "/>
                                                            <Run Text="{Binding CurrentUser}" Foreground="#CCC"/>
                                                        </TextBlock>
                                                        <TextBlock FontSize="10" Foreground="#888" Margin="0,2">
                                                            <Run Text="💾 "/>
                                                            <Run Text="{Binding RAM}" Foreground="#CCC"/>
                                                            <Run Text=" RAM"/>
                                                        </TextBlock>
                                                        <TextBlock FontSize="10" Foreground="#888" Margin="0,2">
                                                            <Run Text="🖥 "/>
                                                            <Run Text="{Binding Manufacturer}" Foreground="#CCC"/>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <!-- Quick Actions -->
                                                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <Button Content="RDP"
                                                                FontSize="9" Padding="6,3" Margin="0,0,4,0"
                                                                Background="{StaticResource AccentOrangeBrush}"
                                                                Foreground="White" BorderThickness="0"
                                                                ToolTip="Remote Desktop"/>
                                                        <Button Content="PS"
                                                                FontSize="9" Padding="6,3"
                                                                Background="{StaticResource BgDarkBrush}"
                                                                Foreground="{StaticResource AccentOrangeBrush}"
                                                                BorderThickness="1"
                                                                BorderBrush="{StaticResource AccentOrangeBrush}"
                                                                ToolTip="PowerShell"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Skeleton Loader Overlay - TAG: #AUTO_UPDATE_UI_ENGINE #SKELETON_LOADER -->
                            <Border x:Name="FleetSkeletonLoader"
                                    Background="{StaticResource BgDarkBrush}"
                                    Visibility="Collapsed">
                                <StackPanel Margin="20">
                                    <!-- Repeat skeleton rows -->
                                    <Border Height="40" Background="#1A1A1A" Margin="0,0,0,2" CornerRadius="4">
                                        <Grid Margin="10">
                                            <Rectangle Fill="#2A2A2A" Width="150" HorizontalAlignment="Left" Height="16" RadiusX="2" RadiusY="2"/>
                                            <Rectangle Fill="#2A2A2A" Width="80" HorizontalAlignment="Right" Height="16" RadiusX="2" RadiusY="2"/>
                                        </Grid>
                                    </Border>
                                    <Border Height="40" Background="#1A1A1A" Margin="0,0,0,2" CornerRadius="4">
                                        <Grid Margin="10">
                                            <Rectangle Fill="#2A2A2A" Width="180" HorizontalAlignment="Left" Height="16" RadiusX="2" RadiusY="2"/>
                                            <Rectangle Fill="#2A2A2A" Width="100" HorizontalAlignment="Right" Height="16" RadiusX="2" RadiusY="2"/>
                                        </Grid>
                                    </Border>
                                    <Border Height="40" Background="#1A1A1A" Margin="0,0,0,2" CornerRadius="4">
                                        <Grid Margin="10">
                                            <Rectangle Fill="#2A2A2A" Width="160" HorizontalAlignment="Left" Height="16" RadiusX="2" RadiusY="2"/>
                                            <Rectangle Fill="#2A2A2A" Width="90" HorizontalAlignment="Right" Height="16" RadiusX="2" RadiusY="2"/>
                                        </Grid>
                                    </Border>
                                    <Border Height="40" Background="#1A1A1A" Margin="0,0,0,2" CornerRadius="4">
                                        <Grid Margin="10">
                                            <Rectangle Fill="#2A2A2A" Width="140" HorizontalAlignment="Left" Height="16" RadiusX="2" RadiusY="2"/>
                                            <Rectangle Fill="#2A2A2A" Width="110" HorizontalAlignment="Right" Height="16" RadiusX="2" RadiusY="2"/>
                                        </Grid>
                                    </Border>
                                    <Border Height="40" Background="#1A1A1A" Margin="0,0,0,2" CornerRadius="4">
                                        <Grid Margin="10">
                                            <Rectangle Fill="#2A2A2A" Width="170" HorizontalAlignment="Left" Height="16" RadiusX="2" RadiusY="2"/>
                                            <Rectangle Fill="#2A2A2A" Width="95" HorizontalAlignment="Right" Height="16" RadiusX="2" RadiusY="2"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DockPanel>
                </TabItem>

                <!-- ══════════════════════════════ -->
                <!-- TAB 3: LIVE DATA & LOGS        -->
                <!-- ══════════════════════════════ -->
                <TabItem Header="LIVE DATA &amp; LOGS">
                    <DockPanel Margin="15">
                        <Border DockPanel.Dock="Top" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="REFRESH LOGS" Style="{StaticResource BtnPrimary}"
                                        Click="Menu_RefreshLogs_Click" Padding="14,6" FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <DataGrid x:Name="AuditGrid" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Timestamp" Binding="{Binding Time}" Width="155"/>
                                <DataGridTextColumn Header="User" Binding="{Binding User}" Width="150"/>
                                <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="140"/>
                                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="160"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="70"/>
                                <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*"/>
                            </DataGrid.Columns>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Kill Process" Click="Ctx_KillProc_Click"/>
                                    <MenuItem Header="Restart Service" Click="Ctx_RestartSvc_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <!-- ══════════════════════════════ -->
                <!-- TAB 4: DOMAIN & DIRECTORY (with Sub-Tabs) - TAG: #VERSION_7 #UI_FIX #SUB_TABS #MMC_EMBEDDING -->
                <!-- ══════════════════════════════ -->
                <TabItem Header="DOMAIN &amp; DIRECTORY">
                    <TabControl x:Name="TabControlDomainDirectory" Background="{StaticResource BgDarkBrush}" BorderThickness="0" Padding="10">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="20,10"/>
                                <Setter Property="Margin" Value="0,0,4,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border Name="Border" Background="{TemplateBinding Background}"
                                                    BorderBrush="#444" BorderThickness="1" CornerRadius="6,6,0,0"
                                                    Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}">
                                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#FF6B35" Offset="0"/>
                                                                <GradientStop Color="#71797E" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#3A3A3A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <!-- SUB-TAB 1: Domain Services -->
                        <TabItem Header="🌐 DOMAIN SERVICES">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Grid Margin="20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                            <!-- SECTION 1: Two-Column Layout (DC Selection + Domain Info) -->
                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.4*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- LEFT: Domain Controller Selection -->
                                <Border Grid.Column="0" Background="#FF1E1E1E" BorderBrush="#FF3C3C3C"
                                        BorderThickness="1" CornerRadius="8" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="🌐 DOMAIN CONTROLLER SELECTION"
                                                   Foreground="{StaticResource AccentOrangeBrush}"
                                                   FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>

                                        <!-- Modern Sleek DC Dropdown - TAG: #DC_DISCOVERY #THEME_COLORS -->
                                        <Border Background="#2D2D2D" CornerRadius="6" BorderThickness="1" Margin="0,0,0,10">
                                            <Border.BorderBrush>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#FF8533" Offset="0"/>
                                                    <GradientStop Color="#A1A1AA" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.BorderBrush>
                                            <ComboBox x:Name="ComboDC"
                                                      Foreground="White" FontWeight="SemiBold" FontSize="12"
                                                      Background="Transparent" BorderThickness="0"
                                                      Padding="10,8">
                                            <ComboBox.Resources>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="Background" Value="#1A1A1A"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="Padding" Value="10,6"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ComboBoxItem">
                                                                <Border Name="Border" Background="{TemplateBinding Background}"
                                                                        Padding="{TemplateBinding Padding}" CornerRadius="3" Margin="2">
                                                                    <ContentPresenter/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsHighlighted" Value="True">
                                                                        <Setter TargetName="Border" Property="Background">
                                                                            <Setter.Value>
                                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                                    <GradientStop Color="#FF8533" Offset="0"/>
                                                                                    <GradientStop Color="#A1A1AA" Offset="1"/>
                                                                                </LinearGradientBrush>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter TargetName="Border" Property="Background" Value="#FF8533"/>
                                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                        </Border>

                                        <!-- TAG: #TOOLTIPS #ACTIONS -->
                                        <Button x:Name="BtnRefreshDCs" Click="BtnRefreshDCs_Click"
                                                Foreground="White" FontSize="10" FontWeight="SemiBold"
                                                Margin="0,0,0,10" Padding="0" BorderThickness="0" Cursor="Hand"
                                                ToolTip="Rediscovers all domain controllers in Active Directory environment and refreshes health status indicators. Pings each DC, checks LDAP connectivity, verifies replication status, and displays role information (PDC, GC, RODC). Updates DC Health Topology grid with real-time status. (F5)">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" CornerRadius="4" Padding="10,7">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#FF8533" Offset="0"/>
                                                                <GradientStop Color="#CC6B29" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="🔄" FontSize="12" Margin="0,0,6,0"/>
                                                <TextBlock Text="REFRESH DOMAIN CONTROLLERS"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- TAG: #VERSION_7 #CONNECTION_PROFILES #TOOLTIPS #CONNECTION_PROFILES - Manage Connection Profiles -->
                                        <Button x:Name="BtnManageProfiles" Click="BtnManageProfiles_Click"
                                                Background="#FF2A2A2A" Foreground="White" FontSize="10" FontWeight="SemiBold"
                                                Margin="0,0,0,12" Padding="10,7" BorderThickness="1" BorderBrush="#FF444444"
                                                Cursor="Hand" ToolTip="Opens Connection Profile Manager to save, load, edit, and delete domain controller connection profiles. Each profile stores preferred DC, credentials, query method, and connection settings. Quickly switch between multiple domains/forests without re-entering credentials. Profiles stored encrypted in database.">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="🔗" FontSize="12" Margin="0,0,6,0"/>
                                                <TextBlock Text="MANAGE CONNECTION PROFILES"/>
                                            </StackPanel>
                                        </Button>

                                        <CheckBox x:Name="ChkRememberDC" Content="Remember DC Selection on Startup"
                                                  Foreground="{StaticResource TextMutedBrush}" FontSize="10"
                                                  Margin="0,0,0,0" Click="ChkRememberDC_Click"/>
                                    </StackPanel>
                                </Border>

                                <!-- RIGHT: Domain Information (Compact) -->
                                <Border Grid.Column="2" Background="#FF1E1E1E" BorderBrush="#FF3C3C3C"
                                        BorderThickness="1" CornerRadius="8" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="ℹ️ DOMAIN INFORMATION"
                                                   Foreground="{StaticResource AccentOrangeBrush}"
                                                   FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Current Domain:"
                                                       Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="0,0,8,8"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtCurrentDomain_Tab"
                                                       Text="Not connected" Foreground="White" FontSize="10"
                                                       FontWeight="SemiBold" Margin="0,0,0,8"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="User Domain:"
                                                       Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="0,0,8,8"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtUserDomain_Tab"
                                                       Text="-" Foreground="White" FontSize="10" Margin="0,0,0,8"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Computer Name:"
                                                       Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="0,0,8,8"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtComputerName_Tab"
                                                       Text="-" Foreground="White" FontSize="10" Margin="0,0,0,8"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="DCs Discovered:"
                                                       Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtDCCount_Tab"
                                                       Text="0" Foreground="{StaticResource AccentOrangeBrush}"
                                                       FontSize="10" FontWeight="Bold"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- SECTION 2: Admin Tools (MOVED HERE per user request) - TAG: #VERSION_7 #UI_IMPROVEMENT -->
                            <Border Grid.Row="1" Background="#FF1E1E1E" BorderBrush="#FF3C3C3C"
                                    BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="🔧 ADMIN TOOLS"
                                               Foreground="{StaticResource AccentOrangeBrush}"
                                               FontSize="14" FontWeight="Bold" Margin="0,0,0,14"/>

                                    <!-- TAG: #TOOLTIPS #UTILITIES -->
                                    <Button x:Name="BtnCheckLockouts" Content="📊 CHECK ACCOUNT LOCKOUTS"
                                            Style="{StaticResource BtnPrimary}" Click="BtnCheckLockouts_Click"
                                            Padding="12,10" FontSize="12" FontWeight="Bold" Margin="0,0,0,14"
                                            ToolTip="Queries domain controllers for recent account lockout events from Security Event Log (Event ID 4740). Shows locked accounts, lockout source computer, timestamp, and DC that logged the event. Useful for troubleshooting user login issues and identifying password attack sources. Requires domain admin privileges."/>

                                    <TextBlock Text="Launch Management Console:"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="ComboAdminTools" Grid.Column="0" Margin="0,0,8,0"
                                                  Foreground="White" FontWeight="SemiBold" FontSize="12"
                                                  Padding="12,8"
                                                  SelectionChanged="ComboAdminTools_SelectionChanged">
                                            <ComboBoxItem Content="AD Users &amp; Computers" IsSelected="True"/>
                                            <ComboBoxItem Content="Group Policy (GPMC)"/>
                                            <ComboBoxItem Content="DNS Manager"/>
                                            <ComboBoxItem Content="DHCP"/>
                                            <ComboBoxItem Content="Services (Local/Remote)"/>
                                            <ComboBoxItem Content="AD Sites and Services"/>
                                            <ComboBoxItem Content="AD Domains and Trusts"/>
                                            <ComboBoxItem Content="Certification Authority"/>
                                            <ComboBoxItem Content="Failover Cluster Manager"/>
                                        </ComboBox>
                                        <!-- TAG: #EXTERNAL_TOOLS #MMC_LAUNCH #ADMIN_TOOLS -->
                                        <Button x:Name="BtnOpenMMCConsole" Grid.Column="1" Style="{StaticResource BtnPrimary}"
                                                Click="BtnOpenMMCConsole_Click" Padding="16,8" FontSize="12" Margin="0,0,8,0"
                                                ToolTip="Opens the selected management console in an external window with Kerberos credential passthrough. The console will use your cached domain credentials for seamless authentication.">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="TxtMMCStatus" Text="🔴" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                                          ToolTip="Tool status: 🟢 = Running, 🔴 = Not running"/>
                                                <TextBlock Text="OPEN" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <!-- TAG: #EXTERNAL_TOOLS #FORCE_CLOSE -->
                                        <Button x:Name="BtnForceCloseMMC" Grid.Column="2" Content="FORCE CLOSE" Style="{StaticResource BtnDanger}"
                                                Click="BtnForceCloseMMC_Click" Padding="12,8" FontSize="12"
                                                Visibility="Collapsed"
                                                ToolTip="Force closes the running MMC console. Use this if the console becomes unresponsive or you need to restart it."/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- SECTION 3: DC Health Topology (MUCH BIGGER per user request) - TAG: #VERSION_7 #UI_IMPROVEMENT -->
                            <Border Grid.Row="2" Background="#FF1E1E1E" BorderBrush="#FF3C3C3C"
                                    BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="💚 DC HEALTH TOPOLOGY"
                                               Foreground="{StaticResource AccentOrangeBrush}"
                                               FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

                                    <TextBlock Text="Real-time health status of all discovered domain controllers:"
                                               Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                                               Margin="0,0,0,16" TextWrapping="Wrap"/>

                                    <!-- TAG: #DC_DISCOVERY #THEME_COLORS #UI_IMPROVEMENT #RESPONSIVE - Auto-wrapping cards that fill space -->
                                    <WrapPanel x:Name="GridDCHealth" Orientation="Horizontal" Margin="0,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- SECTION 5: DC Discovery History (moved from Row 4) -->
                            <Border Grid.Row="3" Background="#FF1E1E1E" BorderBrush="#FF3C3C3C"
                                    BorderThickness="1" CornerRadius="8" Padding="20">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="📜 DC DISCOVERY HISTORY"
                                                   Foreground="{StaticResource AccentOrangeBrush}"
                                                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>

                                        <Border Grid.Column="1" Background="#FF2A2A2A"
                                                CornerRadius="4" Padding="8,5" Cursor="Hand"
                                                MouseLeftButtonDown="DCHistory_Toggle">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="DCHistoryToggleIcon" Text="▼"
                                                           Foreground="{StaticResource AccentOrangeBrush}"
                                                           FontSize="9" FontWeight="Bold" Margin="0,0,6,0"/>
                                                <TextBlock Text="SHOW/HIDE"
                                                           Foreground="{StaticResource AccentOrangeBrush}"
                                                           FontSize="9" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="Previously discovered domain controllers (cached for 30 days):"
                                               Foreground="{StaticResource TextMutedBrush}" FontSize="10"
                                               Margin="0,0,0,10" TextWrapping="Wrap"/>

                                    <!-- TAG: #DC_DISCOVERY #THEME_COLORS -->
                                    <StackPanel x:Name="DCHistoryPanel" Visibility="Collapsed">
                                        <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="DCHistoryList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#FF252525" Padding="12,10" Margin="0,0,0,8"
                                                                CornerRadius="4" BorderBrush="{StaticResource AccentOrangeBrush}" BorderThickness="0,0,0,2">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Status Indicator -->
                                                                <Border Grid.Column="0" Width="12" Height="12" CornerRadius="6"
                                                                        Margin="0,0,12,0" VerticalAlignment="Center">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#666666"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding StatusIcon}" Value="🟢">
                                                                                    <Setter Property="Background">
                                                                                        <Setter.Value>
                                                                                            <RadialGradientBrush>
                                                                                                <GradientStop Color="#00FF00" Offset="0"/>
                                                                                                <GradientStop Color="#00AA00" Offset="1"/>
                                                                                            </RadialGradientBrush>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding StatusIcon}" Value="🟡">
                                                                                    <Setter Property="Background">
                                                                                        <Setter.Value>
                                                                                            <RadialGradientBrush>
                                                                                                <GradientStop Color="#FFFF00" Offset="0"/>
                                                                                                <GradientStop Color="#AAAA00" Offset="1"/>
                                                                                            </RadialGradientBrush>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding StatusIcon}" Value="🟠">
                                                                                    <Setter Property="Background">
                                                                                        <Setter.Value>
                                                                                            <RadialGradientBrush>
                                                                                                <GradientStop Color="#FF8533" Offset="0"/>
                                                                                                <GradientStop Color="#CC6B29" Offset="1"/>
                                                                                            </RadialGradientBrush>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                </Border>

                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{Binding Hostname}" Foreground="White"
                                                                               FontSize="12" FontWeight="SemiBold"/>
                                                                    <TextBlock FontSize="10" Margin="0,3,0,0">
                                                                        <TextBlock.Foreground>
                                                                            <SolidColorBrush Color="#A1A1AA"/>
                                                                        </TextBlock.Foreground>
                                                                        <Run Text="Last seen: "/>
                                                                        <Run Text="{Binding LastSeen, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Foreground="#CCCCCC"/>
                                                                        <Run Text=" | Latency: "/>
                                                                        <Run Text="{Binding AvgLatency}" Foreground="{StaticResource AccentOrangeBrush}"/>
                                                                        <Run Text="ms" Foreground="{StaticResource AccentOrangeBrush}"/>
                                                                    </TextBlock>
                                                                </StackPanel>

                                                                <Border Grid.Column="2" Background="#FF1A1A1A" CornerRadius="3"
                                                                        Padding="8,4" VerticalAlignment="Center">
                                                                    <TextBlock FontSize="9" FontWeight="SemiBold">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="OFFLINE"/>
                                                                                <Setter Property="Foreground" Value="#666666"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding StatusIcon}" Value="🟢">
                                                                                        <Setter Property="Text" Value="RECENT"/>
                                                                                        <Setter Property="Foreground" Value="#00FF00"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding StatusIcon}" Value="🟡">
                                                                                        <Setter Property="Text" Value="~1 WEEK"/>
                                                                                        <Setter Property="Foreground" Value="#FFFF00"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding StatusIcon}" Value="🟠">
                                                                                        <Setter Property="Text" Value="~1 MONTH"/>
                                                                                        <Setter Property="Foreground" Value="{StaticResource AccentOrangeBrush}"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <TextBlock x:Name="DCHistoryEmpty" Text="No cached DC history available"
                                                   Foreground="#666666" FontSize="9" FontStyle="Italic"
                                                   HorizontalAlignment="Center" Margin="0,12,0,0"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>

                        <!-- SUB-TAB 2: AD Management -->
                        <TabItem Header="👥 AD MANAGEMENT">
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header Section -->
                                <Border Grid.Row="0" Background="#FF1E1E1E" BorderBrush="#FF3C3C3C"
                                        BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="👥 ACTIVE DIRECTORY MANAGEMENT"
                                                   Foreground="{StaticResource AccentOrangeBrush}"
                                                   FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

                                        <TextBlock Text="Browse and manage AD objects (users, computers, groups, OUs) with cached admin credentials:"
                                                   Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                                                   Margin="0,0,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- AD Browser Section (takes all remaining space) -->
                                <Border Grid.Row="1" Background="#FF1E1E1E" BorderBrush="#FF3C3C3C"
                                        BorderThickness="1" CornerRadius="8" Padding="20">
                                    <DockPanel>
                                        <!-- TAG: #TOOLTIPS #ACTIONS - Management Action Buttons (at bottom) -->
                                        <Grid DockPanel.Dock="Bottom" Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0" Content="➕ CREATE OBJECT" x:Name="BtnCreateADObject"
                                                    Style="{StaticResource BtnPrimary}" Click="BtnCreateADObject_Click"
                                                    Padding="12,10" FontSize="11" Margin="0,0,4,0"
                                                    ToolTip="Creates new Active Directory object (User, Computer, Group, OU, Contact) in selected container. Opens creation wizard with object-specific attributes. Requires domain admin or delegated OU creation rights. Changes replicate to all DCs within 15 minutes."/>

                                            <Button Grid.Column="1" Content="✏️ EDIT PROPERTIES" x:Name="BtnEditADObject"
                                                    Background="#FF3C3C3C" Foreground="White"
                                                    Click="BtnEditADObject_Click"
                                                    Padding="12,10" FontSize="11" Margin="4,0" IsEnabled="False"
                                                    ToolTip="Opens property editor for selected AD object. Modify attributes including name, description, group membership, account settings, and custom attributes. Requires appropriate AD permissions for target object. Enabled only when object is selected in tree view."/>

                                            <Button Grid.Column="2" Content="🗑️ DELETE OBJECT" x:Name="BtnDeleteADObject"
                                                    Style="{StaticResource BtnDanger}" Click="BtnDeleteADObject_Click"
                                                    Padding="12,10" FontSize="11" Margin="4,0" IsEnabled="False"
                                                    ToolTip="Permanently deletes selected Active Directory object. WARNING: Cannot be undone unless AD Recycle Bin is enabled. Deleting OUs removes all child objects. Requires domain admin or delegated delete rights. Confirmation prompt displayed before deletion."/>

                                            <Button Grid.Column="3" Content="🔄 REFRESH" x:Name="BtnRefreshADObjects"
                                                    Background="#FF3C3C3C" Foreground="White"
                                                    Click="BtnRefreshADObjects_Click"
                                                    Padding="12,10" FontSize="11" Margin="4,0,0,0"
                                                    ToolTip="Refreshes Active Directory object tree view and reloads all containers, users, groups, computers, and OUs from domain controller. Updates object counts and displays recent changes made by other admins. Clears cached results and performs fresh AD query. (F5)"/>
                                        </Grid>

                                        <!-- AD Object Browser Control (fills remaining space) -->
                                        <local:ADObjectBrowser x:Name="ADObjectBrowserDomainTab"/>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </TabItem>

                <!-- ══════════════════════════════ -->
                <!-- TAB 5: REMOTE CONTROL          -->
                <!-- TAG: #REMOTE_CONTROL #RMM_TAB  -->
                <!-- ══════════════════════════════ -->
                <TabItem Header="🖥️ REMOTE CONTROL">
                    <local:RemoteControlTab x:Name="RemoteControlTabContent"/>
                </TabItem>

                <!-- ══════════════════════════════════════════════════════════════ -->
                <!-- TAB: DEPLOYMENT RESULTS - TAG: #DEPLOYMENT_RESULTS #CSV_VIEW  -->
                <!-- ══════════════════════════════════════════════════════════════ -->
                <TabItem Header="📋 DEPLOYMENT RESULTS">
                    <DockPanel Margin="15">

                        <!-- Toolbar -->
                        <Border DockPanel.Dock="Top" Background="#FF1E1E1E" BorderBrush="#FF3C3C3C"
                                BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: action buttons -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <!-- TAG: #TOOLTIPS #ACTIONS -->
                                    <Button x:Name="BtnRefreshDeploymentResults"
                                            Style="{StaticResource BtnPrimary}"
                                            Click="BtnRefreshDeploymentResults_Click"
                                            Padding="14,8" FontSize="11" FontWeight="Bold" Margin="0,0,8,0"
                                            ToolTip="Reload Master_Update_Log.csv from the Deployment Log Directory configured in Options.">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔄" Margin="0,0,6,0"/>
                                            <TextBlock Text="REFRESH"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="BtnExportDeploymentResults"
                                            Style="{StaticResource BtnGhost}"
                                            Click="BtnExportDeploymentResults_Click"
                                            Padding="12,8" FontSize="11" Margin="0,0,8,0"
                                            ToolTip="Export the currently visible (filtered) results to a dated CSV file on your Desktop.">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📊" Margin="0,0,6,0"/>
                                            <TextBlock Text="EXPORT CSV"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="BtnClearDeploymentLog"
                                            Style="{StaticResource BtnGhost}"
                                            Click="BtnClearDeploymentLog_Click"
                                            IsEnabled="False"
                                            Padding="12,8" FontSize="11" Foreground="#EF4444"
                                            ToolTip="Domain Admin login required to clear deployment logs.">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🗑️" Margin="0,0,6,0"/>
                                            <TextBlock Text="CLEAR LOG"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="BtnArchiveDeploymentLog"
                                            Style="{StaticResource BtnGhost}"
                                            Click="BtnArchiveDeploymentLog_Click"
                                            IsEnabled="False"
                                            Padding="12,8" FontSize="11" Foreground="#F59E0B" Margin="8,0,0,0"
                                            ToolTip="Domain Admin login required to archive deployment logs.">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📦" Margin="0,0,6,0"/>
                                            <TextBlock Text="ARCHIVE OLD"/>
                                        </StackPanel>
                                    </Button>
                                    <!-- TAG: #DEPLOYMENT_RESULTS #TOOLTIPS - PC Log access buttons -->
                                    <Button x:Name="BtnBrowsePCLogs"
                                            Style="{StaticResource BtnGhost}"
                                            Click="BtnBrowsePCLogs_Click"
                                            Padding="12,8" FontSize="11" Margin="0,0,8,0"
                                            ToolTip="Open the Individual_PC_Logs folder in Windows Explorer to browse all per-computer deployment logs.">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📁" Margin="0,0,6,0"/>
                                            <TextBlock Text="BROWSE LOGS"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="BtnViewPCLog"
                                            Style="{StaticResource BtnGhost}"
                                            Click="BtnViewPCLog_Click"
                                            IsEnabled="False"
                                            Padding="12,8" FontSize="11" Margin="0,0,8,0"
                                            ToolTip="Open the individual PC log file for the selected deployment result row. Select a row first.">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📄" Margin="0,0,6,0"/>
                                            <TextBlock Text="VIEW LOG"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="BtnLoadArchive"
                                            Style="{StaticResource BtnGhost}"
                                            Click="BtnLoadArchive_Click"
                                            Padding="12,8" FontSize="11" Foreground="#3B82F6" Margin="0,0,8,0"
                                            ToolTip="Load archived deployment results from the Archives folder and merge them into the grid with a Source indicator.">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📂" Margin="0,0,6,0"/>
                                            <TextBlock Text="LOAD ARCHIVE"/>
                                        </StackPanel>
                                    </Button>
                                    <!-- TAG: #DEPLOYMENT_RESULTS - "Latest per PC" toggle -->
                                    <CheckBox x:Name="ChkLatestPerPC"
                                              Content="Latest per PC" IsChecked="True"
                                              Foreground="#A1A1AA" FontSize="11"
                                              VerticalContentAlignment="Center" Margin="16,0,0,0"
                                              Checked="ChkLatestPerPC_Changed" Unchecked="ChkLatestPerPC_Changed"
                                              ToolTip="When checked: shows only the most recent run per computer (cleaner view). Uncheck to see the full run history for every PC."/>
                                    <!-- TAG: #DEPLOYMENT_RESULTS - pulsing dot during load -->
                                    <Ellipse x:Name="DeploymentLoadingPulse"
                                             Width="10" Height="10" Fill="#F59E0B"
                                             VerticalAlignment="Center" Margin="12,0,0,0"
                                             Visibility="Collapsed"
                                             ToolTip="Loading deployment results…"/>
                                    <!-- TAG: #DEPLOYMENT_RESULTS - Auto-refresh toggle -->
                                    <CheckBox x:Name="ChkDeploymentAutoRefresh"
                                              Content="Auto-refresh (60s)" IsChecked="False"
                                              Foreground="#A1A1AA" FontSize="11"
                                              VerticalContentAlignment="Center" Margin="16,0,0,0"
                                              Checked="ChkDeploymentAutoRefresh_Changed" Unchecked="ChkDeploymentAutoRefresh_Changed"
                                              ToolTip="Automatically reload the deployment log every 60 seconds while this tab is visible. Useful for monitoring active deployments in real-time."/>
                                </StackPanel>

                                <!-- Centre: search -->
                                <Border Grid.Column="1" Background="#2D2D2D" CornerRadius="4"
                                        BorderBrush="#444" BorderThickness="1" Margin="12,0,12,0">
                                    <TextBox x:Name="TxtDeploymentSearch"
                                             Background="Transparent" Foreground="White" BorderThickness="0"
                                             Padding="8,6" FontSize="11" VerticalContentAlignment="Center"
                                             TextChanged="TxtDeploymentSearch_TextChanged"
                                             Tag="Search hostname, status, OS, user, serial..."/>
                                </Border>

                                <!-- Right: status info -->
                                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtDeploymentCount"
                                               Text="0 records" Foreground="{StaticResource AccentOrangeBrush}"
                                               FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    <TextBlock x:Name="TxtDeploymentLogPath"
                                               Text="Log: not loaded" Foreground="#A1A1AA"
                                               FontSize="9" HorizontalAlignment="Right"
                                               TextTrimming="CharacterEllipsis" MaxWidth="350"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Outcome tally strip - TAG: #DEPLOYMENT_RESULTS #TALLY -->
                        <Border DockPanel.Dock="Top" Background="#0F0F14" BorderBrush="#252525"
                                BorderThickness="1" CornerRadius="6" Padding="10,7" Margin="0,0,0,6">
                            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                                <!-- Success group (green pill) -->
                                <Border Background="#0D2818" CornerRadius="4" Padding="10,5" Margin="0,0,8,0"
                                        ToolTip="FeatureUpdate: Win11 installed via WU or ISO. FeatureUpdate fallback: Win10 22H2 installed.">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Win11:" Foreground="#6EE7B7" FontSize="10.5" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock x:Name="TxtTallyWin11" Text="—" Foreground="#10B981" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                        <TextBlock Text="Win10:" Foreground="#93C5FD" FontSize="10.5" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock x:Name="TxtTallyWin10" Text="—" Foreground="#3B82F6" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                        <TextBlock Text="Patches:" Foreground="#C4B5FD" FontSize="10.5" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock x:Name="TxtTallyPatches" Text="—" Foreground="#A78BFA" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Compliant group (muted green pill) -->
                                <Border Background="#111A18" CornerRadius="4" Padding="10,5" Margin="0,0,8,0"
                                        ToolTip="Machines already on the target OS version or with no pending patches.">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Up to Date:" Foreground="#6EE7B7" FontSize="10.5" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock x:Name="TxtTallyCompliant" Text="—" Foreground="#10B981" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Problem group (red pill) -->
                                <Border Background="#1F1215" CornerRadius="4" Padding="10,5" Margin="0,0,8,0"
                                        ToolTip="HW Blocked = failed Win11 hardware requirements (TPM/SecureBoot/RAM/Disk). Failed = script error (WU, module install, ISO timeout, etc.).">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="HW Blocked:" Foreground="#FCA5A5" FontSize="10.5" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock x:Name="TxtTallyHWBlocked" Text="—" Foreground="#EF4444" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                        <TextBlock Text="Failed:" Foreground="#FCA5A5" FontSize="10.5" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock x:Name="TxtTallyFailed" Text="—" Foreground="#EF4444" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Pending group (amber pill) -->
                                <Border Background="#1F1A0D" CornerRadius="4" Padding="10,5" Margin="0,0,8,0"
                                        ToolTip="User chose to postpone the upgrade dialog (up to the configured maximum).">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Postponed:" Foreground="#FCD34D" FontSize="10.5" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock x:Name="TxtTallyPostponed" Text="—" Foreground="#F59E0B" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Total group (orange pill) -->
                                <Border Background="#1F1508" CornerRadius="4" Padding="10,5"
                                        ToolTip="Total script runs in the log (all PCs, all runs). Use 'Latest per PC' toggle to see unique PC count.">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Total Runs:" Foreground="#FDBA74" FontSize="10.5" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock x:Name="TxtTallyTotal" Text="—" Foreground="{StaticResource AccentOrangeBrush}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                            </WrapPanel>
                        </Border>

                        <!-- TAG: #DEPLOYMENT_RESULTS - colour + exit-code legend strip -->
                        <Border DockPanel.Dock="Top"
                                Background="#0F0F14" BorderBrush="#252525"
                                BorderThickness="1" CornerRadius="6"
                                Padding="10,7" Margin="0,0,0,8">
                            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                                <!-- ── STATUS section ── -->
                                <Border Background="#1A1A22" CornerRadius="4" Padding="10,5" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="STATUS" Foreground="#6B7280" FontSize="9.5" FontWeight="Bold"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Ellipse Width="9" Height="9" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Success / Compliant" Foreground="#9CA3AF" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <Ellipse Width="9" Height="9" Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Failed / HW Blocked" Foreground="#9CA3AF" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <Ellipse Width="9" Height="9" Fill="#F59E0B" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Rebooting / Postponed" Foreground="#9CA3AF" FontSize="10"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- ── SCRIPT section ── -->
                                <Border Background="#1A1A22" CornerRadius="4" Padding="10,5" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="SCRIPT" Foreground="#6B7280" FontSize="9.5" FontWeight="Bold"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Border Background="#2D2042" CornerRadius="3" Padding="6,2" Margin="0,0,5,0">
                                            <TextBlock Text="Feature" Foreground="#A78BFA" FontSize="10" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Win 10/11 upgrade" Foreground="#9CA3AF" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <Border Background="#1A2740" CornerRadius="3" Padding="6,2" Margin="0,0,5,0">
                                            <TextBlock Text="General" Foreground="#3B82F6" FontSize="10" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Cumulative patches" Foreground="#9CA3AF" FontSize="10"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- ── EXIT CODES section ── -->
                                <Border Background="#1A1A22" CornerRadius="4" Padding="10,5"
                                        ToolTip="ManageEngine shows these exit codes in the task result column so you can see outcomes at a glance without opening log files.">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="EXIT" Foreground="#6B7280" FontSize="9.5" FontWeight="Bold"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="11" Foreground="#10B981" FontSize="10" FontWeight="Bold"
                                                   VerticalAlignment="Center" Margin="0,0,2,0"/>
                                        <TextBlock Text="Win11" Foreground="#6B7280" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="10" Foreground="#3B82F6" FontSize="10" FontWeight="Bold"
                                                   VerticalAlignment="Center" Margin="0,0,2,0"/>
                                        <TextBlock Text="Win10" Foreground="#6B7280" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="0" Foreground="#A1A1AA" FontSize="10" FontWeight="Bold"
                                                   VerticalAlignment="Center" Margin="0,0,2,0"/>
                                        <TextBlock Text="No change" Foreground="#6B7280" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="20-29" Foreground="#EF4444" FontSize="10" FontWeight="Bold"
                                                   VerticalAlignment="Center" Margin="0,0,2,0"/>
                                        <TextBlock Text="Feature fail" Foreground="#6B7280" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="10-13" Foreground="#EF4444" FontSize="10" FontWeight="Bold"
                                                   VerticalAlignment="Center" Margin="0,0,2,0"/>
                                        <TextBlock Text="General fail" Foreground="#6B7280" FontSize="10"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                            </WrapPanel>
                        </Border>

                        <!-- DataGrid -->
                        <DataGrid x:Name="GridDeploymentResults"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserReorderColumns="True" CanUserSortColumns="True"
                                  SelectionMode="Extended" GridLinesVisibility="Horizontal"
                                  RowBackground="#1A1A1A" AlternatingRowBackground="#212121"
                                  ColumnHeaderHeight="30" RowHeight="26"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  MouseDoubleClick="GridDeploymentResults_MouseDoubleClick"
                                  SelectionChanged="GridDeploymentResults_SelectionChanged"
                                  ToolTip="Double-click a row to inspect that computer in the Single System Inspector tab.">
                            <DataGrid.Columns>
                                <!-- Status with colour coding -->
                                <DataGridTemplateColumn Header="Status" Width="120" MinWidth="90" SortMemberPath="Status">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Status}" FontWeight="SemiBold" FontSize="10"
                                                       VerticalAlignment="Center" Padding="4,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#A1A1AA"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="COMPLIANT">
                                                                <Setter Property="Foreground" Value="#10B981"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="SUCCESS">
                                                                <Setter Property="Foreground" Value="#10B981"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="FAILED">
                                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="HW_INCOMPATIBLE">
                                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="REBOOTING_UNATTENDED">
                                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="REBOOTING_AFTER_USER_WARNING">
                                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="NO_REBOOT_NEEDED">
                                                                <Setter Property="Foreground" Value="#10B981"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="POSTPONED">
                                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Hostname"     Binding="{Binding Hostname}"       Width="130" MinWidth="100"/>
                                <DataGridTextColumn Header="Script"       Binding="{Binding Script}"         Width="75"  MinWidth="60"/>
                                <DataGridTextColumn Header="Timestamp"    Binding="{Binding Timestamp}"      Width="145" MinWidth="110"/>
                                <DataGridTextColumn Header="Method"       Binding="{Binding Method}"         Width="110" MinWidth="70"/>
                                <DataGridTextColumn Header="OS"           Binding="{Binding OSVersion}"      Width="180" MinWidth="110"/>
                                <DataGridTextColumn Header="Build"        Binding="{Binding BuildNumber}"    Width="60"  MinWidth="50"/>
                                <DataGridTextColumn Header="Updates"      Binding="{Binding UpdateCount}"    Width="58"  MinWidth="45"/>
                                <DataGridTextColumn Header="Uptime(d)"    Binding="{Binding UptimeDays}"     Width="65"  MinWidth="50"/>
                                <DataGridTextColumn Header="RAM(GB)"      Binding="{Binding TotalRAMGB}"     Width="62"  MinWidth="50"/>
                                <DataGridTextColumn Header="Disk(GB)"     Binding="{Binding DiskFreeGB}"     Width="62"  MinWidth="50"/>
                                <DataGridTextColumn Header="IP Address"   Binding="{Binding IPAddress}"      Width="105" MinWidth="80"/>
                                <DataGridTextColumn Header="LoggedInUser" Binding="{Binding LoggedInUser}"   Width="130" MinWidth="90"/>
                                <DataGridTextColumn Header="Serial"       Binding="{Binding SerialNumber}"   Width="120" MinWidth="80"/>
                                <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}"   Width="110" MinWidth="80"/>
                                <DataGridTextColumn Header="Model"        Binding="{Binding Model}"          Width="145" MinWidth="100"/>
                                <DataGridTextColumn Header="TPM"          Binding="{Binding TPMPresent}"     Width="60"  MinWidth="45"/>
                                <DataGridTextColumn Header="SecureBoot"   Binding="{Binding SecureBoot}"     Width="80"  MinWidth="60"/>
                                <DataGridTextColumn Header="Duration(s)"  Binding="{Binding DurationSeconds}" Width="75" MinWidth="55"/>
                                <DataGridTextColumn Header="Details"      Binding="{Binding Details}"        Width="*"   MinWidth="150"/>
                            </DataGrid.Columns>
                        </DataGrid>

                    </DockPanel>
                </TabItem>

            </TabControl>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- TOOL OPERATION PROGRESS INDICATOR (Bottom-Right Corner)    -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border x:Name="ToolProgressPanel"
                Background="#DD1E1E1E"
                BorderBrush="{StaticResource AccentOrangeBrush}"
                BorderThickness="2"
                CornerRadius="6"
                Padding="16,12"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,20,20"
                Visibility="Collapsed">
            <StackPanel MinWidth="280">
                <!-- Tool Name Header -->
                <TextBlock x:Name="TxtToolName"
                           Text="Opening Tool..."
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentOrangeBrush}"
                           Margin="0,0,0,8"/>

                <!-- Progress Bar -->
                <ProgressBar x:Name="ToolProgressBar"
                             Height="6"
                             Background="#FF2A2A2A"
                             Foreground="{StaticResource AccentOrangeBrush}"
                             IsIndeterminate="True"
                             Margin="0,0,0,8"/>

                <!-- Status Message -->
                <TextBlock x:Name="TxtToolStatus"
                           Text="Connecting..."
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- LOADING OVERLAY - Shows during startup (TAG: #LOADING #STARTUP) -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="LoadingOverlay"
                Background="#DD000000"
                Visibility="Visible"
                Panel.ZIndex="9999">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Logo -->
                <Border Width="80" Height="80" CornerRadius="40" Margin="0,0,0,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF8533" Offset="0"/>
                            <GradientStop Color="#A1A1AA" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="A" FontSize="48" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Product Name -->
                <TextBlock Text="NecessaryAdminTool Suite"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>

                <!-- Loading Status Text -->
                <TextBlock x:Name="LoadingStatusText"
                           Text="Initializing..."
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <!-- Progress Bar -->
                <ProgressBar Width="300"
                             Height="4"
                             IsIndeterminate="True"
                             Foreground="#FF8533"
                             Background="#333333"
                             Margin="0,0,0,10"/>

                <!-- Detailed Status -->
                <TextBlock x:Name="LoadingDetailText"
                           Text="Please wait..."
                           Foreground="#A1A1AA"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,0"/>
            </StackPanel>
        </Border>

        </DockPanel>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- TOAST NOTIFICATION CONTAINER - TAG: #AUTO_UPDATE_UI_ENGINE    -->
        <!-- Overlay panel for toast notifications                          -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <StackPanel x:Name="ToastContainer"
                    Grid.RowSpan="2"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,80,20,0"
                    Width="350"
                    Panel.ZIndex="10000"/>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COMMAND PALETTE - TAG: #AUTO_UPDATE_UI_ENGINE #COMMAND_PALETTE -->
        <!-- Keyboard-driven command launcher (Ctrl+K)                       -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="CommandPaletteOverlay"
                Grid.RowSpan="2"
                Background="#AA000000"
                Visibility="Collapsed"
                Panel.ZIndex="15000"
                MouseDown="CommandPaletteOverlay_MouseDown">
            <components:CommandPalette x:Name="CommandPaletteControl"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Top"
                                  Margin="0,100,0,0"
                                  CommandExecuted="CommandPalette_CommandExecuted"/>
        </Border>

    </Grid>
</Window>
