<Window x:Class="NecessaryAdminTool.ConnectionProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connection Profiles" Height="550" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgDarkestBrush}" ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <!-- TAG: #VERSION_7 #CONNECTION_PROFILES #UI -->

    <Window.Resources>
        <!-- Local shadows removed — uses app-level DynamicResource brushes -->

        <!-- Primary Button Style -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentGradientBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource AccentOrangeBrush}"
                BorderThickness="0,0,0,2" Padding="16,12" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="🔗 CONNECTION PROFILES" Foreground="{DynamicResource AccentOrangeBrush}"
                           FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="Save and manage domain controller connections for quick switching"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Profile List -->
        <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderDimBrush}"
                BorderThickness="1" CornerRadius="6" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Saved Profiles" Foreground="White"
                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="➕ NEW" x:Name="BtnNewProfile" Click="BtnNewProfile_Click"
                                Style="{StaticResource BtnPrimary}" Padding="12,6" Margin="0,0,6,0"/>
                        <Button Content="✏️ EDIT" x:Name="BtnEditProfile" Click="BtnEditProfile_Click"
                                Background="{DynamicResource BgLightBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrightBrush}"
                                BorderThickness="1" Padding="12,6" FontSize="11" FontWeight="SemiBold"
                                Margin="0,0,6,0" IsEnabled="False"/>
                        <Button Content="🗑️ DELETE" x:Name="BtnDeleteProfile" Click="BtnDeleteProfile_Click"
                                Background="#FFCC3333" Foreground="White" BorderThickness="0"
                                Padding="12,6" FontSize="11" FontWeight="SemiBold" IsEnabled="False"/>
                    </StackPanel>
                </Grid>

                <!-- Profile DataGrid -->
                <DataGrid x:Name="GridProfiles" Grid.Row="1"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Background="{DynamicResource BgDarkBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BgLightBrush}"
                          BorderThickness="1" BorderBrush="{DynamicResource BorderDimBrush}"
                          HeadersVisibility="Column" SelectionMode="Single"
                          SelectionChanged="GridProfiles_SelectionChanged">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource BgLightBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentOrangeBrush}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderDimBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{DynamicResource BgDarkBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF252525"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentPrimarySelectionBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Env" Binding="{Binding EnvironmentIcon}" Width="40"/>
                        <DataGridTextColumn Header="Profile Name" Binding="{Binding Name}" Width="150"/>
                        <DataGridTextColumn Header="Domain Controller" Binding="{Binding DomainController}" Width="*" MinWidth="120"/>
                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="150"/>
                        <DataGridTextColumn Header="Environment" Binding="{Binding Environment}" Width="100"/>
                        <DataGridTextColumn Header="Last Used" Binding="{Binding LastUsedDate, StringFormat='{}{0:MM/dd/yyyy HH:mm}'}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Footer Buttons -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="💾 SAVE &amp; LOAD SELECTED" x:Name="BtnLoadProfile"
                    Click="BtnLoadProfile_Click" Style="{StaticResource BtnPrimary}"
                    Margin="0,0,8,0" IsEnabled="False"/>

            <Button Grid.Column="2" Content="CLOSE" x:Name="BtnClose" Click="BtnClose_Click"
                    Background="{DynamicResource BorderDimBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                    Padding="16,8" FontSize="11" FontWeight="SemiBold"/>
        </Grid>
    </Grid>
</Window>
