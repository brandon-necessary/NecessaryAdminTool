<Window x:Class="NecessaryAdminTool.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NecessaryAdminTool Options"
        Height="700" Width="800"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="#FF0D0D0D"
        ResizeMode="CanResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Match MainWindow color scheme -->
        <SolidColorBrush x:Key="BgDarkest" Color="#FF0D0D0D"/>
        <SolidColorBrush x:Key="BgDark" Color="#FF1A1A1A"/>
        <SolidColorBrush x:Key="BgCard" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="BorderDim" Color="#FF3C3C3C"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FFFF8533"/>
        <SolidColorBrush x:Key="AccentZinc" Color="#FFA1A1AA"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextMuted" Color="#FF888888"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#FF16C60C"/>
        <SolidColorBrush x:Key="DangerRed" Color="#FFE81123"/>

        <!-- Button Styles -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentOrange}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFF9944"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFDD6622"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#FF444444"/>
                                <Setter Property="Foreground" Value="#FF888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="{StaticResource DangerRed}"/>
        </Style>

        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource AccentZinc}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDim}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════ -->
        <!-- HEADER                           -->
        <!-- ════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource BgDark}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="30,0">
                    <TextBlock Text="⚙️ APPLICATION OPTIONS" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource AccentOrange}"/>
                    <TextBlock Text="Configure application settings and preferences"
                               FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- TAG: #TOOLTIPS #NAVIGATION -->
                <!-- Close Button -->
                <Button Grid.Column="1" Content="✕" Width="40" Height="40"
                        Margin="0,0,20,0" Click="BtnClose_Click"
                        Style="{StaticResource BtnGhost}" FontSize="18"
                        ToolTip="Closes the Options window without saving any changes. Use 'SAVE &amp; CLOSE' button to save before closing. (Esc)"/>
            </Grid>
        </Border>

        <!-- ════════════════════════════════ -->
        <!-- CONTENT (Scrollable)             -->
        <!-- ════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,20">

                <!-- Status Message (Hidden by default) -->
                <Border x:Name="StatusMessage" Background="{StaticResource BgCard}"
                        BorderBrush="{StaticResource AccentGreen}" BorderThickness="1"
                        CornerRadius="4" Padding="12,8" Margin="0,0,0,15"
                        Visibility="Collapsed">
                    <TextBlock x:Name="TxtStatusMessage" Foreground="{StaticResource AccentGreen}"
                               FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>

                <!-- ══════════════════════════════ -->
                <!-- SECTION 1: ADMIN TOOLS        -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderAdminTools" Header="🔧 ADMIN &amp; DEBUGGING TOOLS"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="ADMIN LAUNCHER SETUP" Foreground="{StaticResource AccentOrange}"
                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>

                            <!-- Create Shortcut Button - TAG: #ADMIN_TOOLS -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource AccentOrange}"
                                    BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,8"
                                    Cursor="Hand" MouseEnter="DebugButton_MouseEnter" MouseLeave="DebugButton_MouseLeave"
                                    MouseLeftButtonDown="CreateShortcut_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="🚀" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock x:Name="DebugButtonText" Text="Create Admin Launcher Shortcut"
                                                  Foreground="{StaticResource AccentOrange}" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Text="Creates a desktop shortcut to launch NecessaryAdminTool Suite as domain admin"
                                                  Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <TextBlock Text="ℹ️ This tool creates a secure launcher that remembers your admin credentials using Windows Credential Manager. Perfect for testing or if you accidentally deleted the shortcut."
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" LineHeight="14"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION 2: GENERAL SETTINGS   -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderGeneral" Header="⚙️ GENERAL SETTINGS"
                          IsExpanded="True" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <!-- Last Username -->
                            <TextBlock Text="Cached Username:" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                            <Grid Margin="0,4,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtLastUser" Grid.Column="0" IsReadOnly="True"
                                         Background="{StaticResource BgDark}" Foreground="White"
                                         BorderBrush="{StaticResource BorderDim}" Padding="8,6" FontSize="11"/>
                                <!-- TAG: #TOOLTIPS #ACTIONS -->
                                <Button Grid.Column="1" Content="CLEAR" Style="{StaticResource BtnDanger}"
                                        Click="BtnClearLastUser_Click" Margin="8,0,0,0" Padding="12,6" FontSize="10"
                                        IsTabStop="False"
                                        ToolTip="Clears the saved last user credential. Application will prompt for domain credentials on next Active Directory scan. Useful when switching between different domain accounts or troubleshooting authentication issues."/>
                            </Grid>

                            <!-- Remember DC Selection -->
                            <CheckBox x:Name="ChkRememberDC" Content="Remember Domain Controller selection"
                                      Foreground="White" FontSize="11" Margin="0,0,0,12"/>

                            <!-- TAG: #SECURITY #AUTHENTICATION #CREDENTIAL_STORAGE -->
                            <!-- Security &amp; Credential Settings -->
                            <TextBlock Text="Security &amp; Authentication:" Foreground="{StaticResource AccentOrange}"
                                       FontSize="10" FontWeight="Bold" Margin="0,8,0,8"/>

                            <!-- Remember Credentials -->
                            <CheckBox x:Name="ChkRememberCredentials"
                                      Content="Remember admin credentials between sessions"
                                      Foreground="White" FontSize="11" Margin="0,0,0,8"
                                      ToolTip="When enabled, credentials are securely stored in Windows Credential Manager (DPAPI-encrypted). When disabled, you'll need to re-enter credentials each time you launch the app. Credentials are tied to your Windows user account and cannot be accessed by other users."/>

                            <!-- Password Expiry Warnings -->
                            <CheckBox x:Name="ChkShowPasswordExpiryWarnings"
                                      Content="Show password expiration warnings"
                                      Foreground="White" FontSize="11" Margin="0,0,0,8"
                                      ToolTip="When enabled, you'll receive warnings when your password is approaching expiration. This helps prevent unexpected service interruptions."/>

                            <!-- Password Warning Days -->
                            <Grid Margin="20,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Warn when password expires within:"
                                           Foreground="{StaticResource TextMuted}" FontSize="10" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtPasswordWarningDays" Grid.Column="1"
                                         Background="{StaticResource BgDark}" Foreground="White"
                                         BorderBrush="{StaticResource BorderDim}" Padding="6,4" FontSize="10"
                                         Margin="8,0,8,0" HorizontalContentAlignment="Center"
                                         ToolTip="Number of days before password expiration to show warnings (1-90 days)"/>
                                <TextBlock Grid.Column="2" Text="days"
                                           Foreground="{StaticResource TextMuted}" FontSize="10" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Credential Storage Info -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="🔐 Credential Storage Information"
                                               Foreground="{StaticResource AccentOrange}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" FontSize="9" LineHeight="14">
                                        <Run Text="• Credentials are encrypted using Windows Data Protection API (DPAPI)"/>
                                        <LineBreak/>
                                        <Run Text="• Stored in Windows Credential Manager (same as RDP, Edge passwords)"/>
                                        <LineBreak/>
                                        <Run Text="• Location: Control Panel → Credential Manager → Windows Credentials"/>
                                        <LineBreak/>
                                        <Run Text="• Target Name: NecessaryAdminTool_*"/>
                                        <LineBreak/>
                                        <Run Text="• Only your Windows user account can access these credentials"/>
                                        <LineBreak/>
                                        <Run Text="• HIPAA/PCI compliant when using Windows enterprise policies"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- DC Health Display Settings - TAG: #DC_HEALTH #CONFIGURABLE_OPTIONS #DASHBOARD -->
                            <TextBlock Text="DC Health Widget Settings:" Foreground="{StaticResource AccentOrange}"
                                       FontSize="10" FontWeight="Bold" Margin="0,8,0,8"/>

                            <!-- Expand DC Health by Default -->
                            <CheckBox x:Name="ChkDCHealthExpanded" Content="Show expanded DC Health widget by default (6 cards)"
                                      Foreground="White" FontSize="11" Margin="0,0,0,8"
                                      ToolTip="When enabled, the DC Health widget on the dashboard will show 6 domain controllers by default. When disabled, it shows collapsed view with expand button."/>

                            <!-- Favorite DCs Info -->
                            <TextBlock Text="💡 To favorite a domain controller, click the star (⭐) button on its health card in the dashboard. Favorited DCs will be displayed first in the widget."
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,8" LineHeight="14"/>

                            <!-- Clear DC Preferences -->
                            <Button Content="RESET DC PREFERENCES" Style="{StaticResource BtnDanger}"
                                    Click="BtnResetDCPreferences_Click" Padding="12,6" FontSize="10"
                                    Margin="0,0,0,16"
                                    ToolTip="Resets all domain controller preferences including favorites, display order, and expansion state. The DC Health widget will return to default settings."/>

                            <!-- AD Query Method - TAG: #VERSION_7 #AD_QUERY_BACKEND_SELECTION #PERFORMANCE_AUDIT -->
                            <TextBlock Text="AD Query Method:" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox x:Name="ComboADQueryMethod" Margin="0,0,0,12"
                                      Background="{StaticResource BgDark}" Foreground="White"
                                      BorderBrush="{StaticResource BorderDim}" Padding="8,6" FontSize="11"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Content="DirectorySearcher (Fast)" Tag="DirectorySearcher" IsSelected="True"/>
                                <ComboBoxItem Content="ActiveDirectoryManager (Detailed)" Tag="ActiveDirectoryManager"/>
                            </ComboBox>
                            <TextBlock Text="💡 DirectorySearcher is faster for large environments. ActiveDirectoryManager provides richer AD object properties."
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="14"/>

                            <!-- Target History -->
                            <TextBlock Text="Recent Targets:" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,6"/>
                            <ListBox x:Name="ListTargetHistory" Height="120" Background="{StaticResource BgDark}"
                                     BorderBrush="{StaticResource BorderDim}" Foreground="White" FontSize="11" Margin="0,0,0,8"/>
                            <!-- TAG: #TOOLTIPS #ACTIONS -->
                            <Button Content="CLEAR HISTORY" Style="{StaticResource BtnDanger}"
                                    Click="BtnClearHistory_Click" Padding="12,6" FontSize="10"
                                    ToolTip="Clears all recent target computer names from history. This list is used for quick access to frequently scanned computers. Does not affect database records or bookmarks. History will rebuild as you scan new computers."/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION 3: GLOBAL SERVICES    -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderGlobalServices" Header="🌐 GLOBAL SERVICES CONFIGURATION"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Configure which cloud services to monitor for status and uptime. You can use the visual editor or edit the raw JSON configuration."
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="14"/>

                            <!-- TAG: #TOOLTIPS #CONFIGURATION -->
                            <!-- Tab Selector - TAG: #THEME_COLORS -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnVisualEditor" Content="📋 VISUAL EDITOR" Grid.Column="0"
                                        Background="{StaticResource AccentOrange}" Foreground="White" BorderThickness="0"
                                        Padding="8,6" FontSize="10" FontWeight="Bold" Margin="0,0,2,0"
                                        Click="BtnVisualEditor_Click" Cursor="Hand"
                                        ToolTip="Switches to visual editor mode with grid-based service configuration. Easier to use for adding, editing, and removing cloud services. Recommended for most users. Changes are synchronized with JSON editor."/>
                                <Button x:Name="BtnJsonEditor" Content="{}{} JSON EDITOR" Grid.Column="1"
                                        Background="#FF2A2A2A" Foreground="{StaticResource TextMuted}" BorderThickness="0"
                                        Padding="8,6" FontSize="10" FontWeight="Bold" Margin="2,0,0,0"
                                        Click="BtnJsonEditor_Click" Cursor="Hand"
                                        ToolTip="Switches to raw JSON editor mode for advanced users. Allows direct editing of service configuration JSON. Useful for bulk imports, complex configurations, or troubleshooting. Invalid JSON will be rejected on save."/>
                            </Grid>

                            <!-- Visual Editor Panel -->
                            <StackPanel x:Name="VisualEditorPanel" Margin="0,0,0,0">
                                <TextBlock Text="SERVICES LIST" Foreground="{StaticResource AccentOrange}"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>

                                <!-- Services DataGrid - TAG: #GLOBAL_SERVICES -->
                                <DataGrid x:Name="GridServicesConfig"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="True"
                                          CanUserDeleteRows="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          Background="{StaticResource BgCard}"
                                          Foreground="#FFE0E0E0"
                                          BorderBrush="{StaticResource BorderDim}"
                                          BorderThickness="1"
                                          RowBackground="#FF2A2A2A"
                                          AlternatingRowBackground="#FF252525"
                                          FontSize="10"
                                          Height="200"
                                          Margin="0,0,0,12">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="{StaticResource BgDark}"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="10"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AccentOrange}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FF353535"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#FF404040"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Service Name" Binding="{Binding ServiceName}" Width="140">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                                    <Setter Property="Padding" Value="4,2"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                                    <Setter Property="Background" Value="#FF1A1A1A"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentOrange}"/>
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="API Endpoint / IP" Binding="{Binding Endpoint}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                                    <Setter Property="Padding" Value="4,2"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                                    <Setter Property="Background" Value="#FF1A1A1A"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentOrange}"/>
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="💡 TIP: Use 'ping:IP' for simple ping checks (e.g., ping:8.8.8.8) or full HTTPS URLs for status APIs"
                                           Foreground="{StaticResource AccentOrange}" FontSize="8" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="12"/>
                            </StackPanel>

                            <!-- JSON Editor Panel -->
                            <StackPanel x:Name="JsonEditorPanel" Visibility="Collapsed">
                                <TextBlock Text="RAW JSON CONFIGURATION" Foreground="{StaticResource AccentOrange}"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>

                                <TextBox x:Name="TxtJsonConfig"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="{StaticResource BgDark}"
                                         Foreground="#FF00FF00"
                                         BorderBrush="{StaticResource BorderDim}"
                                         BorderThickness="1"
                                         Padding="10"
                                         FontFamily="Consolas"
                                         FontSize="9"
                                         Height="220"
                                         Margin="0,0,0,12"/>

                                <TextBlock Text="⚠️ JSON Format: [{}ServiceName:Azure, Endpoint:https://... (use editor above)]"
                                           Foreground="#FFFF6B6B" FontSize="8" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="12"/>
                            </StackPanel>

                            <!-- TAG: #TOOLTIPS #ACTIONS -->
                            <!-- Action Buttons -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="💾 SAVE" x:Name="BtnSaveServicesConfig"
                                        Background="#FF00C853" Foreground="White" BorderThickness="0"
                                        Padding="8,6" FontSize="10" FontWeight="Bold" Margin="0,0,3,0"
                                        Click="BtnSaveServicesConfig_Click" Cursor="Hand"
                                        ToolTip="Saves global services configuration to settings. Configuration is validated before saving. Invalid service URLs or missing API keys will trigger warnings. Changes apply immediately to status monitoring."/>
                                <Button Grid.Column="1" Content="🔄 RESET TO DEFAULTS" x:Name="BtnResetServicesConfig"
                                        Background="#FFFF6B6B" Foreground="White" BorderThickness="0"
                                        Padding="8,6" FontSize="9" FontWeight="Bold" Margin="1.5,0,1.5,0"
                                        Click="BtnResetServicesConfig_Click" Cursor="Hand"
                                        ToolTip="Resets global services configuration to factory defaults. All custom service configurations will be lost. Default configuration includes common cloud services (Microsoft 365, Azure, Google, AWS). You will be asked to confirm this action."/>
                                <Button Grid.Column="2" Content="🧪 TEST APIS" x:Name="BtnTestAPIs"
                                        Background="#FF2196F3" Foreground="White" BorderThickness="0"
                                        Padding="8,6" FontSize="10" FontWeight="Bold" Margin="3,0,0,0"
                                        Click="BtnTestAPIs_Click" Cursor="Hand"
                                        ToolTip="Tests connectivity to all configured cloud service APIs. Verifies API keys, endpoints, and network connectivity. Results show response time and status for each service. Useful for troubleshooting configuration issues."/>
                            </Grid>

                            <TextBlock x:Name="TxtConfigStatus" Text="" Foreground="#FF00FF00"
                                       FontSize="9" FontWeight="Bold" Margin="0,8,0,0"
                                       HorizontalAlignment="Center" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION 4: PINNED DEVICES     -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderPinnedDevices" Header="📌 PINNED DEVICES MANAGEMENT"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Manage devices pinned for quick status monitoring (max 10)"
                                       Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,0,0,12"/>

                            <!-- Pinned Devices DataGrid -->
                            <DataGrid x:Name="GridPinnedDevicesManager" AutoGenerateColumns="False"
                                      CanUserAddRows="False" Height="200" Margin="0,0,0,12"
                                      Background="{StaticResource BgDark}"
                                      Foreground="#FFE0E0E0"
                                      BorderBrush="{StaticResource BorderDim}"
                                      BorderThickness="1"
                                      RowBackground="#FF2A2A2A"
                                      AlternatingRowBackground="#FF252525"
                                      FontSize="10"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource BgDark}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentOrange}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FF353535"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#FF404040"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Device" Binding="{Binding Input}" Width="*" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Last Checked" Binding="{Binding LastChecked}" Width="120" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- TAG: #TOOLTIPS #FILE_OPERATIONS -->
                                <!-- First Row: Import/Template buttons -->
                                <Button Grid.Row="0" Grid.Column="0" Content="📥 IMPORT FROM CSV" Style="{StaticResource BtnPrimary}"
                                        Click="BtnImportPinnedCsv_Click" Padding="12,6" FontSize="10" Margin="0,0,0,8"
                                        ToolTip="Imports pinned devices from a CSV file. CSV format: ComputerName,IPAddress,Description. Useful for bulk pinning computers from network scans or asset lists. Duplicate entries will be merged. Download template for correct format."/>
                                <Button Grid.Row="0" Grid.Column="1" Content="📋 DOWNLOAD TEMPLATE" Style="{StaticResource BtnGhost}"
                                        Click="BtnDownloadTemplate_Click" Margin="8,0,0,8" Padding="12,6" FontSize="10"
                                        ToolTip="Downloads a CSV template file with correct column headers and sample data. Use this template as a starting point for bulk importing pinned devices. Open in Excel or text editor to populate with your computer list."/>

                                <!-- Second Row: Clear/Export buttons -->
                                <!-- TAG: #TOOLTIPS #ACTIONS -->
                                <Button Grid.Row="1" Grid.Column="0" Content="CLEAR ALL PINNED DEVICES" Style="{StaticResource BtnDanger}"
                                        Click="BtnClearAllPinned_Click" Padding="12,6" FontSize="10"
                                        ToolTip="Removes ALL pinned devices from the list. This action is permanent and cannot be undone. Export to CSV first if you want to keep a backup. Pinned devices provide quick access to frequently managed computers."/>
                                <Button Grid.Row="1" Grid.Column="1" Content="📤 EXPORT TO CSV" Style="{StaticResource BtnGhost}"
                                        Click="BtnExportPinned_Click" Margin="8,0,0,0" Padding="12,6" FontSize="10"
                                        ToolTip="Exports all pinned devices to a CSV file for backup or migration. File includes computer names, IP addresses, and descriptions. Can be imported into another installation or edited and re-imported."/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION 5: PERFORMANCE        -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderPerformance" Header="🔧 PERFORMANCE &amp; THREADING"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Column -->
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <!-- Max Parallel Scans -->
                                <TextBlock Text="Max Parallel Scans:" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <Grid Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SliderMaxParallel" Grid.Column="0" Minimum="1" Maximum="100"
                                            Value="30" TickFrequency="10" IsSnapToTickEnabled="False"
                                            ValueChanged="SliderMaxParallel_ValueChanged"/>
                                    <TextBox x:Name="TxtMaxParallel" Grid.Column="1" Text="30" TextAlignment="Center"
                                             Background="{StaticResource BgDark}" Foreground="White"
                                             BorderBrush="{StaticResource BorderDim}" Padding="4" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- WMI Timeout -->
                                <TextBlock Text="WMI Timeout (ms):" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <TextBox x:Name="TxtWmiTimeout" Text="15000" Margin="0,4,0,12"
                                         Background="{StaticResource BgDark}" Foreground="White"
                                         BorderBrush="{StaticResource BorderDim}" Padding="8,6"/>
                            </StackPanel>

                            <!-- Right Column -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <!-- Ping Timeout -->
                                <TextBlock Text="Ping Timeout (ms):" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <TextBox x:Name="TxtPingTimeout" Text="1200" Margin="0,4,0,12"
                                         Background="{StaticResource BgDark}" Foreground="White"
                                         BorderBrush="{StaticResource BorderDim}" Padding="8,6"/>

                                <!-- Max Retry Attempts -->
                                <TextBlock Text="Max Retry Attempts:" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <TextBox x:Name="TxtMaxRetry" Text="3" Margin="0,4,0,12"
                                         Background="{StaticResource BgDark}" Foreground="White"
                                         BorderBrush="{StaticResource BorderDim}" Padding="8,6"/>

                                <!-- TAG: #TOOLTIPS #ACTIONS -->
                                <!-- Cache Cleanup - TAG: #VERSION_7 #CACHE #PERFORMANCE_AUDIT -->
                                <TextBlock Text="Failure Cache:" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,8,0,4"/>
                                <Button Content="🗑 CLEAR FAILURE CACHE" Style="{StaticResource BtnGhost}"
                                        Click="BtnClearFailureCache_Click" Padding="12,6" FontSize="10" HorizontalAlignment="Stretch"
                                        ToolTip="Clears the cache of computers that previously failed WMI or network connectivity checks. After clearing, all computers will be re-tested on next scan. Cache automatically sizes based on domain size (2× computer count, max 10,000 entries). Useful after network changes or troubleshooting connectivity issues."/>
                                <TextBlock Text="💡 Cache automatically sizes based on AD computer count (2× limit, max 10000)"
                                           Foreground="{StaticResource TextMuted}" FontSize="8" TextWrapping="Wrap" Margin="0,4,0,0" LineHeight="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION 6: APPEARANCE         -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderAppearance" Header="🎨 APPEARANCE &amp; BRANDING"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Column: Logo & Colors -->
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <!-- Custom Logo - TAG: #LOGO_PLACEMENT #BRANDING -->
                                <TextBlock Text="Custom Logo:" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold"/>
                                <Grid Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtLogoPath" Grid.Column="0" IsReadOnly="True"
                                             Background="{StaticResource BgDark}" Foreground="White"
                                             BorderBrush="{StaticResource BorderDim}" Padding="8,6" FontSize="10"
                                             Text="(Using default NecessaryAdmin logo)"/><!-- TAG: #DYNAMIC_BRANDING -->
                                    <!-- TAG: #TOOLTIPS #FILE_OPERATIONS -->
                                    <Button Grid.Column="1" Content="BROWSE" Style="{StaticResource BtnPrimary}"
                                            Click="BtnBrowseLogo_Click" Margin="8,0,0,0" Padding="12,6" FontSize="10"
                                            ToolTip="Browse for a custom logo image file (PNG, JPG, BMP). Logo appears in the About window and main title bar. Recommended size: 200x50 pixels. Leave empty to use default NecessaryAdminTool branding. Changes apply immediately."/>
                                </Grid>

                                <!-- Logo Preview -->
                                <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                        BorderThickness="1" Padding="10" Margin="0,0,0,12" Height="80">
                                    <Viewbox x:Name="LogoPreview" Stretch="Uniform" HorizontalAlignment="Center">
                                        <TextBlock Text="A" FontSize="48" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentOrange}"/>
                                    </Viewbox>
                                </Border>

                                <!-- Logo Size -->
                                <TextBlock Text="Logo Size:" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <Grid Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SliderLogoSize" Grid.Column="0" Minimum="32" Maximum="128"
                                            Value="64" TickFrequency="16" IsSnapToTickEnabled="False"/>
                                    <TextBox x:Name="TxtLogoSize" Grid.Column="1" Text="64" TextAlignment="Center"
                                             Background="{StaticResource BgDark}" Foreground="White"
                                             BorderBrush="{StaticResource BorderDim}" Padding="4" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- Primary Accent Color - TAG: #THEME_COLORS -->
                                <TextBlock Text="Primary Accent Color (Orange):" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <Grid Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="PrimaryColorPreview" Grid.Column="0" Width="40" Height="30"
                                            Background="#FFFF8533" BorderBrush="{StaticResource BorderDim}"
                                            BorderThickness="1" Margin="0,0,8,0" Cursor="Hand"
                                            MouseLeftButtonDown="PrimaryColorPreview_Click"
                                            ToolTip="Click to open color picker"/>
                                    <TextBox x:Name="TxtPrimaryColor" Grid.Column="1" Text="#FFFF8533"
                                             Background="{StaticResource BgDark}" Foreground="White"
                                             BorderBrush="{StaticResource BorderDim}" Padding="8,6" FontSize="10"
                                             TextChanged="TxtPrimaryColor_TextChanged"/>
                                </Grid>

                                <!-- Secondary Accent Color -->
                                <TextBlock Text="Secondary Accent Color (Zinc):" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <Grid Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="SecondaryColorPreview" Grid.Column="0" Width="40" Height="30"
                                            Background="#FFA1A1AA" BorderBrush="{StaticResource BorderDim}"
                                            BorderThickness="1" Margin="0,0,8,0" Cursor="Hand"
                                            MouseLeftButtonDown="SecondaryColorPreview_Click"
                                            ToolTip="Click to open color picker"/>
                                    <TextBox x:Name="TxtSecondaryColor" Grid.Column="1" Text="#FFA1A1AA"
                                             Background="{StaticResource BgDark}" Foreground="White"
                                             BorderBrush="{StaticResource BorderDim}" Padding="8,6" FontSize="10"
                                             TextChanged="TxtSecondaryColor_TextChanged"/>
                                </Grid>
                            </StackPanel>

                            <!-- Right Column: Preview & Actions -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <!-- Preview Panel -->
                                <TextBlock Text="Preview:" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold"/>
                                <Border Background="{StaticResource BgDarkest}" BorderBrush="{StaticResource BorderDim}"
                                        BorderThickness="1" Padding="15" Margin="0,4,0,12" Height="200">
                                    <StackPanel>
                                        <!-- TAG: #DYNAMIC_BRANDING - Preview uses static text (OK for preview) -->
                                        <TextBlock Text="NecessaryAdmin" FontSize="18" FontWeight="Bold" Margin="0,0,0,8">
                                            <TextBlock.Foreground>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop x:Name="PreviewPrimaryStop" Color="#FFFF8533" Offset="0"/>
                                                    <GradientStop x:Name="PreviewSecondaryStop" Color="#FFA1A1AA" Offset="0.7"/>
                                                </LinearGradientBrush>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                        <TextBlock Text="I T   M A N A G E M E N T   S U I T E" FontSize="7"
                                                   Foreground="{StaticResource AccentOrange}" FontWeight="Bold" Opacity="0.8"/>
                                        <Border Height="1" Background="{StaticResource BorderDim}" Margin="0,10"/>
                                        <Button Content="Sample Button" Padding="12,6" FontSize="11" Margin="0,10,0,0">
                                            <Button.Background>
                                                <SolidColorBrush x:Name="PreviewButtonBg" Color="#FFFF8533"/>
                                            </Button.Background>
                                            <Button.Foreground>
                                                <SolidColorBrush Color="White"/>
                                            </Button.Foreground>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <!-- Font Settings -->
                                <TextBlock Text="Font Family:" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <ComboBox x:Name="CmbFontFamily" Margin="0,4,0,12"
                                          Background="{StaticResource BgDark}" Foreground="White"
                                          BorderBrush="{StaticResource BorderDim}" Padding="8,6" FontSize="10">
                                    <ComboBoxItem Content="Segoe UI (Default)" IsSelected="True"/>
                                    <ComboBoxItem Content="Arial"/>
                                    <ComboBoxItem Content="Calibri"/>
                                    <ComboBoxItem Content="Consolas"/>
                                    <ComboBoxItem Content="Courier New"/>
                                </ComboBox>

                                <!-- TAG: #TOOLTIPS #ACTIONS -->
                                <!-- Action Buttons -->
                                <Button Content="🔄 RESET TO DEFAULTS" Style="{StaticResource BtnDanger}"
                                        Click="BtnResetAppearance_Click" Padding="12,8" FontSize="10" Margin="0,20,0,0"
                                        ToolTip="Resets all appearance settings to factory defaults. This includes primary accent color (Orange #FF8533), secondary accent color (Zinc #A1A1AA), custom logo path, and font family. Changes apply immediately to all windows. Theme engine uses 35+ resource keys."/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION: FONT SIZE - TAG: #VERSION_7 #QUICK_WINS -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderFontSize" Header="🔤 FONT SIZE"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Adjust the font size multiplier for the entire application (0.8x - 2.0x)"
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="14"/>

                            <!-- Font Size Slider -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Font Size:" Foreground="White" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>

                                <Slider x:Name="SliderFontSize" Grid.Column="1" Minimum="0.8" Maximum="2.0"
                                        Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                        ValueChanged="SliderFontSize_ValueChanged"
                                        VerticalAlignment="Center"/>

                                <TextBlock x:Name="TxtFontSizeValue" Grid.Column="2" Text="1.0x" FontWeight="Bold"
                                           Foreground="{StaticResource AccentOrange}" FontSize="12"
                                           VerticalAlignment="Center" Margin="12,0,0,0" MinWidth="50"/>
                            </Grid>

                            <!-- Preview Text -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                <TextBlock x:Name="TxtFontPreview" Text="The quick brown fox jumps over the lazy dog. 0123456789"
                                           Foreground="White" FontSize="12" TextWrapping="Wrap"/>
                            </Border>

                            <!-- TAG: #TOOLTIPS #ACTIONS -->
                            <!-- Action Buttons -->
                            <StackPanel Orientation="Horizontal">
                                <Button Content="✓ APPLY" Style="{StaticResource BtnPrimary}"
                                        Click="BtnApplyFontSize_Click" Padding="12,6" FontSize="10" Margin="0,0,8,0"
                                        ToolTip="Applies the selected font size multiplier to the entire application. Changes affect all windows, buttons, text, and UI elements. Range: 0.8x (smaller) to 2.0x (larger). Default: 1.0x. Changes apply immediately without restart."/>
                                <Button Content="↺ RESET TO DEFAULT (1.0x)" Style="{StaticResource BtnGhost}"
                                        Click="BtnResetFontSize_Click" Padding="12,6" FontSize="10"
                                        ToolTip="Resets font size multiplier to default value (1.0x). Restores standard font sizes across the entire application. Changes apply immediately."/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION: AUTO-SAVE - TAG: #VERSION_7 #QUICK_WINS -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderAutoSave" Header="💾 AUTO-SAVE &amp; BACKUP"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Automatically save inventory backups at regular intervals. Backups are stored in %AppData%\NecessaryAdminTool\AutoSave\"
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="14"/>

                            <!-- Enable/Disable Auto-Save -->
                            <CheckBox x:Name="ChkAutoSaveEnabled" Content="Enable automatic backups"
                                      Foreground="White" FontSize="11" Margin="0,0,0,12"
                                      Checked="ChkAutoSaveEnabled_Changed" Unchecked="ChkAutoSaveEnabled_Changed"/>

                            <!-- Interval Setting -->
                            <StackPanel x:Name="PanelAutoSaveSettings" Margin="0,0,0,12">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Save interval:" Foreground="White" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBox x:Name="TxtAutoSaveInterval" Grid.Column="1" Text="5"
                                             Background="{StaticResource BgDark}" Foreground="White"
                                             BorderBrush="{StaticResource BorderDim}" Padding="8,6" FontSize="11"/>
                                    <TextBlock Grid.Column="2" Text="minutes (1-60)" Foreground="{StaticResource TextMuted}" FontSize="11"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>

                                <TextBlock Text="💡 Backups are automatically cleaned up (last 10 kept)"
                                           Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,0,0,0"/>
                            </StackPanel>

                            <!-- Manual Backup Button -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Manual Backup" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="Create a backup of the current inventory right now"
                                                   Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- TAG: #TOOLTIPS #FILE_OPERATIONS -->
                                    <Button Grid.Column="1" Content="💾 BACKUP NOW" Style="{StaticResource BtnPrimary}"
                                            Click="BtnManualBackup_Click" Padding="12,6" FontSize="10"
                                            ToolTip="Creates an immediate backup of the current database inventory. Backup is saved with timestamp in backup folder. Useful before major changes, bulk imports, or testing. Automatic cleanup keeps last 10 backups. Does not interfere with auto-save schedule."/>
                                </Grid>
                            </Border>

                            <!-- TAG: #TOOLTIPS #FILE_OPERATIONS -->
                            <!-- View Backups Button -->
                            <Button Content="📂 OPEN BACKUP FOLDER" Style="{StaticResource BtnGhost}"
                                    Click="BtnOpenBackupFolder_Click" Padding="12,6" FontSize="10" HorizontalAlignment="Left"
                                    ToolTip="Opens Windows Explorer to the backup folder location. View all automatic and manual backup files sorted by timestamp. Backup folder: %APPDATA%\NecessaryAdminTool\Backups\. Last 10 backups are automatically retained."/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION: CONNECTION PROFILES - TAG: #VERSION_7 #CONNECTION_PROFILES -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderConnectionProfiles" Header="🔌 CONNECTION PROFILES"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Save frequently used domain controller configurations for quick access"
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="14"/>

                            <!-- Profiles List -->
                            <DataGrid x:Name="GridConnectionProfiles" AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="{StaticResource BgDark}" Foreground="#FFE0E0E0"
                                      BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                                      RowBackground="#FF1A1A1A" AlternatingRowBackground="#FF151515"
                                      FontSize="10" Height="180" Margin="0,0,0,12">

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource BgDark}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </DataGrid.CellStyle>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Profile Name" Binding="{Binding ProfileName}" Width="150"/>
                                    <DataGridTextColumn Header="Domain/Server" Binding="{Binding ServerAddress}" Width="200"/>
                                    <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="150"/>
                                    <DataGridTemplateColumn Header="Actions" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <!-- TAG: #TOOLTIPS #CONNECTION_PROFILES -->
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="✓ LOAD" Tag="{Binding}" Background="#FF16C60C" Foreground="White"
                                                            BorderThickness="0" Padding="10,4" Margin="0,0,8,0" FontSize="9"
                                                            Click="BtnLoadProfile_Click" Cursor="Hand"
                                                            ToolTip="Loads this connection profile as the active configuration. Sets domain/server address and username for Active Directory scans. Credentials are securely stored in Windows Credential Manager. Changes apply immediately."/>
                                                    <Button Content="✏ EDIT" Tag="{Binding}" Background="#FF2A2A2A" Foreground="White"
                                                            BorderThickness="0" Padding="10,4" Margin="0,0,8,0" FontSize="9"
                                                            Click="BtnEditProfile_Click" Cursor="Hand"
                                                            ToolTip="Opens dialog to edit this connection profile. Modify profile name, server/domain address, or username. Password can be updated separately via Windows Credential Manager. Changes are saved immediately."/>
                                                    <Button Content="🗑 DELETE" Tag="{Binding}" Background="{StaticResource DangerRed}" Foreground="White"
                                                            BorderThickness="0" Padding="10,4" FontSize="9"
                                                            Click="BtnDeleteProfile_Click" Cursor="Hand"
                                                            ToolTip="Permanently deletes this connection profile. Associated credentials are removed from Windows Credential Manager. This action cannot be undone. You will be asked to confirm."/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Add New Profile -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Add New Profile"
                                               Foreground="{StaticResource AccentOrange}" FontSize="11" FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Profile Name:" Foreground="White" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,8,4"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtNewProfileName"
                                             Background="#FF0D0D0D" Foreground="White" BorderBrush="{StaticResource BorderDim}"
                                             Padding="6,4" FontSize="10" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Server/Domain:" Foreground="White" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,8,4"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtNewProfileServer"
                                             Background="#FF0D0D0D" Foreground="White" BorderBrush="{StaticResource BorderDim}"
                                             Padding="6,4" FontSize="10" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Username:" Foreground="White" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtNewProfileUsername"
                                             Background="#FF0D0D0D" Foreground="White" BorderBrush="{StaticResource BorderDim}"
                                             Padding="6,4" FontSize="10"/>
                                </Grid>
                            </Border>

                            <!-- TAG: #TOOLTIPS #CONNECTION_PROFILES -->
                            <!-- Add Button -->
                            <Button Content="➕ ADD PROFILE" Style="{StaticResource BtnPrimary}"
                                    Click="BtnAddProfile_Click" Padding="12,6" FontSize="10" HorizontalAlignment="Left"
                                    ToolTip="Creates a new connection profile with the information entered above. Profiles store domain/server address and username for quick switching between different Active Directory environments. Credentials are securely stored in Windows Credential Manager. Requires all fields to be filled."/>

                            <TextBlock Text="💡 Profiles are stored locally. Credentials are saved securely in Windows Credential Manager."
                                       Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,12,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION: BOOKMARKS/FAVORITES - TAG: #VERSION_7 #BOOKMARKS -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderBookmarks" Header="⭐ BOOKMARKS / FAVORITES"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Save frequently accessed servers and devices for quick access"
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="14"/>

                            <!-- Bookmarks List -->
                            <DataGrid x:Name="GridBookmarks" AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="{StaticResource BgDark}" Foreground="#FFE0E0E0"
                                      BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                                      RowBackground="#FF1A1A1A" AlternatingRowBackground="#FF151515"
                                      FontSize="10" Height="200" Margin="0,0,0,12">

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource BgDark}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </DataGrid.CellStyle>

                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="⭐" Width="30">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="⭐" FontSize="12" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="150"/>
                                    <DataGridTextColumn Header="Hostname/IP" Binding="{Binding Hostname}" Width="150"/>
                                    <DataGridTextColumn Header="Folder" Binding="{Binding Folder}" Width="100"/>
                                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                                    <DataGridTemplateColumn Header="Actions" Width="180">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <!-- TAG: #TOOLTIPS #BOOKMARKS -->
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="📋 COPY" Tag="{Binding}" Background="#FF2A2A2A" Foreground="White"
                                                            BorderThickness="0" Padding="8,4" Margin="0,0,6,0" FontSize="9"
                                                            Click="BtnCopyBookmark_Click" Cursor="Hand"
                                                            ToolTip="Copies the computer name/hostname to clipboard for quick use in other applications or search boxes. Does not modify the bookmark."/>
                                                    <Button Content="✏ EDIT" Tag="{Binding}" Background="#FF2A2A2A" Foreground="White"
                                                            BorderThickness="0" Padding="8,4" Margin="0,0,6,0" FontSize="9"
                                                            Click="BtnEditBookmark_Click" Cursor="Hand"
                                                            ToolTip="Opens dialog to edit this bookmark. Modify display name, hostname/IP, folder organization, or notes. Changes are saved immediately and sync across all devices using the same database."/>
                                                    <Button Content="🗑 DELETE" Tag="{Binding}" Background="{StaticResource DangerRed}" Foreground="White"
                                                            BorderThickness="0" Padding="8,4" FontSize="9"
                                                            Click="BtnDeleteBookmark_Click" Cursor="Hand"
                                                            ToolTip="Permanently deletes this bookmark. This action cannot be undone. The actual computer record in the database is not affected - only the bookmark reference is removed. You will be asked to confirm."/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Add New Bookmark -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Add New Bookmark"
                                               Foreground="{StaticResource AccentOrange}" FontSize="11" FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Display Name:" Foreground="White" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,8,4"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtNewBookmarkName"
                                             Background="#FF0D0D0D" Foreground="White" BorderBrush="{StaticResource BorderDim}"
                                             Padding="6,4" FontSize="10" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Hostname/IP:" Foreground="White" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,8,4"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtNewBookmarkHost"
                                             Background="#FF0D0D0D" Foreground="White" BorderBrush="{StaticResource BorderDim}"
                                             Padding="6,4" FontSize="10" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Folder (optional):" Foreground="White" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,8,4"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtNewBookmarkFolder"
                                             Background="#FF0D0D0D" Foreground="White" BorderBrush="{StaticResource BorderDim}"
                                             Padding="6,4" FontSize="10" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Notes (optional):" Foreground="White" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtNewBookmarkNotes"
                                             Background="#FF0D0D0D" Foreground="White" BorderBrush="{StaticResource BorderDim}"
                                             Padding="6,4" FontSize="10"/>
                                </Grid>
                            </Border>

                            <!-- TAG: #TOOLTIPS #BOOKMARKS -->
                            <!-- Add Button -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="➕ ADD BOOKMARK" Style="{StaticResource BtnPrimary}"
                                        Click="BtnAddBookmark_Click" Padding="12,6" FontSize="10" Margin="0,0,8,0"
                                        ToolTip="Opens dialog to create a new bookmark. Bookmarks provide quick access to frequently used computers. Add computer name, optional description, and organize into folders. Bookmarks sync across all devices using the same database."/>
                                <Button Content="📂 IMPORT FROM CSV" Style="{StaticResource BtnGhost}"
                                        Click="BtnImportBookmarks_Click" Padding="12,6" FontSize="10" Margin="0,0,8,0"
                                        ToolTip="Imports bookmarks from a CSV file. CSV format: ComputerName,Description,Folder. Useful for bulk bookmark creation or migration from other systems. Duplicate bookmarks will be skipped. Click 'Download Template' to get sample CSV format."/>
                                <Button Content="📤 EXPORT TO CSV" Style="{StaticResource BtnGhost}"
                                        Click="BtnExportBookmarks_Click" Padding="12,6" FontSize="10"
                                        ToolTip="Exports all bookmarks to a CSV file for backup or migration. File includes computer names, descriptions, and folder organization. Can be imported into another installation or edited in Excel and re-imported."/>
                            </StackPanel>

                            <TextBlock Text="💡 Use folders to organize bookmarks (e.g., 'Production', 'Development', 'Critical')"
                                       Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,0,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION 7: DATABASE MANAGEMENT - TAG: #VERSION_1_2 #DATABASE -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderDatabase" Header="💾 DATABASE MANAGEMENT"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Manage persistent storage of computer inventory data"
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="14"/>

                            <!-- Current Configuration -->
                            <TextBlock Text="CURRENT CONFIGURATION" Foreground="{StaticResource AccentOrange}"
                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Database Type:" Foreground="{StaticResource TextMuted}"
                                           FontSize="10" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtDbType" Text="SQLite (AES-256 Encrypted)"
                                           Foreground="White" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Location:" Foreground="{StaticResource TextMuted}"
                                           FontSize="10" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtDbPath" Text="C:\ProgramData\NecessaryAdminTool"
                                           Foreground="White" FontSize="10" TextWrapping="Wrap"/>
                            </Grid>

                            <!-- Database Statistics -->
                            <TextBlock Text="DATABASE STATISTICS" Foreground="{StaticResource AccentOrange}"
                                       FontSize="10" FontWeight="Bold" Margin="0,12,0,8"/>

                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Total Computers -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="💻" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtDbComputers" Text="0" FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentOrange}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Computers" FontSize="9" Foreground="{StaticResource TextMuted}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Total Scans -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="🔍" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtDbScans" Text="0" FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentOrange}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Scans" FontSize="9" Foreground="{StaticResource TextMuted}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Total Scripts -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="📜" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtDbScripts" Text="0" FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentOrange}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Scripts" FontSize="9" Foreground="{StaticResource TextMuted}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Database Size -->
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="💾" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtDbSize" Text="0 MB" FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentOrange}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Size" FontSize="9" Foreground="{StaticResource TextMuted}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Database Actions -->
                            <TextBlock Text="DATABASE ACTIONS" Foreground="{StaticResource AccentOrange}"
                                       FontSize="10" FontWeight="Bold" Margin="0,12,0,8"/>

                            <!-- Refresh Stats -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Refresh Statistics" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="Update the database statistics shown above"
                                                   Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- TAG: #TOOLTIPS #ACTIONS -->
                                    <Button Grid.Column="1" Content="🔄 REFRESH" Style="{StaticResource BtnPrimary}"
                                            Click="BtnRefreshDbStats_Click" Padding="12,6" FontSize="10"
                                            ToolTip="Refreshes database statistics displayed above, including total records, file size, last modified date, and connection status. Useful after bulk imports or data changes. (F5)"/>
                                </Grid>
                            </Border>

                            <!-- Backup Database -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Backup Database" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="Create a complete backup of the database"
                                                   Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- TAG: #TOOLTIPS #FILE_OPERATIONS -->
                                    <Button Grid.Column="1" Content="💾 BACKUP" Style="{StaticResource BtnPrimary}"
                                            Click="BtnBackupDatabase_Click" Padding="12,6" FontSize="10"
                                            ToolTip="Creates a complete backup copy of the database file with timestamp. Backup is saved to the same directory as the database with .backup extension. Recommended before major changes, updates, or migrations. Database can be backed up while in use."/>
                                </Grid>
                            </Border>

                            <!-- Restore Database -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Restore Database" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="Restore database from a backup file"
                                                   Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- TAG: #TOOLTIPS #FILE_OPERATIONS -->
                                    <Button Grid.Column="1" Content="📂 RESTORE" Style="{StaticResource BtnGhost}"
                                            Click="BtnRestoreDatabase_Click" Padding="12,6" FontSize="10"
                                            ToolTip="Restores database from a previously created backup file. This will OVERWRITE the current database with the backup data. All current data will be lost. Application will close and restart after restore. ALWAYS backup current database first!"/>
                                </Grid>
                            </Border>

                            <!-- Optimize Database -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Optimize/Vacuum Database" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="Reclaim disk space and improve performance"
                                                   Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- TAG: #TOOLTIPS #ACTIONS -->
                                    <Button Grid.Column="1" Content="⚡ OPTIMIZE" Style="{StaticResource BtnGhost}"
                                            Click="BtnOptimizeDatabase_Click" Padding="12,6" FontSize="10"
                                            ToolTip="Runs VACUUM command to reclaim unused disk space and rebuild internal indexes. Improves query performance and reduces file size after bulk deletions. For SQLite databases only. May take several minutes for large databases. Database is locked during optimization."/>
                                </Grid>
                            </Border>

                            <!-- Re-run Setup Wizard -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Change Database Configuration" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="Re-run the setup wizard to change database type or location"
                                                   Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- TAG: #TOOLTIPS #CONFIGURATION -->
                                    <Button Grid.Column="1" Content="🔧 RECONFIGURE" Style="{StaticResource BtnGhost}"
                                            Click="BtnRerunSetup_Click" Padding="12,6" FontSize="10"
                                            ToolTip="Re-runs the database setup wizard to change database type (SQLite/SQL Server/Access) or file location. Current database will remain unchanged but new connection will be used. Application will close and restart to complete reconfiguration. Backup database before changing!"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="⚠️ Always backup your database before making configuration changes"
                                       Foreground="{StaticResource DangerRed}" FontSize="9" Margin="0,8,0,0" TextWrapping="Wrap"/>

                            <!-- TAG: #FIRST_RUN_RESET - Reset setup wizard flag -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Reset Database Setup" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="Re-run the database setup wizard (you can choose to restart immediately or manually)"
                                                   Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <Button x:Name="BtnResetSetup" Grid.Column="1" VerticalAlignment="Center"
                                            Content="🔄 Reset Setup" Click="BtnResetSetup_Click"
                                            Background="{StaticResource AccentOrangeBrush}" Foreground="White"
                                            Padding="12,6" FontSize="10" FontWeight="SemiBold"
                                            ToolTip="Reset first-run flag and restart to launch setup wizard"/>
                                </Grid>
                            </Border>

                            <!-- TAG: #CONFIGURABLE_OPTIONS #DEPLOYMENT #POWERSHELL_SCRIPTS -->
                            <!-- Deployment Configuration -->
                            <TextBlock Text="DEPLOYMENT CONFIGURATION" Foreground="{StaticResource AccentOrange}"
                                       FontSize="10" FontWeight="Bold" Margin="0,20,0,8"/>

                            <!-- Deployment Log Directory -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Deployment Log Directory" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="Network or local path for PowerShell deployment script logs (e.g., \\server\share\Logs)"
                                               Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,2,0,8"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="TxtLogDirectory" Grid.Column="0"
                                                 Background="{StaticResource BgLight}" Foreground="White"
                                                 BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                                                 Padding="8,6" FontSize="10" Margin="0,0,8,0"
                                                 ToolTip="Directory where PowerShell deployment scripts save update logs. Defaults to database directory + '\DeploymentLogs'. Leave empty to use local temp directory with automatic fallback if network unavailable."/>

                                        <!-- TAG: #TOOLTIPS #FILE_OPERATIONS -->
                                        <Button Grid.Column="1" Content="📁" Width="36" Height="32"
                                                Background="{StaticResource BgLight}" Foreground="{StaticResource AccentOrange}"
                                                BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                                                Click="BtnBrowseLogDir_Click" FontSize="14"
                                                ToolTip="Opens folder browser to select deployment log directory. Choose a network share for centralized logging or local path for single-machine scenarios."/>
                                    </Grid>

                                    <TextBlock Text="💡 Scripts will automatically fall back to local logging if network path is unavailable."
                                               Foreground="{StaticResource AccentOrange}" FontSize="8" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Windows Update ISO Path -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Windows Update ISO Path" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="Network path or local path to Windows Feature Update ISO (e.g., \\server\share\Win11.iso)"
                                               Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,2,0,8"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="TxtISOPath" Grid.Column="0"
                                                 Background="{StaticResource BgLight}" Foreground="White"
                                                 BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                                                 Padding="8,6" FontSize="10" Margin="0,0,8,0"
                                                 ToolTip="Path to Windows Feature Update ISO file for offline/local upgrades. Leave empty to use cloud-based Windows Update (downloads directly from Microsoft). Network paths (\\server\share) are recommended for fleet deployments."/>

                                        <!-- TAG: #TOOLTIPS #FILE_OPERATIONS -->
                                        <Button Grid.Column="1" Content="📁" Width="36" Height="32"
                                                Background="{StaticResource BgLight}" Foreground="{StaticResource AccentOrange}"
                                                BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                                                Click="BtnBrowseISO_Click" FontSize="14"
                                                ToolTip="Opens file browser to select Windows Update ISO file (.iso). Typically used for Feature Updates (e.g., Windows 11 version upgrades). ISO path is passed to PowerShell scripts via environment variables."/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Local ISO Hostname Pattern -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Local ISO Deployment Pattern" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="Configure which computers use local ISO vs cloud update based on hostname"
                                               Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,2,0,8"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="If hostname" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,0,8,0"/>

                                        <ComboBox x:Name="CmbHostnameMatchMode" Grid.Column="1"
                                                  Background="{StaticResource BgLight}" Foreground="White"
                                                  BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                                                  Padding="8,6" FontSize="10" Margin="0,0,8,0">
                                            <ComboBoxItem Content="Starts With" Tag="StartsWith"/>
                                            <ComboBoxItem Content="Equals" Tag="Equals"/>
                                            <ComboBoxItem Content="Contains" Tag="Contains"/>
                                            <ComboBoxItem Content="Ends With" Tag="EndsWith"/>
                                        </ComboBox>

                                        <TextBox x:Name="TxtHostnamePattern" Grid.Column="2"
                                                 Background="{StaticResource BgLight}" Foreground="White"
                                                 BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                                                 Padding="8,6" FontSize="10"
                                                 ToolTip="e.g., 'TN' for computers starting with TN-"/>
                                    </Grid>

                                    <TextBlock Text="💡 Computers matching this pattern will use the local ISO. Others will use cloud update."
                                               Foreground="{StaticResource AccentOrange}" FontSize="8" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Background Service Management -->
                            <TextBlock Text="BACKGROUND SERVICE" Foreground="{StaticResource AccentOrange}"
                                       FontSize="10" FontWeight="Bold" Margin="0,20,0,8"/>

                            <!-- Service Status -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Status:" Foreground="{StaticResource TextMuted}"
                                               FontSize="10" Margin="0,0,12,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtServiceStatus" Text="Not Installed"
                                               Foreground="White" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Last Run:" Foreground="{StaticResource TextMuted}"
                                               FontSize="10" Margin="0,0,12,4"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtServiceLastRun" Text="Never"
                                               Foreground="White" FontSize="10" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Next Run:" Foreground="{StaticResource TextMuted}"
                                               FontSize="10" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtServiceNextRun" Text="N/A"
                                               Foreground="White" FontSize="10"/>
                                </Grid>
                            </Border>

                            <!-- TAG: #TOOLTIPS #BACKGROUND_SERVICE -->
                            <!-- Service Actions -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button x:Name="BtnEnableService" Content="⚡ ENABLE" Style="{StaticResource BtnPrimary}"
                                        Click="BtnEnableService_Click" Padding="12,6" FontSize="10" Margin="0,0,8,0"
                                        ToolTip="Enables and installs the background scanning service using Windows Task Scheduler. Service will automatically scan Active Directory at configured intervals and update the database. Requires administrator privileges to install. Service runs even when application is closed."/>
                                <Button x:Name="BtnDisableService" Content="⏸ DISABLE" Style="{StaticResource BtnGhost}"
                                        Click="BtnDisableService_Click" Padding="12,6" FontSize="10" Margin="0,0,8,0"
                                        ToolTip="Disables the background scanning service. Scheduled scans will stop but service remains installed. Re-enable anytime to resume automatic scanning. Manual scans via the application are still available."/>
                                <Button Content="▶ RUN NOW" Style="{StaticResource BtnGhost}"
                                        Click="BtnRunServiceNow_Click" Padding="12,6" FontSize="10" Margin="0,0,8,0"
                                        ToolTip="Immediately runs a background scan outside the normal schedule. Scans Active Directory for all computers and updates the database. Scan runs asynchronously in background. Results appear in database when complete. Useful for testing or immediate updates."/>
                                <Button Content="🗑 UNINSTALL" Style="{StaticResource BtnDanger}"
                                        Click="BtnUninstallService_Click" Padding="12,6" FontSize="10"
                                        ToolTip="Completely removes the background scanning service from Windows Task Scheduler. All scheduled tasks will be deleted. This action requires administrator privileges. Service can be reinstalled later by clicking ENABLE."/>
                            </StackPanel>

                            <TextBlock Text="ℹ️ The background service uses Windows Task Scheduler to run automatic scans"
                                       Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,0,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION: TOAST NOTIFICATIONS - TAG: #AUTO_UPDATE_UI_ENGINE #USER_CONFIG #SETTINGS -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderNotifications" Header="🔔 TOAST NOTIFICATIONS"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Configure which toast notifications you want to see. Toasts provide non-blocking feedback for actions and events."
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="14"/>

                            <!-- Master Toggle -->
                            <CheckBox x:Name="ChkEnableToasts" Content="Enable Toast Notifications (Master Toggle)"
                                      Foreground="White" FontSize="12" FontWeight="Bold" IsChecked="True"
                                      Margin="0,0,0,16"/>

                            <!-- Toast Types Section -->
                            <TextBlock Text="TOAST TYPES" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}" Margin="0,0,0,8"/>

                            <StackPanel Margin="20,0,0,16">
                                <CheckBox x:Name="ChkToastSuccess" Content="✓ Success Toasts (Green)"
                                          Foreground="White" FontSize="11" IsChecked="True" Margin="0,0,0,8"/>
                                <CheckBox x:Name="ChkToastInfo" Content="ℹ Info Toasts (Blue)"
                                          Foreground="White" FontSize="11" IsChecked="True" Margin="0,0,0,8"/>
                                <CheckBox x:Name="ChkToastWarning" Content="⚠ Warning Toasts (Amber)"
                                          Foreground="White" FontSize="11" IsChecked="True" Margin="0,0,0,8"/>
                                <CheckBox x:Name="ChkToastError" Content="✕ Error Toasts (Red)"
                                          Foreground="White" FontSize="11" IsChecked="True"/>
                            </StackPanel>

                            <!-- Toast Categories Section -->
                            <TextBlock Text="TOAST CATEGORIES" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}" Margin="0,0,0,8"/>

                            <StackPanel Margin="20,0,0,16">
                                <CheckBox x:Name="ChkToastStatus" Content="Status Update Toasts"
                                          Foreground="White" FontSize="11" IsChecked="True" Margin="0,0,0,8"/>
                                <CheckBox x:Name="ChkToastValidation" Content="Validation Message Toasts"
                                          Foreground="White" FontSize="11" IsChecked="True" Margin="0,0,0,8"/>
                                <CheckBox x:Name="ChkToastWorkflow" Content="Workflow Completion Toasts"
                                          Foreground="White" FontSize="11" IsChecked="True" Margin="0,0,0,8"/>
                                <CheckBox x:Name="ChkToastErrors" Content="Error Handler Toasts"
                                          Foreground="White" FontSize="11" IsChecked="True"/>
                            </StackPanel>

                            <!-- Preview Button -->
                            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Test Toast Notifications" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="Preview what toasts will look like with current settings"
                                                   Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <Button Grid.Column="1" Content="🧪 TEST TOASTS" Style="{StaticResource BtnPrimary}"
                                            Click="BtnTestToasts_Click" Padding="12,6" FontSize="10"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="💡 TIP: Disable categories you find distracting while keeping critical error notifications enabled"
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,0" LineHeight="14"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ══════════════════════════════ -->
                <!-- SECTION: KEYBOARD SHORTCUTS - TAG: #AUTO_UPDATE_UI_ENGINE #USER_CONFIG #SETTINGS -->
                <!-- ══════════════════════════════ -->
                <Expander x:Name="ExpanderKeyboardShortcuts" Header="⌨️ KEYBOARD SHORTCUTS"
                          IsExpanded="False" Margin="0,0,0,10">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderDim}"
                            BorderThickness="1" CornerRadius="0,0,6,6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Customize keyboard shortcuts for quick access to common commands. Click on a shortcut to record a new key combination."
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="14"/>

                            <!-- Shortcuts DataGrid -->
                            <DataGrid x:Name="DgShortcuts" AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="{StaticResource BgDark}" Foreground="#FFE0E0E0"
                                      BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                                      RowBackground="#FF1A1A1A" AlternatingRowBackground="#FF151515"
                                      FontSize="10" Height="300" Margin="0,0,0,16">

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource BgDark}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </DataGrid.CellStyle>

                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FF252525"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Command" Binding="{Binding Value.Command}" Width="*" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Shortcut" Binding="{Binding Value.DisplayShortcut}" Width="200" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="Actions" Width="180">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="✏ EDIT" Tag="{Binding Key}" Background="#FF2A2A2A" Foreground="White"
                                                            BorderThickness="0" Padding="10,4" Margin="0,0,8,0" FontSize="9"
                                                            Click="BtnEditShortcut_Click" Cursor="Hand"/>
                                                    <Button Content="↺ RESET" Tag="{Binding Key}" Background="#FF444444" Foreground="White"
                                                            BorderThickness="0" Padding="10,4" FontSize="9"
                                                            Click="BtnResetShortcut_Click" Cursor="Hand"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Reset All Button -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Content="↺ RESET ALL TO DEFAULTS" Style="{StaticResource BtnDanger}"
                                        Click="BtnResetAllShortcuts_Click" Padding="12,6" FontSize="10"/>
                            </StackPanel>

                            <TextBlock Text="💡 TIP: Conflicts will be detected automatically. Press Escape while editing to cancel changes."
                                       Foreground="{StaticResource TextMuted}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,0" LineHeight="14"/>
                        </StackPanel>
                    </Border>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- ════════════════════════════════ -->
        <!-- FOOTER BUTTONS                   -->
        <!-- ════════════════════════════════ -->
        <Border Grid.Row="2" Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderDim}"
                BorderThickness="0,1,0,0" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- TAG: #TOOLTIPS #ACTIONS -->
                <!-- Reset All -->
                <Button Grid.Column="0" Content="🔄 RESET ALL" Style="{StaticResource BtnDanger}"
                        Click="BtnResetAll_Click" Padding="14,8" FontSize="11" Margin="0,0,10,0"
                        ToolTip="Resets ALL settings to factory defaults. This includes database configuration, theme colors, deployment paths, bookmarks, and all user preferences. You will be asked to confirm this action. This cannot be undone."/>

                <!-- TAG: #VERSION_7 #EXPORT_IMPORT - Backup/Restore All Settings -->
                <!-- TAG: #TOOLTIPS #FILE_OPERATIONS -->
                <Button Grid.Column="1" Content="📤 EXPORT ALL" Style="{StaticResource BtnGhost}"
                        Click="BtnExportAllSettings_Click" Padding="14,8" FontSize="10" Margin="0,0,10,0"
                        ToolTip="Exports all application settings to a JSON file for backup or migration to another computer. Includes database configuration, theme colors, deployment settings, bookmarks, and connection profiles. Credentials are NOT exported for security."/>

                <Button Grid.Column="2" Content="📥 IMPORT ALL" Style="{StaticResource BtnGhost}"
                        Click="BtnImportAllSettings_Click" Padding="14,8" FontSize="10"
                        ToolTip="Imports previously exported settings from a JSON file. Restores database configuration, theme colors, deployment settings, bookmarks, and connection profiles. Existing settings will be overwritten. Application restart required after import."/>

                <!-- Spacer -->
                <StackPanel Grid.Column="3"/>

                <!-- TAG: #TOOLTIPS #NAVIGATION -->
                <!-- Cancel -->
                <Button Grid.Column="4" Content="CANCEL" Style="{StaticResource BtnGhost}"
                        Click="BtnCancel_Click" Padding="20,8" Margin="0,0,10,0" FontSize="11"
                        ToolTip="Closes the Options window and discards all unsaved changes. All modifications made during this session will be lost. (Esc)"/>

                <!-- TAG: #TOOLTIPS #ACTIONS -->
                <!-- Apply -->
                <Button Grid.Column="5" Content="APPLY" Style="{StaticResource BtnPrimary}"
                        Click="BtnApply_Click" Padding="20,8" Margin="0,0,10,0" FontSize="11"
                        ToolTip="Saves all settings changes to disk and applies them immediately without closing the Options window. Settings persist across application restarts. (Ctrl+S)"/>

                <!-- Save & Close -->
                <Button Grid.Column="6" Content="SAVE &amp; CLOSE" Style="{StaticResource BtnPrimary}"
                        Click="BtnSaveAndClose_Click" Padding="20,8" FontSize="11"
                        ToolTip="Saves all settings changes to disk, applies them immediately, and closes the Options window. Settings persist across application restarts. (Ctrl+Enter)"/>
            </Grid>
        </Border>

    </Grid>
</Window>
