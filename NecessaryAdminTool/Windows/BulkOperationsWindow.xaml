<Window x:Class="NecessaryAdminTool.Windows.BulkOperationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk Computer Operations"
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgDarkestBrush}"
        Loaded="Window_Loaded"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <!-- TAG: #FEATURE_BULK_OPERATIONS #FLUENT_DESIGN #WINDOW_UI -->

    <Window.Resources>
        <!-- Local accent colors not in app-level resources -->
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#FF3B82F6"/>
        <SolidColorBrush x:Key="SuccessGreenBrush" Color="#FF10B981"/>
        <SolidColorBrush x:Key="ErrorRedBrush" Color="#FFEF4444"/>
        <SolidColorBrush x:Key="WarningAmberBrush" Color="#FFF59E0B"/>

        <!-- Fluent Corner Radius -->
        <CornerRadius x:Key="FluentCornerRadius">6</CornerRadius>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Operation Selection -->
            <RowDefinition Height="Auto"/>  <!-- Target Selection -->
            <RowDefinition Height="Auto"/>  <!-- Execution Options -->
            <RowDefinition Height="*"/>     <!-- Progress/Results -->
            <RowDefinition Height="Auto"/>  <!-- Action Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BgMediumBrush}"
                BorderBrush="{DynamicResource BorderDimBrush}" BorderThickness="1"
                CornerRadius="{StaticResource FluentCornerRadius}"
                Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Bulk Computer Operations" FontSize="24" FontWeight="Bold"
                          Foreground="{DynamicResource AccentOrangeBrush}"/>
                <TextBlock Text="Execute operations on multiple computers in parallel" FontSize="12"
                          Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Operation Selection -->
        <Border Grid.Row="1" Background="{DynamicResource BgMediumBrush}"
                BorderBrush="{DynamicResource BorderDimBrush}" BorderThickness="1"
                CornerRadius="{StaticResource FluentCornerRadius}"
                Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Operation Type:" FontSize="14" FontWeight="SemiBold"
                          Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"
                          Margin="0,0,20,0"/>

                <ComboBox Grid.Column="1" x:Name="CmbOperationType"
                         Height="36" FontSize="14"
                         Background="{DynamicResource BgLightBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderDimBrush}"
                         SelectionChanged="CmbOperationType_SelectionChanged">
                    <ComboBoxItem Content="Ping Test" Tag="PingTest"/>
                    <ComboBoxItem Content="Restart Computers" Tag="RestartComputers"/>
                    <ComboBoxItem Content="Run PowerShell Script" Tag="RunPowerShellScript"/>
                    <ComboBoxItem Content="Install Windows Updates" Tag="InstallWindowsUpdates"/>
                    <ComboBoxItem Content="Enable Service" Tag="EnableService"/>
                    <ComboBoxItem Content="Disable Service" Tag="DisableService"/>
                    <ComboBoxItem Content="Collect System Inventory" Tag="CollectSystemInventory"/>
                    <ComboBoxItem Content="WMI Scan" Tag="WMIScan"/>
                </ComboBox>
            </Grid>
        </Border>

        <!-- Target Selection -->
        <Border Grid.Row="2" Background="{DynamicResource BgMediumBrush}"
                BorderBrush="{DynamicResource BorderDimBrush}" BorderThickness="1"
                CornerRadius="{StaticResource FluentCornerRadius}"
                Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Target Computers" FontSize="14" FontWeight="SemiBold"
                          Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" x:Name="TxtTargets"
                            Height="100" TextWrapping="Wrap" AcceptsReturn="True"
                            Background="{DynamicResource BgLightBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderDimBrush}"
                            Padding="10"
                            VerticalScrollBarVisibility="Auto"
                            Text="Enter computer names (one per line)"/>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Top">
                        <Button x:Name="BtnImportFromCsv" Content="Import CSV" Width="120" Height="32"
                               Margin="0,0,0,8" Click="BtnImportFromCsv_Click"/>
                        <Button x:Name="BtnLoadFromAD" Content="Load from AD" Width="120" Height="32"
                               Click="BtnLoadFromAD_Click"/>
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="TxtTargetCount" Text="0 targets" FontSize="12"
                          Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Execution Options -->
        <Border Grid.Row="3" Background="{DynamicResource BgMediumBrush}"
                BorderBrush="{DynamicResource BorderDimBrush}" BorderThickness="1"
                CornerRadius="{StaticResource FluentCornerRadius}"
                Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Thread Count -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Parallel Threads:" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" x:Name="SliderThreads" Minimum="1" Maximum="50" Value="10"
                               TickFrequency="1" IsSnapToTickEnabled="True"
                               VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="TxtThreadCount" Text="10" FontSize="14"
                                  Foreground="{DynamicResource TextPrimaryBrush}" Margin="10,0,0,0"
                                  VerticalAlignment="Center" Width="30"/>
                    </Grid>
                </StackPanel>

                <!-- Timeout -->
                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                    <TextBlock Text="Timeout (seconds):" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBox x:Name="TxtTimeout" Height="32" Text="300" Margin="0,5,0,0"
                            Background="{DynamicResource BgLightBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderDimBrush}"
                            Padding="8,0"/>
                </StackPanel>

                <!-- Retry Attempts -->
                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                    <TextBlock Text="Retry Attempts:" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBox x:Name="TxtRetryAttempts" Height="32" Text="3" Margin="0,5,0,0"
                            Background="{DynamicResource BgLightBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderDimBrush}"
                            Padding="8,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Progress/Results -->
        <Border Grid.Row="4" Background="{DynamicResource BgMediumBrush}"
                BorderBrush="{DynamicResource BorderDimBrush}" BorderThickness="1"
                CornerRadius="{StaticResource FluentCornerRadius}"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Progress Header -->
                <TextBlock Grid.Row="0" Text="Progress" FontSize="14" FontWeight="SemiBold"
                          Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>

                <!-- Progress Bar -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ProgressBar Grid.Column="0" x:Name="ProgressOverall" Height="24"
                                Background="{DynamicResource BgLightBrush}"
                                Foreground="{DynamicResource AccentOrangeBrush}"
                                BorderBrush="{DynamicResource BorderDimBrush}" BorderThickness="1"/>

                    <TextBlock Grid.Column="1" x:Name="TxtProgress" Text="0%" FontSize="12"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              VerticalAlignment="Center" Margin="10,0,0,0" Width="60" TextAlignment="Right"/>
                </Grid>

                <!-- Results DataGrid -->
                <DataGrid Grid.Row="2" x:Name="ResultsGrid"
                         AutoGenerateColumns="False"
                         IsReadOnly="True"
                         Background="{DynamicResource BgLightBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderDimBrush}"
                         BorderThickness="1"
                         GridLinesVisibility="Horizontal"
                         HeadersVisibility="Column"
                         RowBackground="{DynamicResource BgLightBrush}"
                         AlternatingRowBackground="{DynamicResource BgMediumBrush}"
                         CanUserResizeRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Computer" Binding="{Binding ComputerName}" Width="200"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="100"/>
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                        <DataGridTextColumn Header="Time (ms)" Binding="{Binding ExecutionTimeMs}" Width="100"/>
                        <DataGridTextColumn Header="Retries" Binding="{Binding RetryCount}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Summary Stats -->
                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" x:Name="TxtTotal" Text="Total: 0" FontSize="12"
                              Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" x:Name="TxtSuccess" Text="Success: 0" FontSize="12"
                              Foreground="{StaticResource SuccessGreenBrush}"/>
                    <TextBlock Grid.Column="2" x:Name="TxtFailed" Text="Failed: 0" FontSize="12"
                              Foreground="{StaticResource ErrorRedBrush}"/>
                    <TextBlock Grid.Column="3" x:Name="TxtSkipped" Text="Skipped: 0" FontSize="12"
                              Foreground="{StaticResource WarningAmberBrush}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Action Buttons -->
        <Grid Grid.Row="5" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" x:Name="BtnExecute" Content="Execute Operation" Width="160" Height="40"
                   FontSize="14" FontWeight="SemiBold"
                   Background="{DynamicResource AccentOrangeBrush}"
                   Foreground="White"
                   BorderThickness="0"
                   Click="BtnExecute_Click"
                   Margin="0,0,10,0"/>

            <Button Grid.Column="2" x:Name="BtnCancel" Content="Cancel" Width="120" Height="40"
                   FontSize="14"
                   Background="{DynamicResource BgLightBrush}"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   BorderBrush="{DynamicResource BorderDimBrush}"
                   Click="BtnCancel_Click"
                   IsEnabled="False"
                   Margin="0,0,10,0"/>

            <Button Grid.Column="3" x:Name="BtnExportCsv" Content="Export CSV" Width="120" Height="40"
                   FontSize="14"
                   Background="{DynamicResource BgLightBrush}"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   BorderBrush="{DynamicResource BorderDimBrush}"
                   Click="BtnExportCsv_Click"
                   IsEnabled="False"
                   Margin="0,0,10,0"/>

            <Button Grid.Column="4" x:Name="BtnClose" Content="Close" Width="120" Height="40"
                   FontSize="14"
                   Background="{DynamicResource BgLightBrush}"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   BorderBrush="{DynamicResource BorderDimBrush}"
                   Click="BtnClose_Click"/>
        </Grid>
    </Grid>
</Window>
