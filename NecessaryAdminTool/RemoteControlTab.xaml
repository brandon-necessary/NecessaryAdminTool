<UserControl x:Class="NecessaryAdminTool.RemoteControlTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgDarkestBrush}">

    <!-- TAG: #REMOTE_CONTROL #RMM_TAB #UI -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel MaxWidth="1200">

            <!-- QUICK LAUNCH SECTION -->
            <Border Background="{DynamicResource BgDarkBrush}" BorderBrush="{DynamicResource BgLightBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🚀 QUICK LAUNCH" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource AccentOrangeBrush}" Margin="0,0,0,12"/>

                    <TextBlock Text="Launch remote control session to target device"
                               Foreground="{DynamicResource AccentZincBrush}" FontSize="10" Margin="0,0,0,12"/>

                    <!-- Target Input -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="TxtRemoteTarget" Grid.Column="0"
                                 Background="{DynamicResource BgDarkestBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BgLightBrush}" Padding="10,8" FontSize="12"
                                 Text="{Binding CurrentTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Enter hostname or IP address..."
                                                                       Foreground="#FF555555" FontSize="12" Margin="10,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <Button x:Name="BtnRecentTargets" Grid.Column="1" Content="📋 RECENT ▼"
                                Background="{DynamicResource BgLightBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                                Padding="12,8" Margin="8,0,0,0" FontSize="10" Cursor="Hand"
                                Click="BtnRecentTargets_Click"/>
                    </Grid>

                    <!-- Tool Buttons -->
                    <ItemsControl x:Name="QuickLaunchButtons" Margin="0,0,0,15">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding DisplayName}" Tag="{Binding ToolType}"
                                        Click="QuickLaunch_Click"
                                        Background="{DynamicResource AccentOrangeBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                                        Padding="20,10" Margin="0,0,8,8" FontSize="11" FontWeight="Bold"
                                        Cursor="Hand" IsEnabled="{Binding IsConfigured}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Last Connection Info -->
                    <TextBlock x:Name="TxtLastConnection" Foreground="{DynamicResource TextMutedBrush}" FontSize="9"
                               Text="No recent connections"/>
                </StackPanel>
            </Border>

            <!-- TOOL CONFIGURATION SECTION -->
            <Border Background="{DynamicResource BgDarkBrush}" BorderBrush="{DynamicResource BgLightBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="⚙️ TOOL CONFIGURATION" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource AccentOrangeBrush}" Margin="0,0,0,12"/>

                    <TextBlock Text="Configure and test remote control integrations (all disabled by default for security)"
                               Foreground="{DynamicResource AccentZincBrush}" FontSize="10" Margin="0,0,0,12"/>

                    <!-- Configuration DataGrid -->
                    <DataGrid x:Name="GridToolConfig" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              Background="{DynamicResource BgDarkestBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BgLightBrush}" BorderThickness="1"
                              RowBackground="{DynamicResource BgDarkBrush}" AlternatingRowBackground="{DynamicResource BgDarkestBrush}"
                              FontSize="10" Height="250" Margin="0,0,0,15">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource BgDarkestBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentOrangeBrush}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="10"/>
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BgLightBrush}"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="10,6"/>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tool Name" Binding="{Binding ToolName}" Width="150" IsReadOnly="True"/>

                            <DataGridTemplateColumn Header="Enabled" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" Click="ToolEnabled_Changed"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Status" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StatusDisplay}"
                                                   Foreground="{Binding StatusColor}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Actions" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="⚙️ CONFIGURE" Tag="{Binding}"
                                                    Background="{DynamicResource BgLightBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                                                    Padding="10,4" Margin="0,0,8,0" FontSize="9"
                                                    Click="Configure_Click" Cursor="Hand"/>
                                            <Button Content="🧪 TEST" Tag="{Binding}"
                                                    Background="{DynamicResource BgLightBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                                                    Padding="10,4" FontSize="9"
                                                    Click="Test_Click" Cursor="Hand"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Foreground="{DynamicResource TextMutedBrush}" FontSize="9" Margin="0,0,0,8">
                        💡 Click CONFIGURE to set up server URLs, credentials, and connection settings for each tool
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- GLOBAL SETTINGS SECTION -->
            <Border Background="{DynamicResource BgDarkBrush}" BorderBrush="{DynamicResource BgLightBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🌐 GLOBAL SETTINGS" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource AccentOrangeBrush}" Margin="0,0,0,12"/>

                    <CheckBox x:Name="ChkShowConfirmation" Content="Show confirmation dialog before connecting"
                              Foreground="{DynamicResource TextPrimaryBrush}" FontSize="10" Margin="0,0,0,8" IsChecked="True"/>

                    <CheckBox x:Name="ChkLogSessions" Content="Log all remote control sessions (audit trail)"
                              Foreground="{DynamicResource TextPrimaryBrush}" FontSize="10" Margin="0,0,0,8" IsChecked="True"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Connection timeout:" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="TxtTimeout" Text="30" Width="50"
                                 Background="{DynamicResource BgDarkestBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BgLightBrush}" Padding="6,4" FontSize="10"/>
                        <TextBlock Text="seconds" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Retry attempts:" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="TxtRetries" Text="2" Width="50"
                                 Background="{DynamicResource BgDarkestBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BgLightBrush}" Padding="6,4" FontSize="10"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="📤 EXPORT CONFIG" x:Name="BtnExportConfig"
                                Background="{DynamicResource BgLightBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                                Padding="12,8" Margin="0,0,8,0" FontSize="10" Cursor="Hand"
                                Click="ExportConfig_Click"/>
                        <Button Content="📥 IMPORT CONFIG" x:Name="BtnImportConfig"
                                Background="{DynamicResource BgLightBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                                Padding="12,8" Margin="0,0,8,0" FontSize="10" Cursor="Hand"
                                Click="ImportConfig_Click"/>
                        <Button Content="🔄 RESET ALL" x:Name="BtnResetAll"
                                Background="{DynamicResource DangerBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                                Padding="12,8" FontSize="10" Cursor="Hand"
                                Click="ResetAll_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- CONNECTION HISTORY SECTION -->
            <Border Background="{DynamicResource BgDarkBrush}" BorderBrush="{DynamicResource BgLightBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="20">
                <StackPanel>
                    <TextBlock Text="📜 CONNECTION HISTORY" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource AccentOrangeBrush}" Margin="0,0,0,12"/>

                    <TextBlock Text="Recent remote control connections (last 10):"
                               Foreground="{DynamicResource AccentZincBrush}" FontSize="10" Margin="0,0,0,12"/>

                    <ListBox x:Name="ListConnectionHistory" Background="{DynamicResource BgDarkestBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BgLightBrush}" BorderThickness="1"
                             Height="150" Margin="0,0,0,12" FontSize="10" Padding="8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding TimeAgo}" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <Run Text=": "/>
                                    <Run Text="{Binding ToolName}" Foreground="{DynamicResource AccentOrangeBrush}"/>
                                    <Run Text=" → "/>
                                    <Run Text="{Binding Target}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding Status}" Foreground="{Binding StatusColor}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="📊 VIEW FULL HISTORY" x:Name="BtnViewHistory"
                                Background="{DynamicResource BgLightBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                                Padding="12,8" Margin="0,0,8,0" FontSize="10" Cursor="Hand"/>
                        <Button Content="🗑️ CLEAR HISTORY" x:Name="BtnClearHistory"
                                Background="{DynamicResource BgLightBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                                Padding="12,8" FontSize="10" Cursor="Hand"
                                Click="ClearHistory_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
