<Window x:Class="NecessaryAdminTool.ConnectionProfileEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Connection Profile" Height="500" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#FF0D0D0D" ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <!-- TAG: #VERSION_7 #CONNECTION_PROFILES #UI -->

    <Window.Resources>
        <SolidColorBrush x:Key="AccentOrange" Color="#FFFF8533"/>
        <SolidColorBrush x:Key="TextMuted" Color="#FFA1A1AA"/>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FF1E1E1E" BorderBrush="{StaticResource AccentOrange}"
                BorderThickness="0,0,0,2" Padding="16,12" Margin="0,0,0,20">
            <TextBlock x:Name="TxtHeader" Text="➕ NEW CONNECTION PROFILE"
                       Foreground="{StaticResource AccentOrange}"
                       FontSize="14" FontWeight="Bold"/>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Profile Name -->
                <TextBlock Text="Profile Name *" Foreground="{StaticResource TextMuted}"
                           FontSize="10" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtProfileName" Padding="10,8" FontSize="11"
                         Background="#FF1E1E1E" Foreground="White"
                         BorderBrush="#FF3C3C3C" BorderThickness="1"
                         Margin="0,0,0,16"/>

                <!-- Domain Controller -->
                <TextBlock Text="Domain Controller (hostname or IP) *" Foreground="{StaticResource TextMuted}"
                           FontSize="10" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtDomainController" Padding="10,8" FontSize="11"
                         Background="#FF1E1E1E" Foreground="White"
                         BorderBrush="#FF3C3C3C" BorderThickness="1"
                         Margin="0,0,0,16"/>

                <!-- Username -->
                <TextBlock Text="Username (DOMAIN\user or user@domain.com) *" Foreground="{StaticResource TextMuted}"
                           FontSize="10" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtUsername" Padding="10,8" FontSize="11"
                         Background="#FF1E1E1E" Foreground="White"
                         BorderBrush="#FF3C3C3C" BorderThickness="1"
                         Margin="0,0,0,16"/>

                <!-- Domain -->
                <TextBlock Text="Domain Name" Foreground="{StaticResource TextMuted}"
                           FontSize="10" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtDomain" Padding="10,8" FontSize="11"
                         Background="#FF1E1E1E" Foreground="White"
                         BorderBrush="#FF3C3C3C" BorderThickness="1"
                         Margin="0,0,0,16"/>

                <!-- Environment -->
                <TextBlock Text="Environment Type" Foreground="{StaticResource TextMuted}"
                           FontSize="10" Margin="0,0,0,4"/>
                <ComboBox x:Name="ComboEnvironment" Padding="10,8" FontSize="11"
                          Background="#FF1E1E1E" Foreground="White"
                          BorderBrush="#FF3C3C3C" BorderThickness="1"
                          Margin="0,0,0,16">
                    <ComboBoxItem Content="Production" IsSelected="True"/>
                    <ComboBoxItem Content="Staging"/>
                    <ComboBoxItem Content="Test"/>
                    <ComboBoxItem Content="Development"/>
                    <ComboBoxItem Content="Other"/>
                </ComboBox>

                <!-- Description -->
                <TextBlock Text="Description / Notes" Foreground="{StaticResource TextMuted}"
                           FontSize="10" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtDescription" Padding="10,8" FontSize="11"
                         Background="#FF1E1E1E" Foreground="White"
                         BorderBrush="#FF3C3C3C" BorderThickness="1"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         Height="60" Margin="0,0,0,8"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="💾 SAVE PROFILE" x:Name="BtnSave" Click="BtnSave_Click"
                    Padding="16,8" FontSize="11" FontWeight="SemiBold"
                    BorderThickness="0" Foreground="White" Margin="0,0,8,0">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFFF8533" Offset="0"/>
                        <GradientStop Color="#FFCC6B29" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

            <Button Grid.Column="2" Content="CANCEL" x:Name="BtnCancel" Click="BtnCancel_Click"
                    Background="#FF3C3C3C" Foreground="White" BorderThickness="0"
                    Padding="16,8" FontSize="11" FontWeight="SemiBold"/>
        </Grid>
    </Grid>
</Window>
