<Window x:Class="NecessaryAdminTool.RemediationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NecessaryAdminTool"
        Title="Automated Remediation" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgDarkestBrush}" ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <!-- TAG: #VERSION_7.1 #REMEDIATION #UI -->

    <Window.Resources>
        <!-- Local shadows removed — uses app-level DynamicResource brushes -->

        <!-- Pulse Animation for Progress -->
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.3" Duration="0:0:1" AutoReverse="True"/>
        </Storyboard>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource AccentOrangeBrush}"
                BorderThickness="0,0,0,2" Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🔧 AUTOMATED REMEDIATION" Foreground="{DynamicResource AccentOrangeBrush}"
                               FontSize="16" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtActionName" Text="Action: Restart Windows Update"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="1" Background="{DynamicResource BgLightBrush}" BorderBrush="{DynamicResource BorderDimBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="12,8">
                    <StackPanel>
                        <TextBlock Text="PROGRESS" Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="9" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtProgress" Text="0 / 0" Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="14" FontWeight="Bold" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Overall Progress Bar -->
        <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderDimBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Overall Progress" Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="TxtPercentage" Text="0%"
                               Foreground="{DynamicResource AccentOrangeBrush}" FontSize="12" FontWeight="Bold"/>
                </Grid>

                <ProgressBar x:Name="ProgressBarOverall" Height="24" Background="{DynamicResource BgLightBrush}"
                             BorderBrush="{DynamicResource BorderDimBrush}" BorderThickness="1" Maximum="100">
                    <ProgressBar.Foreground>
                        <SolidColorBrush Color="{DynamicResource AccentOrange}"/>
                    </ProgressBar.Foreground>
                </ProgressBar>

                <TextBlock x:Name="TxtCurrentStatus" Text="Ready to start..."
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                           FontStyle="Italic" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Results List -->
        <Border Grid.Row="2" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderDimBrush}"
                BorderThickness="1" CornerRadius="8" Padding="0" Margin="0,0,0,16">
            <DataGrid x:Name="GridResults" AutoGenerateColumns="False" IsReadOnly="True"
                      Background="{DynamicResource BgDarkBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BgLightBrush}"
                      BorderThickness="0" HeadersVisibility="Column"
                      SelectionMode="Single">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource BgLightBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource AccentOrangeBrush}"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderDimBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="{DynamicResource BgDarkBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF252525"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Status" Width="60">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Success">
                                <Binding.Converter>
                                    <local:BoolToIconConverter/>
                                </Binding.Converter>
                            </Binding>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Computer" Binding="{Binding Hostname}" Width="*" MinWidth="150"/>
                    <DataGridTextColumn Header="Result" Binding="{Binding Message}" Width="2*" MinWidth="250"/>
                    <DataGridTextColumn Header="Duration" Binding="{Binding Duration, StringFormat='{}{0:mm\\:ss}'}" Width="80"/>
                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Summary Statistics -->
        <Border Grid.Row="3" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderDimBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="TOTAL" Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="9" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtTotalCount" Text="0" Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="20" FontWeight="Bold"/>
                </StackPanel>

                <!-- Success -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="SUCCESS" Foreground="{DynamicResource AccentGreenBrush}"
                               FontSize="9" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtSuccessCount" Text="0" Foreground="{DynamicResource AccentGreenBrush}"
                               FontSize="20" FontWeight="Bold"/>
                </StackPanel>

                <!-- Failed -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="FAILED" Foreground="{DynamicResource ErrorBrush}"
                               FontSize="9" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtFailedCount" Text="0" Foreground="{DynamicResource ErrorBrush}"
                               FontSize="20" FontWeight="Bold"/>
                </StackPanel>

                <!-- Avg Duration -->
                <StackPanel Grid.Column="3">
                    <TextBlock Text="AVG TIME" Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="9" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtAvgDuration" Text="0s" Foreground="{DynamicResource AccentOrangeBrush}"
                               FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Action Buttons -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="⏸️ CANCEL" x:Name="BtnCancel"
                    Click="BtnCancel_Click"
                    Background="{DynamicResource ErrorBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                    Padding="20,10" FontSize="11" FontWeight="SemiBold"
                    Margin="0,0,8,0" Visibility="Collapsed"/>

            <Button Grid.Column="2" Content="✅ CLOSE" x:Name="BtnClose"
                    Click="BtnClose_Click"
                    BorderThickness="0" Foreground="{DynamicResource TextPrimaryBrush}"
                    Padding="20,10" FontSize="11" FontWeight="SemiBold"
                    Background="{DynamicResource AccentOrangeBrush}"/>
        </Grid>
    </Grid>
</Window>
